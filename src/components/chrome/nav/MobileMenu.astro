---
import { XIcon, ChevronDownIcon } from '@/icons';
import { Logo } from '@/components/brand';
import { Button } from '@/components/ui/button';
import { Paths } from '@/lib/utils/paths';
import { navLinks } from './nav-data';
---

<!-- Slide-from-right drawer.
     IMPORTANT: this component MUST render OUTSIDE the <nav> element. The
     nav has `backdrop-filter: blur(...)` which makes it a containing
     block for `position: fixed` descendants — placing the drawer inside
     the nav would clip the fixed-positioning to the 68px nav box.
     The trigger button lives inline in Nav.astro (see MobileMenuTrigger
     usage), querySelector-based JS in nav.client.ts wires the two
     together via data-attributes. -->
<div
    id="mobile-menu-root"
    class="mobile-menu-root md:hidden"
    data-mobile-menu-root
    aria-hidden="true"
>
    <div
        class="mobile-menu-backdrop"
        data-mobile-menu-backdrop
        aria-hidden="true"
    >
    </div>

    <div
        class="mobile-menu-panel"
        role="dialog"
        aria-modal="true"
        aria-label="Site menu"
    >
        <!-- Drawer header: logo + close -->
        <div
            class="flex items-center justify-between px-5 py-4 border-b border-line"
        >
            <Logo class="h-7 w-auto" label="Travelity" />
            <button
                type="button"
                class="inline-flex items-center justify-center w-10 h-10 rounded-md border border-line bg-transparent cursor-pointer"
                aria-label="Close menu"
                data-mobile-menu-close
            >
                <XIcon class="w-5 h-5 text-ink" aria-hidden="true" />
            </button>
        </div>

        <!-- Nav items + accordion subsections -->
        <nav class="px-4 py-2 flex-1 overflow-y-auto">
            <ul class="list-none p-0 m-0">
                {
                    navLinks.map((link, i) => {
                        const isAccordion = !!link.items?.length;
                        return isAccordion ? (
                            <li
                                data-mobile-section
                                class="border-b border-line last:border-0"
                            >
                                <button
                                    type="button"
                                    class="w-full flex items-center justify-between px-2 py-4 font-body text-[16px] font-medium text-ink cursor-pointer"
                                    aria-expanded="false"
                                    aria-controls={`mobile-section-${i}`}
                                    data-mobile-section-trigger
                                >
                                    {link.label}
                                    <ChevronDownIcon
                                        class="w-4 h-4 mobile-section-chevron transition-transform duration-200"
                                        aria-hidden="true"
                                    />
                                </button>
                                <div
                                    id={`mobile-section-${i}`}
                                    class="mobile-section-body"
                                >
                                    <ul class="list-none p-0 m-0 pb-3 space-y-0.5">
                                        {link.items!.map((item) => (
                                            <li>
                                                <a
                                                    href={item.href}
                                                    class="block px-3 py-2 rounded-md font-body text-[14px] text-ink no-underline hover:bg-surface-alt"
                                                >
                                                    <span class="block font-medium">
                                                        {item.label}
                                                    </span>
                                                    <span class="block text-[12.5px] text-ink-muted mt-0.5">
                                                        {item.description}
                                                    </span>
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </li>
                        ) : (
                            <li class="border-b border-line last:border-0">
                                <a
                                    href={link.href}
                                    class="block px-2 py-4 font-body text-[16px] font-medium text-ink no-underline"
                                >
                                    {link.label}
                                </a>
                            </li>
                        );
                    })
                }
            </ul>
        </nav>

        <!-- Drawer footer: primary CTA so the menu always offers an action -->
        <div class="px-5 py-4 border-t border-line">
            <Button href={Paths.BOOK_DEMO} size="md" class="w-full">
                Book a demo
            </Button>
        </div>
    </div>
</div>

<style>
    /* Root container — full-viewport overlay. Pointer-events disabled
       when closed so the page below is interactive; enabled when open
       so the backdrop catches clicks. */
    .mobile-menu-root {
        position: fixed;
        inset: 0;
        z-index: 90;
        pointer-events: none;
    }
    .mobile-menu-root.open {
        pointer-events: auto;
    }

    /* Backdrop scrim. Fades in 40% black behind the drawer. */
    .mobile-menu-backdrop {
        position: absolute;
        inset: 0;
        background: hsl(var(--ink) / 0);
        transition: background 240ms ease-out;
        pointer-events: none;
    }
    .mobile-menu-root.open .mobile-menu-backdrop {
        background: hsl(var(--ink) / 0.4);
        pointer-events: auto;
    }

    /* Drawer panel. Slides in from off-screen right. Constrained to a
       reasonable max-width on tablet; full-width-minus-some on phone. */
    .mobile-menu-panel {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        width: 85%;
        max-width: 380px;
        background: hsl(var(--paper));
        box-shadow: -16px 0 32px -8px hsl(var(--ink) / 0.18);
        transform: translateX(100%);
        transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
    }
    .mobile-menu-root.open .mobile-menu-panel {
        transform: translateX(0);
    }

    /* Accordion section body — closed by default */
    .mobile-section-body {
        max-height: 0;
        overflow: hidden;
        transition: max-height 240ms ease-out;
    }
    [data-mobile-section].open .mobile-section-body {
        max-height: 600px;
    }
    [data-mobile-section].open .mobile-section-chevron {
        transform: rotate(180deg);
    }

    @media (prefers-reduced-motion: reduce) {
        .mobile-menu-backdrop,
        .mobile-menu-panel,
        .mobile-section-body,
        .mobile-section-chevron {
            transition: none !important;
            transform: none !important;
        }
        .mobile-menu-root.open .mobile-menu-panel {
            transform: none !important;
        }
    }
</style>
