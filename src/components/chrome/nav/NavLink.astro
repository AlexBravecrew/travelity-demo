---
import { cn } from '@/lib/utils/cn';
import { ChevronDownIcon } from '@/icons';
import type { NavLinkData } from './nav-data';

export interface Props {
    link: NavLinkData;
    /** Index of this link, used to generate stable IDs for ARIA. */
    index: number;
    /** True when this link's section is the pinned (current) section. */
    isActive?: boolean;
    class?: string;
}

const { link, index, isActive = false, class: className } = Astro.props;
const isDropdown = !!link.items?.length;
const subrowId = `nav-subrow-panel-${index}`;

const linkClasses = cn(
    'nav-link',
    'inline-flex items-center gap-1',
    'px-[14px] py-2 rounded-md',
    'font-body text-[14px] font-medium',
    'no-underline cursor-pointer',
    'transition-all duration-150',
    'hover:bg-[hsl(var(--ink)/0.04)]',
    'focus-visible:bg-[hsl(var(--ink)/0.04)]',
    isActive
        ? 'text-travelity-teal hover:text-travelity-teal focus-visible:text-travelity-teal'
        : 'text-ink-muted hover:text-ink focus-visible:text-ink',
    className,
);

const chevronClasses = cn(
    'w-[11px] h-[11px]',
    'transition-transform duration-200',
);
---

{
    isDropdown ? (
        <div
            class="nav-item relative"
            data-nav-item
            data-section-label={link.label}
        >
            <button
                type="button"
                class={linkClasses}
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls={subrowId}
                data-nav-trigger
            >
                {link.label}
                <ChevronDownIcon class={chevronClasses} aria-hidden="true" />
            </button>
        </div>
    ) : (
        <a href={link.href} class={linkClasses}>
            {link.label}
        </a>
    )
}

<style>
    /* When parent .nav-item is .open (hover-previewing), rotate the chevron.
       The chevron is the only <svg> inside the button, so the descendant
       selector is safe. */
    :global(.nav-item.open) .nav-link svg {
        transform: rotate(180deg);
    }

    @media (prefers-reduced-motion: reduce) {
        .nav-link svg {
            transition: none !important;
        }
    }
</style>
