---
import { cn } from '@/lib/utils/cn';
import { Paths } from '@/lib/utils/paths';
import { TravelityMark } from '@/components/decorative/travelity-mark';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends Omit<HTMLAttributes<'a'>, 'href'> {
    /** Override the link target. Defaults to home (`/`). */
    href?: string;
    /** Forwarded to underlying element. */
    class?: string;
}

const { href = Paths.HOME, class: className, ...rest } = Astro.props;

const classes = cn(
    'inline-flex items-center gap-[10px]',
    'font-display text-[20px] font-bold tracking-[-0.025em]',
    'text-travelity-blue no-underline',
    className,
);
---

<a href={href} class={classes} {...rest}>
    <TravelityMark class="w-7 h-7" gradientId="travelity-logo-gradient" />
    <span>Travelity</span>
</a>
