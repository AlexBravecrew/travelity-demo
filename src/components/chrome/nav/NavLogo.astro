---
import { cn } from '@/lib/utils/cn';
import { Paths } from '@/lib/utils/paths';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends Omit<HTMLAttributes<'a'>, 'href'> {
    /** Override the link target. Defaults to home (`/`). */
    href?: string;
    /** Forwarded to underlying element. */
    class?: string;
}

const { href = Paths.HOME, class: className, ...rest } = Astro.props;

const classes = cn(
    'inline-flex items-center gap-[10px]',
    'font-display text-[20px] font-bold tracking-[-0.025em]',
    'text-travelity-blue no-underline',
    className,
);
---

<a href={href} class={classes} {...rest}>
    <svg viewBox="0 0 32 32" fill="none" class="w-7 h-7" aria-hidden="true">
        <defs>
            <linearGradient
                id="travelity-logo-gradient"
                x1="0%"
                y1="0%"
                x2="100%"
                y2="100%"
            >
                <stop offset="0%" stop-color="hsl(218 50% 65%)"></stop>
                <stop offset="100%" stop-color="hsl(194 56% 65%)"></stop>
            </linearGradient>
        </defs>
        <path
            d="M4 6 L16 26 L28 6 L22 6 L16 16 L10 6 Z"
            fill="url(#travelity-logo-gradient)"></path>
    </svg>
    <span>Travelity</span>
</a>
