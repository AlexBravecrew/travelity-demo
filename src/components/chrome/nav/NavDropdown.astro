---
import NavDropdownItem from './NavDropdownItem.astro';
import type { NavDropdownItemData } from './nav-data';

export interface Props {
    items: NavDropdownItemData[];
    /** ID for ARIA association with the trigger button. Required. */
    id: string;
}

const { items, id } = Astro.props;
---

<div
    id={id}
    role="menu"
    class:list={[
        'nav-dropdown',
        'absolute top-[calc(100%+8px)] left-0 z-[100]',
        'min-w-[280px] p-2',
        'bg-paper border border-line rounded-xl',
        'shadow-[0_1px_0_hsl(0_0%_100%)_inset,0_16px_32px_-8px_hsl(0_0%_0%/0.12),0_4px_8px_-2px_hsl(0_0%_0%/0.06)]',
        'opacity-0 invisible -translate-y-1',
        'transition-[opacity,transform,visibility] duration-[150ms]',
    ]}
>
    {
        items.map((item) => (
            <NavDropdownItem
                href={item.href}
                label={item.label}
                description={item.description}
                role="menuitem"
            />
        ))
    }
</div>

<style>
    /* The `.open` class is added by nav.client.ts on the parent .nav-item.
       This selector targets *this* dropdown when its parent is open. */
    :global(.nav-item.open) .nav-dropdown {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
        .nav-dropdown {
            transition:
                opacity 1ms,
                visibility 1ms;
            transform: none !important;
        }
    }
</style>
