---
import { Logo } from '@/components/brand';
import FooterColumn from './FooterColumn.astro';
import { Paths } from '@/lib/utils/paths';
import { MailIcon, PhoneIcon } from '@/icons';
---

<footer class="bg-ink text-[hsl(0_0%_90%)] pt-16 pb-8 relative">
    <div class="container mx-auto px-6">
        <div
            class="grid grid-cols-1 lg:grid-cols-[2fr_2fr_3fr] gap-10 lg:gap-16 mb-12"
        >
            <!-- Brand column -->
            <div>
                <div class="footer-brand-logo mb-4">
                    <a
                        href={Paths.HOME}
                        aria-label="Travelity home"
                        class="footer-logo-link inline-flex items-center"
                    >
                        <Logo class="h-6 w-auto" label="Travelity" />
                    </a>
                </div>
                <p
                    class="font-serif italic text-base text-[hsl(0_0%_75%)] leading-normal max-w-[30ch] mb-5"
                >
                    Tour Management Software Built for Travel Businesses.
                </p>

                <!-- Socials. SVG paths are the official brand glyphs
                     (from simple-icons). -->
                <ul class="flex items-center gap-3 list-none p-0 m-0">
                    <li>
                        <a
                            href="https://www.youtube.com/@Travelity-app"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Travelity on YouTube"
                            class="footer-social inline-flex items-center justify-center w-9 h-9 rounded-full text-[hsl(0_0%_75%)] hover:text-white bg-white/5 hover:bg-white/10 transition-colors"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                width="18"
                                height="18"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                                ></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://www.instagram.com/travelity.app?igsh=a2hydHRiM3N0b2Vx&utm_source=qr"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Travelity on Instagram"
                            class="footer-social inline-flex items-center justify-center w-9 h-9 rounded-full text-[hsl(0_0%_75%)] hover:text-white bg-white/5 hover:bg-white/10 transition-colors"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                width="18"
                                height="18"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                                ></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://www.facebook.com/share/1GVB5Pjcza/?mibextid=wwXIfr"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Travelity on Facebook"
                            class="footer-social inline-flex items-center justify-center w-9 h-9 rounded-full text-[hsl(0_0%_75%)] hover:text-white bg-white/5 hover:bg-white/10 transition-colors"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                width="18"
                                height="18"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                                ></path>
                            </svg>
                        </a>
                    </li>
                    <li>
                        <a
                            href="https://www.linkedin.com/company/travelity.app/"
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label="Travelity on LinkedIn"
                            class="footer-social inline-flex items-center justify-center w-9 h-9 rounded-full text-[hsl(0_0%_75%)] hover:text-white bg-white/5 hover:bg-white/10 transition-colors"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                width="18"
                                height="18"
                                fill="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                ></path>
                            </svg>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Contact column -->
            <div>
                <h5
                  class="font-mono text-[11px] font-semibold uppercase tracking-widest text-[hsl(0_0%_60%)] mb-4"
                >
                    Get in touch
                </h5>
                <ul class="list-none p-0 m-0 space-y-3">
                    <li class="flex items-center gap-2.5">
                        <MailIcon
                          class="w-4 h-4 text-[hsl(0_0%_60%)] shrink-0"
                        />
                        <span class="font-body text-sm text-[hsl(0_0%_80%)]">
                            support@travelity.app
                        </span>
                    </li>
                    <li class="flex items-center gap-2.5">
                        <MailIcon
                          class="w-4 h-4 text-[hsl(0_0%_60%)] shrink-0"
                        />
                        <span class="font-body text-sm text-[hsl(0_0%_80%)]">
                            sales@travelity.app
                        </span>
                    </li>
                    <li class="flex items-center gap-2.5">
                        <PhoneIcon
                          class="w-4 h-4 text-[hsl(0_0%_60%)] shrink-0"
                        />
                        <span class="font-body text-sm text-[hsl(0_0%_80%)]">
                            +1 (302) 244-7375
                        </span>
                    </li>
                </ul>
            </div>

            <div class="grid grid-cols-2 gap-8">
                <FooterColumn
                    title="Company"
                    links={[
                        { label: 'Pricing', href: Paths.PRICING },
                        { label: 'Book a Demo', href: Paths.BOOK_DEMO },
                        { label: 'Contact', href: Paths.CONTACT },
                    ]}
                />

                <FooterColumn
                    title="Resources"
                    links={[
                        { label: 'FAQ', href: Paths.FAQ },
                        { label: 'Our Story', href: Paths.OUR_STORY },
                    ]}
                />
            </div>
        </div>

        <div
            class="border-t border-white/10 pt-6 flex flex-wrap justify-between gap-3 font-mono text-[11.5px] text-[hsl(0_0%_60%)]"
        >
            <span>© 2026 BraveCrew Inc.</span>
            <div class="flex flex-wrap gap-4.5">
                <a
                    href={Paths.LEGAL_TERMS}
                    class="text-[hsl(0_0%_60%)] no-underline hover:text-white transition-colors"
                    >Terms and Conditions</a
                >
                <a
                    href={Paths.LEGAL_PRIVACY}
                    class="text-[hsl(0_0%_60%)] no-underline hover:text-white transition-colors"
                    >Privacy Policy</a
                >
            </div>
        </div>
    </div>
</footer>
