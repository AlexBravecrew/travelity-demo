---
import { CheckCircleIcon, MailIcon } from '@/icons';
---

<div class="rounded-xl border border-line bg-paper p-8 md:p-10 text-center">
    <div
        class="inline-flex w-12 h-12 rounded-full bg-[hsl(var(--success)/0.12)] text-[hsl(var(--success))] items-center justify-center mb-5"
    >
        <CheckCircleIcon class="w-6 h-6" stroke-width="2" aria-hidden="true" />
    </div>

    <h3
        class="font-display text-[22px] font-semibold text-ink leading-[1.25] tracking-[-0.02em] mb-2"
    >
        Thanks — message received.
    </h3>

    <p
        class="font-body text-[15px] text-ink-muted leading-[1.55] max-w-[42ch] mx-auto mb-6"
    >
        We read everything and reply within one business day.
    </p>

    <div
        class="inline-flex items-center gap-2 font-mono text-xs text-ink-muted bg-surface-alt border border-line rounded-md px-3 py-2"
    >
        <MailIcon class="w-3.5 h-3.5" stroke-width="1.75" aria-hidden="true" />
        <span data-success-email></span>
    </div>
</div>
