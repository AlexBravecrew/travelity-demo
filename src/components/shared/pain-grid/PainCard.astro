---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    /** Number label (e.g. "Problem 01"). */
    num: string;
    title: string;
    description: string;
    class?: string;
}

const { num, title, description, class: className, ...rest } = Astro.props;
---

<div
    class={cn(
        'pain-card relative bg-paper border border-line rounded-xl p-6',
        className,
    )}
    {...rest}
>
    <span
        class="absolute top-6 left-6 w-6 h-px"
        style="background: hsl(var(--destructive) / 0.55);"
        aria-hidden="true"
    >
    </span>
    <div
        class="font-mono text-[11px] font-semibold uppercase tracking-[0.10em] text-ink-muted pt-3.5 mb-2"
    >
        {num}
    </div>
    <h4
        class="font-display text-[16px] font-semibold leading-[1.3] text-ink mb-2"
    >
        {title}
    </h4>
    <p class="text-[14px] text-ink-muted leading-[1.6] m-0">
        {description}
    </p>
</div>
