---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    /** Quote text. */
    quote: string;
    /** Person/role name (e.g. "Tour Operator"). */
    who: string;
    /** Location (e.g. "Yerevan, Armenia"). */
    where: string;
    /** Optional avatar image src. If absent, a colored circle is used. */
    avatarSrc?: string;
    class?: string;
}

const { quote, who, where, avatarSrc, class: className, ...rest } = Astro.props;
---

<div
    class={cn(
        'p-7 rounded-xl bg-paper border border-line',
        'shadow-[0_1px_2px_hsl(0_0%_0%/0.04)]',
        'flex flex-col',
        className,
    )}
    {...rest}
>
    <div
        class="font-serif italic leading-none text-travelity-teal mb-2"
        style="font-size: 48px; opacity: 0.6;"
        aria-hidden="true"
    >
        "
    </div>

    <p class="font-body text-[15px] text-ink leading-[1.6] m-0 mb-6 flex-1">
        {quote}
    </p>

    <div class="flex items-center gap-3 pt-4 border-t border-line">
        {
            avatarSrc ? (
                <img
                    src={avatarSrc}
                    alt=""
                    class="w-10 h-10 rounded-full object-cover"
                    loading="lazy"
                />
            ) : (
                <div
                    class="w-10 h-10 rounded-full flex-shrink-0"
                    style="background: linear-gradient(135deg, hsl(var(--travelity-blue)) 0%, hsl(var(--travelity-teal)) 100%);"
                    aria-hidden="true"
                />
            )
        }
        <div>
            <div
                class="font-display text-[14px] font-semibold text-ink leading-[1.2]"
            >
                {who}
            </div>
            <div class="text-[12.5px] text-ink-muted leading-[1.3]">
                {where}
            </div>
        </div>
    </div>
</div>
