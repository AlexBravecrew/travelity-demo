---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    eyebrow?: string;
    heading?: string;
    class?: string;
}

const {
    eyebrow = 'In their words',
    heading = 'Operators running their day on Travelity.',
    class: className,
    ...rest
} = Astro.props;
---

<section
    class={cn('social-proof bg-surface-alt py-12 md:py-16', className)}
    {...rest}
>
    <div class="container mx-auto px-6">
        <SectionHeader eyebrow={eyebrow} eyebrowWithRule align="center">
            <Fragment slot="headline">
                {heading}
            </Fragment>
        </SectionHeader>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-2">
            <slot />
        </div>
    </div>
</section>
