---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import LegalToc, { type TocItem } from './LegalToc.astro';

export interface Props {
    /** Document title (e.g. "Privacy Policy"). */
    title: string;
    /** Short subtitle/tagline under the title. */
    tagline?: string;
    /** Last-updated date as a string (e.g. "May 1, 2026"). */
    lastUpdated: string;
    /** Effective date if different from last-updated. */
    effectiveDate?: string;
    /** Table of contents items. Each maps to an h2 in the body. */
    tocItems: TocItem[];
    /** Page meta-description. */
    description: string;
}

const { title, tagline, lastUpdated, effectiveDate, tocItems, description } =
    Astro.props;
---

<MarketingLayout title={`${title} · Travelity`} description={description}>
    <Nav />

    <main class="bg-paper">
        <!-- Hero strip -->
        <section class="border-b border-line py-12 md:py-16">
            <div class="container mx-auto px-6 max-w-[1200px]">
                <Eyebrow withRule>Legal</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.1] tracking-[-0.025em] mt-4 mb-3"
                    style="font-size: clamp(32px, 4vw, 44px);"
                >
                    {title}
                </h1>

                {
                    tagline && (
                        <p class="text-[16px] text-ink-muted leading-[1.55] max-w-[60ch] mb-4">
                            {tagline}
                        </p>
                    )
                }

                <div
                    class="font-mono text-[12px] text-ink-muted flex flex-wrap gap-x-6 gap-y-1.5 tracking-[0.04em]"
                >
                    <span
                        >Last updated: <strong class="font-semibold text-ink"
                            >{lastUpdated}</strong
                        ></span
                    >
                    {
                        effectiveDate && (
                            <span>
                                Effective:{' '}
                                <strong class="font-semibold text-ink">
                                    {effectiveDate}
                                </strong>
                            </span>
                        )
                    }
                </div>
            </div>
        </section>

        <!-- TODO banner — PROMINENT. PO/legal must not be able to miss it. -->
        <div
            class="bg-[hsl(38_92%_50%/0.10)] border-b border-[hsl(38_92%_50%/0.3)]"
        >
            <div class="container mx-auto px-6 max-w-[1200px] py-4">
                <div class="flex items-start gap-3 max-w-[68ch]">
                    <span
                        class="font-mono text-[10.5px] font-bold uppercase tracking-[0.10em] bg-[hsl(38_92%_45%)] text-white px-2 py-1 rounded flex-shrink-0"
                    >
                        DRAFT
                    </span>
                    <p
                        class="font-body text-[13px] text-ink leading-[1.55] m-0"
                    >
                        <strong class="font-semibold"
                            >This document is AI-generated boilerplate pending
                            legal review.</strong
                        >
                        {' '}It reflects common SaaS conventions but has not
                        been validated against Travelity's actual operations or
                        jurisdiction. Do not rely on this content as legal terms
                        until reviewed and approved by qualified counsel.
                    </p>
                </div>
            </div>
        </div>

        <!-- Two-column body: sticky ToC + prose -->
        <div class="container mx-auto px-6 max-w-[1200px] py-12 md:py-16">
            <div
                class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-10 lg:gap-16"
            >
                <!-- ToC: sticky on desktop -->
                <aside class="lg:sticky lg:top-24 lg:self-start">
                    <LegalToc items={tocItems} />
                </aside>

                <!-- Prose -->
                <article class="legal-prose max-w-[68ch]">
                    <slot />
                </article>
            </div>
        </div>
    </main>

    <Footer />
</MarketingLayout>

<style is:global>
    /* Prose typography for legal pages.
       Scoped via .legal-prose so it doesn't leak to other pages. */

    .legal-prose h2 {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.25;
        color: hsl(var(--ink));
        margin-top: 48px;
        margin-bottom: 16px;
        scroll-margin-top: 88px; /* offset for sticky nav when anchor-jumping */
    }
    .legal-prose h2:first-child {
        margin-top: 0;
    }

    .legal-prose h3 {
        font-family: var(--font-display);
        font-size: 17px;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.3;
        color: hsl(var(--ink));
        margin-top: 32px;
        margin-bottom: 10px;
    }

    .legal-prose p {
        font-family: var(--font-body);
        font-size: 15px;
        color: hsl(var(--ink));
        line-height: 1.7;
        margin-top: 0;
        margin-bottom: 18px;
    }

    .legal-prose strong {
        font-weight: 600;
        color: hsl(var(--ink));
    }

    .legal-prose a {
        color: hsl(var(--travelity-teal));
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    .legal-prose a:hover {
        text-decoration-thickness: 2px;
    }

    .legal-prose ul,
    .legal-prose ol {
        margin: 0 0 18px 0;
        padding-left: 24px;
        font-size: 15px;
        line-height: 1.7;
        color: hsl(var(--ink));
    }
    .legal-prose ul {
        list-style: disc;
    }
    .legal-prose ol {
        list-style: decimal;
    }
    .legal-prose li {
        margin-bottom: 6px;
    }
    .legal-prose li > ul,
    .legal-prose li > ol {
        margin-top: 6px;
        margin-bottom: 0;
    }

    .legal-prose code {
        font-family: var(--font-mono);
        font-size: 13.5px;
        background: hsl(var(--surface-alt));
        border: 1px solid hsl(var(--line));
        border-radius: 4px;
        padding: 1px 5px;
        color: hsl(var(--ink));
    }

    .legal-prose hr {
        border: 0;
        border-top: 1px solid hsl(var(--line));
        margin: 40px 0;
    }

    .legal-prose blockquote {
        border-left: 3px solid hsl(var(--travelity-teal));
        padding-left: 20px;
        margin: 20px 0;
        color: hsl(var(--ink-muted));
        font-style: italic;
    }
</style>
