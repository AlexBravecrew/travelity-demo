---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface TocItem {
    /** Anchor target id matching an h2 in the page body. */
    id: string;
    /** Visible label. */
    label: string;
}

export interface Props extends HTMLAttributes<'nav'> {
    items: TocItem[];
    class?: string;
}

const { items, class: className, ...rest } = Astro.props;
---

<nav
    aria-label="Table of contents"
    class={cn('legal-toc', className)}
    {...rest}
>
    <div
        class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.10em] text-ink-muted mb-4"
    >
        On this page
    </div>
    <ul class="list-none m-0 p-0 flex flex-col gap-2">
        {
            items.map((item) => (
                <li>
                    <a
                        href={`#${item.id}`}
                        class="font-body text-[13.5px] text-ink-muted no-underline leading-[1.4] block py-1 transition-colors duration-150 hover:text-travelity-teal"
                    >
                        {item.label}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
