---
import { cn } from '@/lib/utils/cn';
import { Button } from '@/components/ui/button';
import { Paths } from '@/lib/utils/paths';
import { SectionHeader } from '@/components/ui/section-header';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    /** The plan name. The whole thing renders inside an <em> for the gradient text-fill. */
    planName: string;
    /** Description below the heading. */
    description: string;
    /** Section eyebrow. Defaults to "Plan recommendation". */
    sectionEyebrow?: string;
    /** Section heading. Defaults to "Which Travelity plan fits.". */
    sectionHeading?: string;
    class?: string;
}

const {
    planName,
    description,
    sectionEyebrow = 'Plan recommendation',
    sectionHeading = 'Which Travelity plan fits.',
    class: className,
    ...rest
} = Astro.props;
---

<section
    class={cn('plan-rec-section bg-surface-alt py-16 md:py-24', className)}
    {...rest}
>
    <div class="container mx-auto px-6">
        <SectionHeader eyebrow={sectionEyebrow} eyebrowWithRule align="center">
            <Fragment slot="headline">{sectionHeading}</Fragment>
        </SectionHeader>
        <div
            class="plan-rec bg-paper border border-line rounded-[14px] p-8 md:px-11 md:py-10 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-8 items-center max-w-[880px] mx-auto"
        >
            <div>
                <div
                    class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.12em] text-ink-muted mb-1"
                >
                    Recommended for you
                </div>
                <h3
                    class="plan-rec-headline font-display text-[22px] font-semibold leading-[1.25] tracking-[-0.02em] text-ink mb-2"
                >
                    The <em>{planName}</em> plan
                </h3>
                <p
                    class="text-[15px] text-ink-muted leading-[1.55] max-w-[50ch] m-0"
                >
                    {description}
                </p>
            </div>
            <div class="flex flex-col gap-2">
                <Button href={Paths.PRICING} size="md" withArrow>
                    See full pricing
                </Button>
                <Button href={Paths.BOOK_DEMO} size="md" variant="outline">
                    Talk to us
                </Button>
            </div>
        </div>
    </div>
</section>

<style>
    /* Same gradient-clip italic-em pattern as ProductHero — applied to the plan name. */
    .plan-rec-headline :global(em) {
        font-style: normal;
        background: linear-gradient(
            135deg,
            hsl(var(--travelity-blue)) 0%,
            hsl(var(--travelity-teal)) 100%
        );
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: hsl(var(--travelity-blue));
    }
</style>
