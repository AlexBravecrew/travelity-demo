---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    /** Small uppercase label (e.g. "Recommended plan"). */
    label: string;
    /** The main value (e.g. "Ultimate"). */
    value: string;
    /** Optional muted suffix (e.g. "across all channels"). */
    sub?: string;
    class?: string;
}

const { label, value, sub, class: className, ...rest } = Astro.props;
---

<div
    class={cn(
        'rounded-[10px] border border-line bg-paper px-[18px] py-4',
        'shadow-[0_1px_2px_hsl(0_0%_0%/0.04)]',
        className,
    )}
    {...rest}
>
    <div
        class="font-mono text-[10.5px] uppercase tracking-[0.10em] text-ink-muted mb-1"
    >
        {label}
    </div>
    <div
        class="font-display text-[20px] font-semibold tracking-[-0.02em] text-ink"
    >
        {value}
        {
            sub && (
                <small class="font-body text-[13px] font-normal text-ink-muted ml-1">
                    {sub}
                </small>
            )
        }
    </div>
</div>
