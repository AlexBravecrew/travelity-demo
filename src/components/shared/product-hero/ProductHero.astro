---
import { cn } from '@/lib/utils/cn';
import { Button } from '@/components/ui/button';
import { Eyebrow } from '@/components/ui/eyebrow';
import { Paths } from '@/lib/utils/paths';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    /** Eyebrow text (e.g. "Booking Engine" or "For Tour Operators"). */
    eyebrow: string;
    class?: string;
}

const { eyebrow, class: className, ...rest } = Astro.props;
---

<section
    class={cn(
        'product-hero relative overflow-hidden bg-paper',
        'py-16 md:py-24',
        className,
    )}
    style="background: radial-gradient(ellipse 60% 50% at 80% 0%, hsl(var(--travelity-teal) / 0.10) 0%, transparent 60%), hsl(var(--paper));"
    {...rest}
>
    <div class="container mx-auto px-6">
        <div
            class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-16 items-end"
        >
            <!-- Left: text -->
            <div class="max-w-[640px]">
                <Eyebrow withRule>{eyebrow}</Eyebrow>

                <h1
                    class="product-hero-headline font-serif font-semibold text-ink leading-[1.08] tracking-[-0.035em] mt-5 mb-5"
                    style="font-size: clamp(34px, 4.4vw, 52px);"
                >
                    <slot name="headline" />
                </h1>

                <p
                    class="text-[18px] md:text-[19px] text-ink-muted leading-[1.55] max-w-[56ch] mb-7"
                >
                    <slot name="lead" />
                </p>

                <div class="flex flex-wrap gap-3">
                    <slot name="ctas">
                        {/* Default CTAs if consumer doesn't override */}
                        <Button href={Paths.BOOK_DEMO} size="lg" withArrow>
                            Book a Demo
                        </Button>
                        {/* TODO: split when signup page exists */}
                        <Button
                            href={Paths.BOOK_DEMO}
                            size="lg"
                            variant="outline"
                        >
                            Start Free Trial
                        </Button>
                    </slot>
                </div>
            </div>

            <!-- Right: quick-facts aside (optional) -->
            <div class="flex flex-col gap-3">
                <slot name="aside" />
            </div>
        </div>
    </div>
</section>

<style>
    /* Italic-em pattern: gradient teal-to-blue text-fill on the emphasized phrase.
       v1 demo uses gradient-clip; we keep that effect because it's distinct from the
       home page's solid-teal italic-em (Solutions/Audience pages get a richer
       headline treatment). */
    .product-hero-headline :global(em) {
        font-style: normal;
        background: linear-gradient(
            135deg,
            hsl(var(--travelity-blue)) 0%,
            hsl(var(--travelity-teal)) 100%
        );
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: hsl(
            var(--travelity-blue)
        ); /* fallback for browsers without background-clip:text */
    }
</style>
