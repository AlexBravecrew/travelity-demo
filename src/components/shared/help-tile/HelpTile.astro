---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends Omit<HTMLAttributes<'a'>, 'href'> {
    href: string;
    title: string;
    description: string;
    class?: string;
}

const { href, title, description, class: className, ...rest } = Astro.props;
---

<a
    href={href}
    class={cn(
        'help-tile group',
        'flex flex-col p-7 rounded-xl',
        'bg-paper border border-line text-ink no-underline',
        'transition-all duration-200',
        'hover:-translate-y-1 hover:border-travelity-teal hover:shadow-[0_12px_28px_-10px_hsl(var(--ink)/0.12)]',
        className,
    )}
    {...rest}
>
    <div
        class="w-12 h-12 rounded-xl bg-[hsl(var(--travelity-teal)/0.10)] text-travelity-teal flex items-center justify-center mb-5"
    >
        <slot name="icon" />
    </div>

    <h3
        class="font-display text-[18px] font-semibold text-ink leading-[1.3] tracking-[-0.02em] mb-2"
    >
        {title}
    </h3>

    <p
        class="font-body text-[14.5px] text-ink-muted leading-[1.55] m-0 mb-4 flex-1"
    >
        {description}
    </p>

    <span
        class="font-display text-[13.5px] font-semibold text-travelity-blue inline-flex items-center gap-1 mt-auto"
    >
        Open
        <span
            class="transition-transform group-hover:translate-x-0.5"
            aria-hidden="true">→</span
        >
    </span>
</a>

<style>
    @media (prefers-reduced-motion: reduce) {
        .help-tile {
            transition: none !important;
        }
        .help-tile:hover {
            transform: none !important;
        }
    }
</style>
