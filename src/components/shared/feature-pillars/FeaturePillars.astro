---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    eyebrow?: string;
    heading?: string;
    class?: string;
}

const {
    eyebrow = "What you'll use most",
    heading = 'Five capabilities that earn their keep.',
    class: className,
    ...rest
} = Astro.props;
---

<section
    class={cn(
        'feature-pillars-section bg-surface-alt py-16 md:py-24',
        className,
    )}
    {...rest}
>
    <div class="container mx-auto px-6">
        <SectionHeader eyebrow={eyebrow} eyebrowWithRule align="center">
            <Fragment slot="headline">{heading}</Fragment>
        </SectionHeader>
        <div
            class="bg-paper border border-line rounded-[14px] overflow-hidden max-w-[880px] mx-auto"
        >
            <slot />
        </div>
    </div>
</section>
