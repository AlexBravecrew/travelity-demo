---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface AnchorItem {
    /** Anchor target (e.g. "be-products"). */
    id: string;
    /** Visible label. */
    label: string;
}

export interface Props extends HTMLAttributes<'div'> {
    /** Small uppercase label on the left (e.g. "On this page"). */
    label?: string;
    items: AnchorItem[];
    class?: string;
}

const {
    label = 'On this page',
    items,
    class: className,
    ...rest
} = Astro.props;
---

<div
    class={cn(
        'anchor-nav sticky z-30',
        'bg-[hsl(var(--paper)/0.92)] backdrop-blur-md',
        'border-y border-line',
        className,
    )}
    style="top: var(--nav-height);"
    data-anchor-nav
    {...rest}
>
    <div
        class="container mx-auto px-6 flex items-center gap-5 overflow-x-auto"
        style="scrollbar-width: none; -webkit-overflow-scrolling: touch;"
    >
        <span
            class="font-mono text-[10.5px] uppercase tracking-[0.10em] text-ink-muted font-medium flex-shrink-0 py-3.5"
        >
            {label}
        </span>
        {
            items.map((item, i) => (
                <a
                    href={`#${item.id}`}
                    class={cn(
                        'anchor-link',
                        'font-body text-[13.5px] font-medium',
                        'text-ink-muted no-underline',
                        'py-3.5 border-b-2 border-transparent',
                        'transition-colors duration-150',
                        'hover:text-ink',
                        'whitespace-nowrap',
                        i === 0 && 'is-active',
                    )}
                    data-anchor-link
                    data-anchor-target={item.id}
                >
                    {item.label}
                </a>
            ))
        }
    </div>
</div>

<style>
    .anchor-nav > div {
        scrollbar-width: none;
    }
    .anchor-nav > div::-webkit-scrollbar {
        display: none;
    }

    .anchor-link.is-active {
        color: hsl(var(--ink));
        border-bottom-color: hsl(var(--travelity-teal));
    }
</style>

<script>
    import './anchor-nav.client.ts';
</script>
