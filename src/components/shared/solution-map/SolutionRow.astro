---
import { cn } from '@/lib/utils/cn';
import { ArrowRightIcon } from '@/icons';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    pain: string;
    /** The solution headline (display weight). */
    solution: string;
    /** Optional sub-description below the solution. */
    sub?: string;
    class?: string;
}

const { pain, solution, sub, class: className, ...rest } = Astro.props;
---

<div
    class={cn(
        'solution-row',
        'grid grid-cols-1 md:grid-cols-[1fr_auto_1.5fr] gap-4 md:gap-6 items-center',
        'bg-paper border border-line rounded-xl p-6 md:px-8 md:py-7',
        className,
    )}
    {...rest}
>
    <div
        class="font-display text-[15px] font-semibold leading-[1.4] text-ink-muted"
        style="text-decoration: line-through; text-decoration-thickness: 1px; text-decoration-color: hsl(var(--destructive) / 0.5);"
    >
        {pain}
    </div>
    <div
        class="hidden md:flex items-center justify-center text-travelity-teal"
        aria-hidden="true"
    >
        <ArrowRightIcon class="w-5 h-5" stroke-width="1.75" />
    </div>
    <div>
        <div
            class="font-display text-[16px] font-semibold leading-[1.4] text-ink"
        >
            {solution}
        </div>
        {
            sub && (
                <small class="block font-body text-[13px] font-normal text-ink-muted mt-1 leading-[1.5]">
                    {sub}
                </small>
            )
        }
    </div>
</div>
