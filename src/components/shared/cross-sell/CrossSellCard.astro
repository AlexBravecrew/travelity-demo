---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends Omit<HTMLAttributes<'a'>, 'href'> {
    href: string;
    title: string;
    description: string;
    class?: string;
}

const { href, title, description, class: className, ...rest } = Astro.props;
---

<a
    href={href}
    class={cn(
        'cross-card group',
        'flex flex-col p-6 rounded-xl',
        'bg-paper border border-line text-ink no-underline',
        'transition-all duration-200',
        'hover:-translate-y-0.5 hover:border-travelity-teal',
        className,
    )}
    {...rest}
>
    <div
        class="w-9 h-9 rounded-lg bg-[hsl(var(--travelity-teal)/0.10)] text-travelity-teal flex items-center justify-center mb-3.5"
    >
        <slot name="icon" />
    </div>
    <h4
        class="font-display text-[15px] font-semibold text-ink leading-[1.3] mb-1"
    >
        {title}
    </h4>
    <p class="font-body text-[13.5px] text-ink-muted leading-[1.5] m-0 flex-1">
        {description}
    </p>
    <span
        class="mt-3.5 font-body text-[13px] font-semibold text-travelity-blue inline-flex items-center gap-1"
    >
        Learn more
        <span
            class="transition-transform group-hover:translate-x-0.5"
            aria-hidden="true">→</span
        >
    </span>
</a>

<style>
    @media (prefers-reduced-motion: reduce) {
        .cross-card {
            transition: none !important;
        }
        .cross-card:hover {
            transform: none !important;
        }
    }
</style>
