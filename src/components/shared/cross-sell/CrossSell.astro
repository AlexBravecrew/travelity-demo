---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    /** Eyebrow above the section header. Defaults to "Explore". */
    eyebrow?: string;
    /** Section heading. Defaults to "Other Travelity solutions." */
    heading?: string;
    class?: string;
}

const {
    eyebrow = 'Explore',
    heading = 'Other Travelity solutions.',
    class: className,
    ...rest
} = Astro.props;
---

<section
    class={cn('cross-sell border-t border-line py-12 md:py-16', className)}
    {...rest}
>
    <div class="container mx-auto px-6">
        <SectionHeader eyebrow={eyebrow} eyebrowWithRule align="left">
            <Fragment slot="headline">
                {heading}
            </Fragment>
        </SectionHeader>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <slot />
        </div>
    </div>
</section>
