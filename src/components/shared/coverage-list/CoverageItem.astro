---
import { CheckIcon } from '@/icons';
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'li'> {
    title: string;
    description: string;
    class?: string;
}

const { title, description, class: className, ...rest } = Astro.props;
---

<li
    class={cn('grid grid-cols-[24px_1fr] gap-4 items-start py-4', className)}
    {...rest}
>
    <span
        class="w-6 h-6 rounded-full bg-[hsl(var(--travelity-teal)/0.12)] text-travelity-teal flex items-center justify-center flex-shrink-0 mt-0.5"
    >
        <CheckIcon class="w-3.5 h-3.5" stroke-width="2.5" aria-hidden="true" />
    </span>
    <div>
        <strong
            class="block font-display text-[15.5px] font-semibold text-ink leading-[1.3]"
        >
            {title}
        </strong>
        <span
            class="block font-body text-[14.5px] text-ink-muted leading-[1.55] mt-1"
        >
            {description}
        </span>
    </div>
</li>
