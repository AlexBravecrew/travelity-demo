---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    /** Time/timestamp label (e.g. "8:00 AM"). */
    when: string;
    title: string;
    description: string;
    class?: string;
}

const { when, title, description, class: className, ...rest } = Astro.props;
---

<div
    class={cn(
        'workflow-step relative z-[1]',
        'bg-paper border border-line rounded-xl p-5',
        className,
    )}
    {...rest}
>
    <div
        class="w-8 h-8 rounded-full bg-paper border border-ink-soft text-travelity-teal inline-flex items-center justify-center mb-3.5"
    >
        <slot name="icon" />
    </div>
    <div
        class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.10em] text-ink-muted mb-1.5"
    >
        {when}
    </div>
    <h4
        class="font-display text-[14.5px] font-semibold tracking-[-0.01em] text-ink mb-1.5 leading-[1.3]"
    >
        {title}
    </h4>
    <p class="text-[13px] text-ink-muted leading-[1.55] m-0">
        {description}
    </p>
</div>
