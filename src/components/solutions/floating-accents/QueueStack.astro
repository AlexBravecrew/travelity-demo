---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

/**
 * Section 3 (Manage All Bookings) — a small stack of 3 mini "booking
 * cards" labeled with their source channel, plus a "12 in queue" header.
 *
 * Cards stagger in (60ms apart) when the parent section is in view; the
 * counter on top fades after the third card lands. Each card has a small
 * left-edge color stripe tinted to its source channel (matching the
 * ChannelsSection's orbit colors).
 *
 * Travel touch: each card has a tiny semi-circle notch on the left edge,
 * styled like a boarding-pass stub. Booking IDs render in mono so they
 * read as system labels.
 */

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

interface QueueItem {
    source: 'Direct' | 'GYG' | 'Viator';
    id: string;
    color: string;
}

const items: QueueItem[] = [
    { source: 'Viator', id: 'VTR-09', color: 'hsl(165 80% 28%)' },
    { source: 'GYG', id: 'GYG-21', color: 'hsl(8 100% 60%)' },
    { source: 'Direct', id: 'DIR-44', color: 'hsl(var(--travelity-teal))' },
];
---

<div
    class={cn(
        'queue-stack absolute',
        'w-[220px] md:w-[240px] opacity-0',
        className,
    )}
    {...rest}
>
    <!-- Counter header -->
    <div
        class="queue-counter flex items-center justify-between rounded-t-xl bg-ink/95 backdrop-blur-sm px-3 py-2 text-paper"
        style="box-shadow: 0 12px 24px -8px hsl(var(--ink) / 0.3);"
    >
        <span
            class="font-mono text-[10px] uppercase tracking-[0.12em] text-paper/70"
        >
            Queue
        </span>
        <span class="text-[13px] font-semibold">
            <span class="queue-count">12</span> in queue
        </span>
    </div>

    <!-- Card stack -->
    <div class="relative">
        {
            items.map((item, i) => (
                <div
                    class="queue-card relative flex items-center justify-between gap-2 bg-paper border border-line px-3 py-2.5 -mt-px last:rounded-b-xl"
                    style={`opacity: 0; transform: translateX(20px); transition: opacity 480ms var(--ease-out) ${720 + i * 80}ms, transform 480ms var(--ease-out) ${720 + i * 80}ms;`}
                >
                    {/* Boarding-pass notch on the left edge */}
                    <span
                        aria-hidden="true"
                        class="absolute left-[-4px] top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-paper border border-line"
                    />
                    {/* Color stripe + source label */}
                    <div class="flex items-center gap-2.5 min-w-0">
                        <span
                            class="block w-1 h-7 rounded-full flex-shrink-0"
                            style={`background: ${item.color};`}
                        />
                        <div class="flex flex-col leading-tight min-w-0">
                            <span class="text-[13px] font-semibold text-ink truncate">
                                {item.source}
                            </span>
                            <span class="font-mono text-[10px] uppercase tracking-[0.08em] text-ink-soft">
                                {item.id}
                            </span>
                        </div>
                    </div>
                    <span class="font-mono text-[11px] text-success font-semibold">
                        NEW
                    </span>
                </div>
            ))
        }
    </div>
</div>

<style>
    .queue-stack {
        transition: opacity 600ms var(--ease-out) 600ms;
    }

    [data-in='true'] .queue-stack {
        opacity: 1;
    }

    [data-in='true'] .queue-card {
        opacity: 1 !important;
        transform: translateX(0) !important;
    }

    @media (prefers-reduced-motion: reduce) {
        .queue-stack {
            opacity: 1 !important;
        }
        .queue-card {
            opacity: 1 !important;
            transform: none !important;
            transition: none !important;
        }
    }
</style>
