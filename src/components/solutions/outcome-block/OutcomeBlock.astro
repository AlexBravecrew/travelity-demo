---
import { cn } from '@/lib/utils/cn';
import { Eyebrow } from '@/components/ui/eyebrow';
import type { HTMLAttributes } from 'astro/types';

/**
 * One outcome on the Solutions page — a full-width editorial spread.
 *
 * Vertical stack: centered eyebrow → centered italic-em headline →
 * centered body (3-4 sentences) → large image below. Each block uses
 * generous vertical padding so the three outcomes read as three distinct
 * "acts" rather than three menu items.
 *
 * Sections alternate between paper and surface-alt backgrounds via the
 * `surface` prop — gives each block its own subtle visual identity and
 * cleanly separates the three from each other.
 *
 * Eyebrow tone rotates teal / sunset / blue across the three blocks to
 * carry a single warm accent without leaning on background artifacts.
 */

export type BlockSurface = 'paper' | 'alt';
export type BlockTone = 'teal' | 'sunset' | 'blue';

export interface Props extends HTMLAttributes<'section'> {
    /** Anchor id for cross-page deep links. */
    id?: string;
    /** Short uppercase eyebrow label. */
    eyebrow: string;
    /** Image src for this outcome. */
    imageSrc: string;
    /** Alt text for the image. */
    imageAlt: string;
    /** Background surface — alternate across stacked blocks. */
    surface?: BlockSurface;
    /** Eyebrow accent tone — rotate across stacked blocks. */
    tone?: BlockTone;
    class?: string;
}

const {
    id,
    eyebrow,
    imageSrc,
    imageAlt,
    surface = 'paper',
    tone = 'teal',
    class: className,
    ...rest
} = Astro.props;

const surfaceClass: Record<BlockSurface, string> = {
    paper: 'bg-paper',
    alt: 'bg-surface-alt',
};

const toneClass: Record<BlockTone, string> = {
    teal: 'text-travelity-teal',
    sunset: 'text-[hsl(14_65%_48%)]',
    blue: 'text-travelity-blue-deep',
};
---

<section
    id={id}
    class={cn(
        'outcome-block relative py-20 md:py-28',
        'scroll-mt-[var(--nav-height)]',
        surfaceClass[surface],
        className,
    )}
    {...rest}
>
    <div class="container mx-auto px-6">
        <!-- Centered text block -->
        <div class="max-w-[760px] mx-auto text-center mb-12 md:mb-16">
            <Eyebrow withRule centered class={toneClass[tone]}>
                {eyebrow}
            </Eyebrow>

            <h2
                class="outcome-block-title font-serif font-semibold text-ink leading-[1.05] tracking-[-0.03em] mt-5 mb-6 max-w-[22ch] mx-auto"
                style="font-size: clamp(36px, 4.4vw, 56px);"
            >
                <slot name="title" />
            </h2>

            <p
                class="text-[18px] md:text-[19px] text-ink-muted leading-[1.65] max-w-[60ch] mx-auto"
            >
                <slot name="body" />
            </p>
        </div>

        <!-- Large image below the text -->
        <div
            class="outcome-block-image-wrap relative max-w-[1100px] mx-auto"
        >
            <!-- Soft halo behind the image -->
            <span
                aria-hidden="true"
                class="absolute -inset-6 -z-10 rounded-[28px] pointer-events-none"
                style="background: radial-gradient(60% 60% at 50% 50%, hsl(var(--travelity-teal) / 0.18), transparent 75%); filter: blur(40px);"
            >
            </span>

            <div
                class="relative overflow-hidden rounded-2xl border border-line bg-surface-alt aspect-[16/9]"
                style="box-shadow: 0 30px 60px -24px hsl(var(--travelity-blue-deep) / 0.35), 0 8px 20px -8px hsl(var(--ink) / 0.12);"
            >
                <img
                    src={imageSrc}
                    alt={imageAlt}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover"
                    style="filter: grayscale(0.55) sepia(0.5) hue-rotate(155deg) saturate(0.9) brightness(1.02);"
                />
                <!-- Cool duotone overlay so any photograph reads on-palette -->
                <span
                    aria-hidden="true"
                    class="absolute inset-0"
                    style="background: linear-gradient(150deg, hsl(var(--travelity-blue-deep) / 0.28), hsl(var(--travelity-teal) / 0.15) 70%, transparent); mix-blend-mode: multiply;"
                >
                </span>
            </div>
        </div>
    </div>
</section>

<style>
    /* Italic-em in the title slot — teal, matches Hero / ClosingCTA. */
    .outcome-block-title :global(em) {
        font-style: italic;
        font-weight: 500;
        color: hsl(var(--travelity-teal));
    }
</style>
