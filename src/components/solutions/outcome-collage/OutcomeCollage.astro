---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

/**
 * Scrapbook-style outcome section for the Solutions page.
 *
 * Vertical stack — giant title at the top, a 3-photo collage row where
 * each photo sits in its own polaroid-ish card with a slight tilt, then
 * the body paragraph beneath. The floating UI accent lives inside the
 * middle photo card so it reads as a moment captured on the page.
 *
 * This is deliberately NOT a two-column text/image grid (which lives on
 * /features). The vertical rhythm + multi-photo collage gives Solutions
 * its own visual signature. The polaroid card pattern itself is intended
 * for reuse on the home page later.
 */

export interface CollageImage {
    src: string;
    alt: string;
}

export interface Props extends HTMLAttributes<'section'> {
    /** 2–4 images. Use 3 for the best balance of the default layout. */
    images: CollageImage[];
    /** Anchor id (for cross-page deep-links). */
    id?: string;
    class?: string;
}

const {
    images,
    id,
    class: className,
    ...rest
} = Astro.props;

// Per-image tilt + Y-offset patterns. Cycles every 3 photos so 4+ image
// collages keep their visual rhythm.
const tilts = ['-2.2deg', '1.6deg', '-1.4deg', '2.4deg'];
const offsets = ['10px', '-12px', '14px', '-8px'];
---

<section
    id={id}
    data-outcome-collage
    class={cn(
        'outcome-collage relative my-20 md:my-28 lg:my-32',
        'scroll-mt-[var(--nav-height)]',
        className,
    )}
    {...rest}
>
    <div class="container mx-auto px-6">
        <!-- Header — title only, no eyebrow/numeral -->
        <div class="relative max-w-[1100px] mx-auto text-center mb-12 md:mb-16">
            <h2
                class="collage-title relative font-serif font-semibold text-ink leading-[1.02] tracking-[-0.035em] max-w-[18ch] mx-auto"
                style="font-size: clamp(44px, 6.4vw, 84px);"
            >
                <slot name="title" />
            </h2>
        </div>

        <!-- Collage row — 3 photo cards with varied tilts -->
        <div
            class={cn(
                'collage-row relative grid gap-5 md:gap-7 lg:gap-9 mb-10 md:mb-14',
                images.length === 2 && 'md:grid-cols-2 max-w-[900px] mx-auto',
                images.length === 3 && 'md:grid-cols-3',
                images.length === 4 && 'md:grid-cols-2 lg:grid-cols-4',
            )}
        >
            {
                images.map((img, i) => (
                    <figure
                        class="collage-photo group relative"
                        style={`--tilt: ${tilts[i % tilts.length]}; --y: ${offsets[i % offsets.length]};`}
                    >
                        <!-- Halo glow behind each polaroid -->
                        <span
                            aria-hidden="true"
                            class="absolute -inset-4 -z-10 rounded-2xl pointer-events-none opacity-0 transition-opacity duration-500"
                            style="background: radial-gradient(60% 60% at 50% 50%, hsl(var(--travelity-teal) / 0.35), transparent 70%); filter: blur(28px);"
                        />
                        <div
                            class="collage-photo-card relative overflow-hidden rounded-2xl border border-line bg-paper"
                            style="box-shadow: 0 18px 40px -16px hsl(var(--travelity-blue-deep) / 0.35), 0 6px 16px -8px hsl(var(--ink) / 0.15); padding: 8px;"
                        >
                            <div class="relative overflow-hidden rounded-xl bg-surface-alt aspect-[4/5]">
                                <img
                                    src={img.src}
                                    alt={img.alt}
                                    loading="lazy"
                                    decoding="async"
                                    class="absolute inset-0 w-full h-full object-cover"
                                    style="filter: grayscale(0.6) sepia(0.6) hue-rotate(155deg) saturate(0.85) brightness(1.02);"
                                />
                                <!-- Subtle duotone overlay -->
                                <span
                                    aria-hidden="true"
                                    class="absolute inset-0"
                                    style="background: linear-gradient(150deg, hsl(var(--travelity-blue-deep) / 0.35), hsl(var(--travelity-teal) / 0.2) 70%, transparent); mix-blend-mode: multiply;"
                                />
                                {/* Accent slot lives in the middle photo for a 3-image collage */}
                                {i === Math.floor(images.length / 2) && (
                                    <div class="absolute inset-0 pointer-events-none">
                                        <slot name="accent" />
                                    </div>
                                )}
                            </div>
                            {/* Polaroid caption — small mono label */}
                            <figcaption class="mt-2 px-1 pb-1 font-mono text-[10px] uppercase tracking-[0.10em] text-ink-soft text-center truncate">
                                {img.alt}
                            </figcaption>
                        </div>
                    </figure>
                ))
            }
        </div>

        <!-- Body paragraph — centered, narrower than the title for readability -->
        <p
            class="collage-body relative mx-auto text-center text-ink-muted leading-[1.6] max-w-[64ch]"
            style="font-size: clamp(17px, 1.4vw, 20px);"
        >
            <slot name="body" />
        </p>
    </div>
</section>

<style>
    /* Polaroid resting state — slight tilt + y-offset per nth via CSS vars */
    .collage-photo {
        transform: translateY(var(--y, 0)) rotate(var(--tilt, 0deg));
        transition: transform 600ms var(--ease-default);
        will-change: transform;
    }

    /* Hover — straighten the photo, lift it, reveal the halo */
    .collage-photo:hover {
        transform: translateY(calc(var(--y, 0) - 8px)) rotate(0deg) scale(1.02);
        z-index: 2;
    }
    .collage-photo:hover > span:first-of-type {
        opacity: 1;
    }

    /* Entrance choreography — title fades up first, photos stagger in,
       body comes last. Stays performant with one-shot IntersectionObserver. */
    .collage-title,
    .collage-body {
        opacity: 0;
        transform: translateY(20px);
        transition:
            opacity 800ms var(--ease-out),
            transform 800ms var(--ease-out);
    }
    .collage-body {
        transition-delay: 600ms;
    }

    .collage-photo {
        opacity: 0;
        transition:
            opacity 700ms var(--ease-out),
            transform 700ms var(--ease-spring);
    }
    /* Stagger photos by nth-child so 2/3/4-photo collages all read */
    .collage-photo:nth-child(1) {
        transition-delay: 280ms;
    }
    .collage-photo:nth-child(2) {
        transition-delay: 360ms;
    }
    .collage-photo:nth-child(3) {
        transition-delay: 440ms;
    }
    .collage-photo:nth-child(4) {
        transition-delay: 520ms;
    }

    [data-outcome-collage][data-in='true'] .collage-title,
    [data-outcome-collage][data-in='true'] .collage-body {
        opacity: 1;
        transform: translateY(0);
    }
    [data-outcome-collage][data-in='true'] .collage-photo {
        opacity: 1;
    }

    /* Italic-em in the title — teal accent */
    .collage-title :global(em) {
        font-style: italic;
        font-weight: 500;
        color: hsl(var(--travelity-teal));
    }

    @media (prefers-reduced-motion: reduce) {
        .collage-title,
        .collage-body,
        .collage-photo {
            opacity: 1 !important;
            transform: none !important;
            transition: none !important;
        }
        .collage-photo:hover {
            transform: none !important;
        }
    }
</style>

<script>
    const sections = document.querySelectorAll<HTMLElement>(
        '[data-outcome-collage]',
    );
    if (sections.length > 0) {
        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        (entry.target as HTMLElement).dataset.in = 'true';
                        observer.unobserve(entry.target);
                    }
                }
            },
            { threshold: 0.2 },
        );
        for (const section of sections) {
            observer.observe(section);
        }
    }
</script>
