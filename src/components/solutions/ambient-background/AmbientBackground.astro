---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

/**
 * Atmospheric background for the Solutions page — two stacked layers:
 *
 *  1. Large radial-gradient "blobs" (cool brand + warm accents). The warm
 *     blobs (sunset, amber, dawn) carry the ~25% warm tone target — they
 *     are deliberately more saturated and opaque than the cool blobs so
 *     they read warm against the dominant white paper surface.
 *  2. Decorative "artifacts": small warm dust particles, a sun-glare ring,
 *     and a few thin sun-ray streaks. These supply the textural detail
 *     the user asked for beyond gradients alone.
 *
 * Motion: each blob and each particle gets two motion sources composed:
 *  - CSS `ambient-drift` keyframe (slow 60s orbit via the `translate`
 *    property).
 *  - Scroll-driven parallax via the inline `<script>` (uses `transform`
 *    so it composes with `translate` cleanly).
 * Both stop under `prefers-reduced-motion: reduce`.
 */

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

interface Blob {
    pos: string;
    size: string;
    color: string;
    rate: number;
    delay: string;
    blur: string;
    opacity: string;
}

// Cool 4 + warm 5 = 9 blobs total. Warm now slightly outnumbers cool by
// blob count, but cool primaries (teal/blue) still dominate by opacity
// since they're brand. Net visual reading: ~60% cool, ~30% warm, ~10%
// page-paper showing through.
const blobs: Blob[] = [
    // === COOL ===
    {
        pos: 'top-[-160px] left-[-160px]',
        size: 'w-[680px] h-[680px]',
        color: 'hsl(var(--travelity-teal) / 0.7), hsl(var(--travelity-teal) / 0) 70%',
        rate: 0.12,
        delay: '0s',
        blur: 'blur(100px)',
        opacity: '0.65',
    },
    {
        pos: 'top-[6%] right-[-180px]',
        size: 'w-[600px] h-[600px]',
        color: 'hsl(var(--travelity-blue-deep) / 0.65), hsl(var(--travelity-blue-deep) / 0) 70%',
        rate: -0.18,
        delay: '-12s',
        blur: 'blur(120px)',
        opacity: '0.55',
    },
    {
        pos: 'top-[58%] left-[28%]',
        size: 'w-[560px] h-[560px]',
        color: 'hsl(var(--travelity-teal-deep) / 0.55), hsl(var(--travelity-teal-deep) / 0) 70%',
        rate: 0.16,
        delay: '-8s',
        blur: 'blur(110px)',
        opacity: '0.55',
    },
    {
        pos: 'bottom-[-100px] right-[-120px]',
        size: 'w-[640px] h-[640px]',
        color: 'hsl(var(--travelity-blue) / 0.65), hsl(var(--travelity-blue) / 0) 70%',
        rate: -0.2,
        delay: '-24s',
        blur: 'blur(110px)',
        opacity: '0.55',
    },

    // === WARM === (deliberately stronger so they actually read)
    {
        pos: 'top-[28%] left-[-140px]',
        size: 'w-[600px] h-[600px]',
        color: 'hsl(var(--travelity-sunset) / 0.95), hsl(var(--travelity-sunset) / 0) 70%',
        rate: 0.22,
        delay: '-20s',
        blur: 'blur(100px)',
        opacity: '0.85',
    },
    {
        pos: 'top-[36%] right-[6%]',
        size: 'w-[540px] h-[540px]',
        color: 'hsl(var(--travelity-amber) / 0.9), hsl(var(--travelity-amber) / 0) 70%',
        rate: -0.14,
        delay: '-32s',
        blur: 'blur(95px)',
        opacity: '0.85',
    },
    {
        pos: 'top-[72%] right-[28%]',
        size: 'w-[480px] h-[480px]',
        color: 'hsl(var(--travelity-sunset) / 0.85), hsl(var(--travelity-sunset) / 0) 70%',
        rate: 0.18,
        delay: '-44s',
        blur: 'blur(100px)',
        opacity: '0.7',
    },
    {
        pos: 'bottom-[18%] left-[-140px]',
        size: 'w-[560px] h-[560px]',
        color: 'hsl(var(--travelity-dawn) / 0.95), hsl(var(--travelity-dawn) / 0) 70%',
        rate: 0.28,
        delay: '-40s',
        blur: 'blur(100px)',
        opacity: '0.8',
    },
    {
        pos: 'bottom-[34%] left-[42%]',
        size: 'w-[420px] h-[420px]',
        color: 'hsl(var(--travelity-amber) / 0.7), hsl(var(--travelity-amber) / 0) 65%',
        rate: -0.1,
        delay: '-16s',
        blur: 'blur(90px)',
        opacity: '0.6',
    },
];

interface Particle {
    /** Inline style for position (top/left + width/height). */
    style: string;
    /** Background color — small enough that solid HSL renders well. */
    bg: string;
    /** Parallax rate. Particles drift more than blobs (they're light dust). */
    rate: number;
    /** Drift animation delay so they don't pulse in lockstep. */
    delay: string;
    /** Small blur so they read as light, not pixels. */
    blur: string;
    /** Soft glow via box-shadow tinted to bg color. */
    glow: string;
}

// Warm-dominant dust particles scattered across the page. The user
// described "elements fragments" — these are the smallest such fragments.
// Sized 3-8px with 4-12px blur so they read as floating motes.
const particles: Particle[] = [
    { style: 'top: 14%; left: 22%; width: 6px; height: 6px;', bg: 'hsl(var(--travelity-amber))', rate: 0.4, delay: '-4s', blur: 'blur(4px)', glow: '0 0 18px hsl(var(--travelity-amber) / 0.9)' },
    { style: 'top: 22%; left: 64%; width: 4px; height: 4px;', bg: 'hsl(var(--travelity-sunset))', rate: -0.5, delay: '-22s', blur: 'blur(3px)', glow: '0 0 14px hsl(var(--travelity-sunset) / 0.9)' },
    { style: 'top: 38%; left: 8%; width: 8px; height: 8px;', bg: 'hsl(var(--travelity-sunset))', rate: 0.36, delay: '-14s', blur: 'blur(5px)', glow: '0 0 22px hsl(var(--travelity-sunset) / 0.85)' },
    { style: 'top: 32%; left: 48%; width: 5px; height: 5px;', bg: 'hsl(var(--travelity-dawn))', rate: -0.42, delay: '-34s', blur: 'blur(4px)', glow: '0 0 16px hsl(var(--travelity-dawn) / 0.9)' },
    { style: 'top: 46%; right: 12%; width: 7px; height: 7px;', bg: 'hsl(var(--travelity-amber))', rate: 0.3, delay: '-26s', blur: 'blur(5px)', glow: '0 0 20px hsl(var(--travelity-amber) / 0.9)' },
    { style: 'top: 58%; left: 18%; width: 5px; height: 5px;', bg: 'hsl(var(--travelity-teal))', rate: -0.34, delay: '-6s', blur: 'blur(4px)', glow: '0 0 16px hsl(var(--travelity-teal) / 0.8)' },
    { style: 'top: 64%; right: 8%; width: 6px; height: 6px;', bg: 'hsl(var(--travelity-dawn))', rate: 0.38, delay: '-18s', blur: 'blur(4px)', glow: '0 0 18px hsl(var(--travelity-dawn) / 0.9)' },
    { style: 'top: 70%; left: 36%; width: 4px; height: 4px;', bg: 'hsl(var(--travelity-sunset))', rate: -0.46, delay: '-30s', blur: 'blur(3px)', glow: '0 0 14px hsl(var(--travelity-sunset) / 0.85)' },
    { style: 'top: 80%; right: 22%; width: 7px; height: 7px;', bg: 'hsl(var(--travelity-amber))', rate: 0.32, delay: '-12s', blur: 'blur(5px)', glow: '0 0 20px hsl(var(--travelity-amber) / 0.9)' },
    { style: 'top: 86%; left: 12%; width: 5px; height: 5px;', bg: 'hsl(var(--travelity-dawn))', rate: -0.4, delay: '-38s', blur: 'blur(4px)', glow: '0 0 16px hsl(var(--travelity-dawn) / 0.9)' },
    { style: 'top: 18%; left: 38%; width: 3px; height: 3px;', bg: 'hsl(var(--travelity-amber))', rate: 0.52, delay: '-8s', blur: 'blur(2px)', glow: '0 0 12px hsl(var(--travelity-amber) / 0.9)' },
    { style: 'top: 50%; left: 70%; width: 4px; height: 4px;', bg: 'hsl(var(--travelity-sunset))', rate: -0.38, delay: '-42s', blur: 'blur(3px)', glow: '0 0 14px hsl(var(--travelity-sunset) / 0.9)' },
];
---

<div
    class={cn(
        'ambient-background absolute inset-0 -z-10 overflow-hidden pointer-events-none',
        className,
    )}
    aria-hidden="true"
    {...rest}
>
    <!-- Large blurred blobs -->
    {
        blobs.map((b) => (
            <span
                class={cn(
                    'ambient-blob absolute rounded-full will-change-transform',
                    b.pos,
                    b.size,
                )}
                data-rate={b.rate}
                style={`background: radial-gradient(circle, ${b.color}); filter: ${b.blur}; opacity: ${b.opacity}; animation: ambient-drift 60s ease-in-out infinite ${b.delay};`}
            />
        ))
    }

    <!-- Sun-glare ring artifact: a soft warm donut sits in the
         upper-middle band, evokes lens flare without being literal -->
    <span
        class="ambient-glare absolute rounded-full will-change-transform"
        data-rate="0.18"
        style="top: 30%; left: 56%; width: 320px; height: 320px; background: radial-gradient(circle, transparent 38%, hsl(var(--travelity-sunset) / 0.6) 46%, hsl(var(--travelity-amber) / 0.4) 56%, transparent 72%); filter: blur(20px); opacity: 0.55; animation: ambient-drift 80s ease-in-out infinite -28s;"
        aria-hidden="true"
    >
    </span>

    <!-- Sun-ray streak fragments — long thin warm gradients tilted slightly.
         Three of them, scattered, very low opacity. Evoke afternoon light
         streaks without being literal sun rays. -->
    <span
        class="ambient-streak absolute will-change-transform"
        data-rate="0.08"
        style="top: 14%; left: 42%; width: 520px; height: 8px; background: linear-gradient(90deg, transparent, hsl(var(--travelity-amber) / 0.55), transparent); filter: blur(6px); transform: rotate(-18deg); opacity: 0.6;"
        aria-hidden="true"
    >
    </span>
    <span
        class="ambient-streak absolute will-change-transform"
        data-rate="-0.12"
        style="top: 54%; left: 8%; width: 440px; height: 6px; background: linear-gradient(90deg, transparent, hsl(var(--travelity-sunset) / 0.5), transparent); filter: blur(5px); transform: rotate(8deg); opacity: 0.55;"
        aria-hidden="true"
    >
    </span>
    <span
        class="ambient-streak absolute will-change-transform"
        data-rate="0.14"
        style="top: 78%; right: 4%; width: 460px; height: 7px; background: linear-gradient(90deg, transparent, hsl(var(--travelity-dawn) / 0.55), transparent); filter: blur(5px); transform: rotate(-12deg); opacity: 0.55;"
        aria-hidden="true"
    >
    </span>

    <!-- Dust particles — small bright dots with soft glow -->
    {
        particles.map((p) => (
            <span
                class="ambient-particle absolute rounded-full will-change-transform"
                data-rate={p.rate}
                style={`${p.style} background: ${p.bg}; filter: ${p.blur}; box-shadow: ${p.glow}; animation: ambient-drift 45s ease-in-out infinite ${p.delay};`}
            />
        ))
    }
</div>

<style>
    @media (prefers-reduced-motion: reduce) {
        .ambient-blob,
        .ambient-glare,
        .ambient-streak,
        .ambient-particle {
            animation: none !important;
        }
    }
</style>

<script>
    // Scroll-driven parallax for blobs, glare, streaks, AND particles.
    // One rAF loop reads everything carrying `data-rate` and applies a
    // translateY proportional to scrollY × the per-element rate. Composes
    // with the CSS `ambient-drift` keyframe via separate properties (the
    // keyframe sets `translate`, this sets `transform`). Streaks also
    // preserve their rotation via inline `transform: rotate(...)` — we
    // append the parallax translate to that rotation so they don't
    // un-rotate when scrolling.
    const layer =
        document.querySelector<HTMLElement>('.ambient-background');
    const reduced = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
    ).matches;

    if (layer && !reduced) {
        type Item = {
            el: HTMLElement;
            rate: number;
            baseTransform: string;
        };
        const items: Item[] = Array.from(
            layer.querySelectorAll<HTMLElement>('[data-rate]'),
        ).map((el) => ({
            el,
            rate: Number(el.dataset.rate ?? 0),
            // Preserve any inline rotation (streaks) so the parallax
            // translate composes with it rather than replacing it.
            baseTransform: el.style.transform ?? '',
        }));

        const mobileMatch = window.matchMedia('(max-width: 767px)');
        const scale = () => (mobileMatch.matches ? 0.5 : 1);

        let ticking = false;
        const update = () => {
            const y = window.scrollY;
            const s = scale();
            for (const it of items) {
                const offset = y * it.rate * s;
                it.el.style.transform = `translate3d(0, ${offset}px, 0) ${it.baseTransform}`;
            }
            ticking = false;
        };

        const onScroll = () => {
            if (!ticking) {
                requestAnimationFrame(update);
                ticking = true;
            }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        update();
    }
</script>
