---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

type TagVariant = 'default' | 'success' | 'warning' | 'destructive';

export interface Props extends HTMLAttributes<'span'> {
    /** Semantic variant. Defaults to `default` (neutral metadata). */
    variant?: TagVariant;
    /** Forwarded to underlying element. */
    class?: string;
}

const { variant = 'default', class: className, ...rest } = Astro.props;

const base =
    'inline-flex items-center ' +
    'px-[11px] py-[5px] rounded-full ' +
    'font-mono text-[11.5px] font-medium ' +
    'border';

const variantClasses: Record<TagVariant, string> = {
    default: 'bg-surface-alt border-line text-ink',
    success:
        'bg-[hsl(var(--success)/0.10)] border-[hsl(var(--success)/0.30)] text-[hsl(var(--success))]',
    warning:
        'bg-[hsl(var(--warning)/0.10)] border-[hsl(var(--warning)/0.30)] text-[hsl(var(--warning))]',
    destructive:
        'bg-[hsl(var(--destructive)/0.10)] border-[hsl(var(--destructive)/0.30)] text-[hsl(var(--destructive))]',
};

const classes = cn(base, variantClasses[variant], className);
---

<span class={classes} {...rest}>
    <slot />
</span>
