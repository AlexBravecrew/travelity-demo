---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

type EyebrowTone = 'teal' | 'ink';

export interface Props extends HTMLAttributes<'span'> {
    /** Show a 24px horizontal rule before the text. */
    withRule?: boolean;
    /** Center-align inside flex parent. Useful inside centered section headers. */
    centered?: boolean;
    /** Color tone. `teal` = section eyebrows (default). `ink` = muted metadata labels. */
    tone?: EyebrowTone;
    /** Forwarded to underlying element. */
    class?: string;
}

const {
    withRule = false,
    centered = false,
    tone = 'teal',
    class: className,
    ...rest
} = Astro.props;

const base =
    'inline-flex items-center gap-[10px] ' +
    'font-mono text-[11px] font-semibold uppercase tracking-[0.12em]';

const toneClasses: Record<EyebrowTone, string> = {
    teal: 'text-travelity-teal',
    ink: 'text-ink-muted',
};

const ruleColorClasses: Record<EyebrowTone, string> = {
    teal: 'bg-travelity-teal',
    ink: 'bg-ink-muted',
};

const justify = centered ? 'justify-center' : '';

const classes = cn(base, toneClasses[tone], justify, className);
---

<span class={classes} data-with-rule={withRule ? 'true' : undefined} {...rest}>
    {
        withRule && (
            <span
                class={cn('inline-block w-6 h-px', ruleColorClasses[tone])}
                aria-hidden="true"
            />
        )
    }
    <slot />
</span>
