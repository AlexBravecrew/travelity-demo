---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'svg'> {
    /** Unique gradient ID. Required when the mark renders more than once on a page. */
    gradientId?: string;
    /** Override CSS dimensions. Defaults to 32px square. */
    class?: string;
}

const {
    gradientId = `travelity-mark-${Math.random().toString(36).slice(2, 9)}`,
    class: className,
    ...rest
} = Astro.props;

const classes = cn('w-8 h-8 block', className);
---

<svg
    viewBox="0 0 32 32"
    fill="none"
    class={classes}
    aria-hidden="true"
    {...rest}
>
    <defs>
        <linearGradient id={gradientId} x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="hsl(218 50% 65%)"></stop>
            <stop offset="100%" stop-color="hsl(194 56% 65%)"></stop>
        </linearGradient>
    </defs>
    <path
        d="M4 6 L16 26 L28 6 L22 6 L16 16 L10 6 Z"
        fill={`url(#${gradientId})`}></path>
</svg>
