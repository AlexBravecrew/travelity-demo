---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import {
    SettingsIcon,
    GraduationCapIcon,
    HeadphonesIcon,
    SparklesIcon,
} from '@/icons';
import GoLiveStep from './GoLiveStep.astro';
import type { HTMLAttributes } from 'astro/types';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

export interface Props extends HTMLAttributes<'section'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

interface Step {
    title: string;
    description: string;
    Icon: AstroComponentFactory;
}

const steps: Step[] = [
    {
        title: 'Setup Assistance',
        description:
            'We help configure your account, products, schedules, and workflows to match your business needs.',
        Icon: SettingsIcon,
    },
    {
        title: 'Personalized Training',
        description:
            'Receive practical training sessions tailored to the way your company operates.',
        Icon: GraduationCapIcon,
    },
    {
        title: 'Dedicated Support',
        description: 'Get assistance from our support team whenever you need.',
        Icon: HeadphonesIcon,
    },
    {
        title: 'Continuous Improvements',
        description:
            'We are constantly evolving with new features and optimizations designed for modern travel businesses.',
        Icon: SparklesIcon,
    },
];
---

<section
    class={cn(
        'golive-section relative overflow-hidden bg-paper pb-10 md:pb-14',
        className,
    )}
    {...rest}
>
    <!-- Subtle teal bloom in upper-center area -->
    <span
        class="absolute pointer-events-none"
        style="top: -100px; left: 50%; transform: translateX(-50%); width: 600px; height: 400px; background: radial-gradient(ellipse at center, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%);"
        aria-hidden="true"></span>

    <div class="container mx-auto px-6 relative z-[1]">
        <SectionHeader
            eyebrow="Onboarding"
            eyebrowWithRule
            align="center"
            data-reveal
        >
            <Fragment slot="headline">
                We help you <em>go live.</em>
            </Fragment>
            <p
                slot="dek"
                class="text-[18px] text-ink-muted leading-[1.55] max-w-[56ch] mx-auto"
            >
                From initial setup and training to everyday assistance, our team
                supports you throughout the entire onboarding process and
                beyond.
            </p>
        </SectionHeader>

        <div
            class="golive-steps grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-x-8 lg:gap-y-12 mt-6"
        >
            {
                steps.map((step, idx) => (
                    <GoLiveStep
                        title={step.title}
                        description={step.description}
                        data-reveal
                        data-reveal-direction={idx % 2 === 0 ? 'down' : 'up'}
                        data-reveal-delay={idx * 80}
                    >
                        <step.Icon
                            slot="icon"
                            class="w-7 h-7"
                            stroke-width="1.75"
                            aria-hidden="true"
                        />
                    </GoLiveStep>
                ))
            }
        </div>
    </div>
</section>

<style>
    /* Warm-accent icons on steps 1 (Setup — sunset welcome) and 4 (Ongoing
       updates — amber, fits the SparklesIcon's "celebratory" feel). Steps
       2 + 3 keep their default teal from GoLiveStep. The icon-color
       contrast values are bumped darker (45–48% lightness) than the bg
       (60–65%) so the strokes stay readable on a tinted background. */
    .golive-steps :global(.golive-step:nth-child(1) .golive-step-icon) {
        background: hsl(var(--travelity-sunset) / 0.16);
        color: hsl(var(--travelity-sunset-ink));
    }
    .golive-steps :global(.golive-step:nth-child(4) .golive-step-icon) {
        background: hsl(var(--travelity-amber) / 0.2);
        color: hsl(var(--travelity-amber-ink));
    }

    /* ----------------------------------------------------------------
       Per-step icon animations. Each targets the SVG inside the icon
       container so ONLY the icon moves, the square background stays
       still. transform-origin is set explicitly where the rotation
       point matters (gear from center, cap from bottom).
       ---------------------------------------------------------------- */

    /* Step 1: gear rotates one full turn, then pauses, then again. */
    @keyframes golive-gear-rotate {
        0%,
        15% {
            transform: rotate(0deg);
        }
        50% {
            transform: rotate(360deg);
        }
        65%,
        100% {
            transform: rotate(360deg);
        }
    }
    .golive-steps :global(.golive-step:nth-child(1) .golive-step-icon svg) {
        animation: golive-gear-rotate 7s var(--ease-default) infinite;
        transform-origin: 50% 50%;
    }

    /* Step 2: cap wiggles right then left, pivot at the bottom edge so
       it reads like a head tipping side to side. */
    @keyframes golive-cap-wiggle {
        0%,
        100% {
            transform: rotate(0deg);
        }
        20% {
            transform: rotate(9deg);
        }
        40% {
            transform: rotate(0deg);
        }
        60% {
            transform: rotate(-9deg);
        }
        80% {
            transform: rotate(0deg);
        }
    }
    .golive-steps :global(.golive-step:nth-child(2) .golive-step-icon svg) {
        animation: golive-cap-wiggle 4.8s var(--ease-default) infinite;
        transform-origin: 50% 85%;
    }

    /* Step 3: headphones do a continuous full flip — short hold upright,
       then 360° rotation on the X axis with no pause at the upside-down
       point so the motion reads as one fluid revolution. */
    @keyframes golive-headphones-flip {
        0%,
        15% {
            transform: rotateX(0deg);
        }
        100% {
            transform: rotateX(360deg);
        }
    }
    .golive-steps :global(.golive-step:nth-child(3) .golive-step-icon svg) {
        animation: golive-headphones-flip 2.5s var(--ease-default) infinite;
        transform-origin: 50% 50%;
        backface-visibility: visible;
    }

    /* Step 4: sparkles "shine" — scale up + warm amber drop-shadow glow,
       then back to rest. The icon color is already amber so the glow
       reads as a deeper, more saturated version of itself. */
    @keyframes golive-sparkles-shine {
        0%,
        100% {
            transform: scale(1);
            filter: drop-shadow(0 0 0 transparent);
        }
        50% {
            transform: scale(1.18);
            filter: drop-shadow(0 0 10px hsl(var(--travelity-amber) / 0.95));
        }
    }
    .golive-steps :global(.golive-step:nth-child(4) .golive-step-icon svg) {
        animation: golive-sparkles-shine 4s ease-in infinite;
        transform-origin: 50% 50%;
    }

    @media (prefers-reduced-motion: reduce) {
        .golive-steps :global(.golive-step .golive-step-icon svg) {
            animation: none !important;
            transform: none !important;
            filter: none !important;
        }
    }
</style>
