---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import { LinkInline } from '@/components/ui/link-inline';
import {
    Share2Icon,
    CodeIcon,
    ClockIcon,
    FileCheckIcon,
    CreditCardIcon,
    CalendarIcon,
    ClipboardListIcon,
    UsersIcon,
    MessageSquareIcon,
} from '@/icons';
import { Paths } from '@/lib/utils/paths';
import FeatureCard from './FeatureCard.astro';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

const sectionClasses = cn(
    'features-section',
    'relative overflow-hidden bg-paper',
    'pb-10 md:pb-14',
    className,
);

const features = [
    {
        title: 'Channel Manager',
        description:
            'Sell through multiple booking channels without the hassle of managing inventory manually.',
        slug: 'channel-manager',
        icon: Share2Icon,
    },
    {
        title: 'Booking Widget',
        description:
            'Turn your website into a direct booking channel with a conversion-focused booking widget.',
        slug: 'booking-widget',
        icon: CodeIcon,
    },
    {
        title: 'Real-Time Availability',
        description:
            'Track live availability across all bookings and sales channels in real time.',
        slug: 'real-time-availability',
        icon: ClockIcon,
    },
    {
        title: 'Trip Proposal Builder',
        description:
            'Create interactive trip proposals in a few clicks and turn inquiries into confirmed bookings.',
        slug: 'trip-proposal-builder',
        icon: FileCheckIcon,
    },
    {
        title: 'Payment Gateway Integrations',
        description:
            'Accept online payments seamlessly through your booking flows and sales tools.',
        slug: 'payment-gateways',
        icon: CreditCardIcon,
    },
    {
        title: 'Booking Management',
        description:
            'Manage all your reservations, customer details, and payments from one centralized system.',
        slug: 'booking-management',
        icon: CalendarIcon,
    },
    {
        title: 'Daily Operations',
        description: 'Placeholder — real copy TBD.',
        slug: 'daily-operations',
        icon: ClipboardListIcon,
    },
    {
        title: 'CRM',
        description: 'Placeholder — real copy TBD.',
        slug: 'crm',
        icon: UsersIcon,
    },
    {
        title: 'Team Collaboration',
        description: 'Placeholder — real copy TBD.',
        slug: 'team-collaboration',
        icon: MessageSquareIcon,
    },
];
---

<section class={sectionClasses} {...rest}>
    <!-- Atmospheric blooms — large diffuse gradients in upper-right and lower-left -->
    <div
        class="absolute top-[200px] -right-[200px] w-[600px] h-[600px] pointer-events-none"
        style="background: radial-gradient(circle, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%);"
        aria-hidden="true"
    >
    </div>
    <div
        class="absolute bottom-[100px] -left-[200px] w-[500px] h-[500px] pointer-events-none"
        style="background: radial-gradient(circle, hsl(var(--travelity-blue) / 0.08) 0%, transparent 60%);"
        aria-hidden="true"
    >
    </div>

    <div class="container mx-auto px-6 relative z-[1]">
        <SectionHeader
            eyebrow="From bookings to operations"
            eyebrowWithRule
            align="center"
            data-reveal
        >
            <Fragment slot="headline">
                All the Essential Tools to <em>Run and Grow Your Business.</em>
            </Fragment>
            <p
                slot="dek"
                class="text-lg text-ink-muted leading-[1.55] max-w-[56ch] mx-auto"
            >
                Travelity brings together the features you need to manage
                sales, automate workflows, and operate more efficiently.
            </p>
        </SectionHeader>

        <div
            class="features-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[18px] mt-12 relative z-[1]"
        >
            {
                /* Home shows the first 6 of 9 features; the rest live on
                /features. Slug definitions for all 9 stay in the array
                above so anchor targets remain visible alongside this
                consumer. */
                features.slice(0, 6).map((f, idx) => {
                    const Icon = f.icon;
                    return (
                        <FeatureCard
                            title={f.title}
                            description={f.description}
                            href={`${Paths.FEATURES}#${f.slug}`}
                            data-reveal
                            data-reveal-delay={idx * 60}
                        >
                            <Icon
                                slot="icon"
                                class="w-5.5 h-5.5"
                                stroke-width="1.75"
                                aria-hidden="true"
                            />
                        </FeatureCard>
                    );
                })
            }
        </div>

        <div class="features-cta mt-14 text-center relative z-[1]">
            <LinkInline href={Paths.FEATURES} withArrow data-reveal>
                See all capabilities in detail
            </LinkInline>
        </div>
    </div>
</section>

<style>
    /* ============================================================
       Per-position color rotation on FeatureCards.
       Selectors target the FeatureCard wrapper (`.feature-card`)
       inside the grid. Pattern repeats every 6 cards — with 9 cards
       in a 3-column grid, positions 7-9 cycle back to colors 1-3,
       which reads cleanly in the 3x3 layout.
       ============================================================ */

    /* Corner gradient bloom — different tint per position */
    .features-grid :global(.feature-card) {
        position: relative;
    }

    .features-grid :global(.feature-card::before) {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 200px;
        height: 200px;
        pointer-events: none;
        transition: opacity 300ms;
        z-index: 0;
    }

    .features-grid :global(.feature-card:nth-child(6n + 1)::before) {
        background: radial-gradient(
            circle at top right,
            hsl(var(--travelity-dawn) / 0.18) 0%,
            transparent 60%
        );
    }
    .features-grid :global(.feature-card:nth-child(6n + 2)::before) {
        background: radial-gradient(
            circle at top right,
            hsl(var(--travelity-teal) / 0.1) 0%,
            transparent 60%
        );
    }
    .features-grid :global(.feature-card:nth-child(6n + 3)::before) {
        background: radial-gradient(
            circle at top right,
            hsl(var(--travelity-sunset) / 0.16) 0%,
            transparent 60%
        );
    }
    .features-grid :global(.feature-card:nth-child(6n + 4)::before) {
        background: radial-gradient(
            circle at top right,
            hsl(var(--travelity-teal-deep) / 0.1) 0%,
            transparent 60%
        );
    }
    .features-grid :global(.feature-card:nth-child(6n + 5)::before) {
        background: radial-gradient(
            circle at top right,
            hsl(var(--travelity-amber) / 0.18) 0%,
            transparent 60%
        );
    }
    .features-grid :global(.feature-card:nth-child(6n + 6)::before) {
        background: radial-gradient(
            circle at top right,
            hsl(var(--travelity-teal) / 0.1) 0%,
            transparent 60%
        );
    }
    .features-grid :global(.feature-card:hover::before) {
        opacity: 1.4;
    }

    /* Icon container — different tint per position */
    .features-grid :global(.feature-card:nth-child(6n + 1) .feature-icon) {
        background: hsl(var(--travelity-dawn) / 0.22);
        color: hsl(350 50% 48%);
    }
    .features-grid :global(.feature-card:nth-child(6n + 2) .feature-icon) {
        background: hsl(var(--travelity-teal) / 0.14);
        color: hsl(var(--travelity-teal));
    }
    .features-grid :global(.feature-card:nth-child(6n + 3) .feature-icon) {
        background: hsl(var(--travelity-sunset) / 0.16);
        color: hsl(14 65% 48%);
    }
    .features-grid :global(.feature-card:nth-child(6n + 4) .feature-icon) {
        background: hsl(var(--travelity-teal-deep) / 0.12);
        color: hsl(var(--travelity-teal-deep));
    }
    .features-grid :global(.feature-card:nth-child(6n + 5) .feature-icon) {
        background: hsl(var(--travelity-amber) / 0.18);
        color: hsl(32 70% 42%);
    }
    .features-grid :global(.feature-card:nth-child(6n + 6) .feature-icon) {
        background: hsl(var(--travelity-teal) / 0.14);
        color: hsl(var(--travelity-teal));
    }
</style>
