---
import { Card } from '@/components/ui/card';
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'a'> {
    title: string;
    description: string;
    /** Destination link — every feature card is clickable. */
    href: string;
    class?: string;
}

const { title, description, href, class: className, ...rest } = Astro.props;
---

{
    /* The `<a>` is the full-card click surface. Card primitive provides the
    visual treatment (hover-lift via `interactive`, border, radius). Padding
    moved from Card to the inner `<a>` so the entire card interior is the
    click target — no dead-zones around the edges. `.feature-card` stays on
    Card so FeaturesSection's :nth-child color rotation still works (the
    selector targets direct children of `.features-grid`). */
}
<Card interactive class={cn('feature-card', className)}>
    <a
        href={href}
        class="block no-underline p-7 text-inherit h-full"
        {...rest}
    >
        <!-- Icon container — color rotation is set by FeaturesSection's scoped CSS -->
        <div
            class="feature-icon w-12 h-12 rounded-xl flex items-center justify-center mb-5 relative z-[1]"
        >
            <slot name="icon" />
        </div>

        <h3
            class="font-display text-lg font-semibold leading-[1.3] tracking-[-0.02em] text-ink mb-2 relative z-[1]"
        >
            {title}
        </h3>

        <p
            class="text-[14.5px] text-ink-muted leading-[1.6] m-0 relative z-[1]"
        >
            {description}
        </p>
    </a>
</Card>
