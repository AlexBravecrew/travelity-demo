---
import { cn } from '@/lib/utils/cn';
import { MountainScene } from '@/components/decorative/mountain-scene';
import BookingFlowCard from './BookingFlowCard.astro';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    /**
     * Optional URL for a real photo. When provided, replaces MountainScene.
     * Designed for swap when a real travel photo is sourced.
     */
    photoSrc?: string;
    /** Alt text for the photo. Required if photoSrc is set. */
    photoAlt?: string;
    class?: string;
}

const { photoSrc, photoAlt, class: className, ...rest } = Astro.props;
---

<div
    class={cn(
        'hero-visual',
        'relative overflow-hidden rounded-[18px]',
        'aspect-[4/5] max-h-[600px] lg:aspect-auto lg:h-[540px] lg:max-h-none',
        'shadow-[0_32px_64px_-20px_hsl(var(--travelity-blue)/0.25)]',
        className,
    )}
    style="background: linear-gradient(180deg, hsl(194 35% 88%) 0%, hsl(200 45% 70%) 30%, hsl(218 42% 48%) 65%, hsl(218 42% 30%) 100%);"
    {...rest}
>
    <!-- Soft sun bloom -->
    <div
        class="absolute top-[60px] right-[90px] w-[130px] h-[130px] rounded-full"
        style="background: radial-gradient(circle, hsl(194 70% 85%) 0%, hsl(200 60% 70% / 0.35) 60%, transparent 80%); filter: blur(1px);"
        aria-hidden="true"
    >
    </div>

    <!-- Atmospheric haze -->
    <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse at 30% 70%, hsl(194 60% 85% / 0.28) 0%, transparent 50%), radial-gradient(ellipse at 70% 40%, hsl(218 50% 70% / 0.2) 0%, transparent 50%);"
        aria-hidden="true"
    >
    </div>

    <!-- Scene: real photo if provided, otherwise SVG mock -->
    <div class="absolute bottom-0 left-0 right-0 h-[65%]">
        {
            photoSrc ? (
                <img
                    src={photoSrc}
                    alt={photoAlt ?? ''}
                    class="w-full h-full object-cover block"
                    loading="eager"
                    decoding="async"
                />
            ) : (
                <MountainScene />
            )
        }
    </div>

    <!-- The page's signature visual: the booking-flow card -->
    <BookingFlowCard />
</div>
