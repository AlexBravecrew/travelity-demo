---
import { cn } from '@/lib/utils/cn';
import { Button } from '@/components/ui/button';
import { Eyebrow } from '@/components/ui/eyebrow';
import { CheckIcon } from '@/icons';
import { Paths } from '@/lib/utils/paths';
import BookDemoVideo from '@/components/book-demo/BookDemoVideo.astro';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<section
    class={cn(
        'hero',
        'relative overflow-hidden bg-paper',
        'pb-4 lg:pb-4',
        className,
    )}
    {...rest}
>
    <div class="container mx-auto px-6">
        <div
            class="hero-content relative z-2 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-18 items-center min-h-135 lg:min-h-150"
        >
            <!-- Text column -->
            <div class="hero-text max-w-140">
                <Eyebrow withRule data-reveal
                    >Booking platform for travel businesses</Eyebrow
                >

                <h1
                    class="font-serif font-semibold text-ink leading-[1.02] tracking-[-0.035em] mt-6 mb-6"
                    style="font-size: clamp(36px, 4.2vw, 56px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    Run your travel business<br />
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            without the spreadsheets.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-[22px] text-ink-muted leading-[1.55] max-w-[52ch] mb-4"
                    data-reveal
                    data-reveal-delay="160"
                >
                    Bookings, channels, OTA integrations, payments, and
                    operations — all in one platform.
                </p>

                <div class="mb-9" data-reveal data-reveal-delay="240">
                    <p class="text-lg text-ink-muted leading-[1.55] mb-3">
                        Built for:
                    </p>
                    <ul
                        class="m-0 p-0 list-none grid grid-cols-2 gap-x-6 gap-y-2.5 max-w-[460px]"
                    >
                        {
                            [
                                'Tour Operators',
                                'Transfer Providers',
                                'Travel Agencies',
                                'Independent Guides',
                            ].map((label) => (
                                <li class="grid grid-cols-[22px_1fr] gap-3 items-center text-[15px] text-ink">
                                    <span
                                        class="block w-1.5 h-1.5 rounded-full bg-travelity-teal mx-auto"
                                        style="box-shadow: 0 0 0 3px hsl(var(--travelity-teal) / 0.16);"
                                        aria-hidden="true"
                                    />
                                    <span class="font-display font-semibold">
                                        {label}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <div
                    class="flex flex-wrap gap-3 mb-7"
                    data-reveal
                    data-reveal-delay="320"
                >
                    <Button href={Paths.BOOK_DEMO} size="lg" withArrow>
                        Book a Demo
                    </Button>
                    <Button
                        href={Paths.START_TRIAL}
                        size="lg"
                        variant="outline"
                        external
                    >
                        Start Free Trial
                    </Button>
                </div>

                <div
                    class="flex flex-wrap items-center gap-6 text-[13px] text-ink-muted"
                    data-reveal
                    data-reveal-delay="400"
                >
                    <span class="inline-flex items-center gap-1.5">
                        <CheckIcon
                            class="w-3.5 h-3.5 text-travelity-teal"
                            stroke-width="2.5"
                            aria-hidden="true"
                        />
                        No credit card
                    </span>
                    <span class="inline-flex items-center gap-1.5">
                        <CheckIcon
                            class="w-3.5 h-3.5 text-travelity-teal"
                            stroke-width="2.5"
                            aria-hidden="true"
                        />
                        30-day trial
                    </span>
                    <span class="inline-flex items-center gap-1.5">
                        <CheckIcon
                            class="w-3.5 h-3.5 text-travelity-teal"
                            stroke-width="2.5"
                            aria-hidden="true"
                        />
                        White-glove setup
                    </span>
                </div>
            </div>

            <!-- Visual column -->
            <BookDemoVideo
                videoId="LZfT8xLdzIQ"
                data-reveal
                data-reveal-direction="right"
                data-reveal-delay="200"
            />
        </div>
    </div>
</section>
