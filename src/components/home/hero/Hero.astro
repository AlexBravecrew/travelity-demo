---
import { cn } from '@/lib/utils/cn';
import { Button } from '@/components/ui/button';
import { Eyebrow } from '@/components/ui/eyebrow';
import { CheckIcon } from '@/icons';
import { Paths } from '@/lib/utils/paths';
import BookDemoVideo from '@/components/book-demo/BookDemoVideo.astro';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<section
    class={cn(
        'hero',
        'relative overflow-hidden bg-paper',
        'pt-8 pb-4 lg:pt-8 lg:pb-4',
        className,
    )}
    {...rest}
>
    <!-- Warm afternoon-window bloom behind the video. Subtle (opacity
         ~0.22 with heavy blur), sits in the upper-right quadrant — adds
         ~15% warmth to the above-the-fold without competing with the
         cool palette dominant elsewhere on the page. -->
    <span
        aria-hidden="true"
        class="hero-warm-bloom pointer-events-none absolute"
        style="top: -120px; right: -120px; width: 540px; height: 540px; background: radial-gradient(circle, hsl(var(--travelity-sunset) / 0.55), hsl(var(--travelity-amber) / 0.25) 50%, transparent 75%); filter: blur(90px); opacity: 0.55; z-index: 0;"
    >
    </span>

    <div class="container mx-auto px-6 relative z-[1]">
        <div
            class="hero-content relative z-2 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-18 items-center min-h-135 lg:min-h-150"
        >
            <!-- Text column -->
            <div class="hero-text max-w-140">
                <Eyebrow withRule
                    >Booking platform for travel businesses</Eyebrow
                >

                <h1
                    class="font-serif font-semibold text-ink leading-[1.02] tracking-[-0.035em] mt-6 mb-6"
                    style="font-size: clamp(36px, 4.2vw, 56px);"
                >
                    Run your travel business<br />
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            without the spreadsheets.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-[22px] text-ink-muted leading-[1.55] max-w-[52ch] mb-4"
                >
                    Bookings, channels, OTA integrations, payments, and
                    operations — all in one platform.
                </p>

                <p
                    class="text-lg text-ink-muted leading-[1.55] max-w-[52ch] mb-9"
                >
                    Built for:
                    <span class="font-semibold text-travelity-teal"
                        >Tour Operators</span
                    >
                    |
                    <span class="font-semibold text-travelity-teal"
                        >Transfer Providers</span
                    >
                    |
                    <span class="font-semibold text-travelity-teal"
                        >Travel Agencies</span
                    >
                    |
                    <span class="font-semibold text-travelity-teal"
                        >Independent Guides</span
                    >
                </p>

                <div class="flex flex-wrap gap-3 mb-7">
                    <Button href={Paths.BOOK_DEMO} size="lg" withArrow>
                        Book a Demo
                    </Button>
                    <Button
                        href={Paths.START_TRIAL}
                        size="lg"
                        variant="outline"
                        external
                    >
                        Start Free Trial
                    </Button>
                </div>

                <div
                    class="flex flex-wrap items-center gap-6 text-[13px] text-ink-muted"
                >
                    <span class="inline-flex items-center gap-1.5">
                        <CheckIcon
                            class="w-3.5 h-3.5 text-travelity-teal"
                            stroke-width="2.5"
                            aria-hidden="true"
                        />
                        No credit card
                    </span>
                    <span class="inline-flex items-center gap-1.5">
                        <CheckIcon
                            class="w-3.5 h-3.5 text-travelity-teal"
                            stroke-width="2.5"
                            aria-hidden="true"
                        />
                        30-day trial
                    </span>
                    <span class="inline-flex items-center gap-1.5">
                        <CheckIcon
                            class="w-3.5 h-3.5 text-travelity-teal"
                            stroke-width="2.5"
                            aria-hidden="true"
                        />
                        White-glove setup
                    </span>
                </div>
            </div>

            <!-- Visual column -->
            <BookDemoVideo videoId="LZfT8xLdzIQ" />
        </div>
    </div>
</section>
