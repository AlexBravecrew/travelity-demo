---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<div
    class={cn('absolute bottom-0 left-0 right-0 h-[70%]', className)}
    aria-hidden="true"
    {...rest}
>
    <svg
        viewBox="0 0 1440 320"
        preserveAspectRatio="xMidYMax slice"
        class="w-full h-full block"
    >
        <!-- distant ridge -->
        <path
            d="M0 200 L120 100 L240 160 L380 80 L500 130 L620 90 L760 150 L900 100 L1040 160 L1180 110 L1320 150 L1440 120 L1440 320 L0 320 Z"
            fill="hsl(220 35% 35%)"
            opacity="0.55"></path>
        <!-- mid ridge -->
        <path
            d="M0 240 L100 180 L220 220 L340 170 L460 200 L580 175 L720 220 L860 180 L1000 220 L1140 185 L1280 220 L1440 195 L1440 320 L0 320 Z"
            fill="hsl(220 45% 22%)"
            opacity="0.78"></path>
        <!-- foreground silhouette -->
        <path
            d="M0 280 L80 230 L180 270 L280 240 L400 280 L520 240 L640 280 L760 245 L880 280 L1000 245 L1120 280 L1240 250 L1360 285 L1440 260 L1440 320 L0 320 Z"
            fill="hsl(220 55% 12%)"></path>
    </svg>
</div>
