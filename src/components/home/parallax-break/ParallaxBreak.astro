---
import ParallaxScene from './ParallaxScene.astro';
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<div
    class={cn('parallax-break relative overflow-hidden h-[480px]', className)}
    {...rest}
>
    <!-- Photo layer — gets translated on scroll by nav.client.ts.
         data-parallax-photo is the script's hook. -->
    <div
        data-parallax-photo
        class="parallax-photo absolute inset-x-0 will-change-transform"
        style="top: -10%; bottom: -10%; background: linear-gradient(135deg, hsl(220 50% 25%) 0%, hsl(218 42% 40%) 40%, hsl(200 50% 55%) 70%, hsl(218 42% 30%) 100%);"
    >
        <!-- Atmospheric haze blob -->
        <span
            class="absolute rounded-full pointer-events-none"
            style="top: 30%; right: 15%; width: 240px; height: 240px; background: radial-gradient(circle, hsl(194 70% 85% / 0.35) 0%, transparent 70%); filter: blur(8px);"
            aria-hidden="true"></span>
        <ParallaxScene />
    </div>

    <!-- Dark gradient overlay above photo, below text -->
    <div
        class="absolute inset-0 z-[2] pointer-events-none"
        style="background: linear-gradient(180deg, hsl(220 50% 15% / 0.2) 0%, hsl(220 50% 15% / 0) 50%, hsl(220 50% 15% / 0.4) 100%);"
        aria-hidden="true"
    >
    </div>

    <!-- Text layer — center -->
    <div class="absolute inset-0 z-[3] flex items-center justify-center px-8">
        <div class="text-center max-w-[760px]">
            <span
                class="block font-serif italic leading-none mb-[-20px]"
                style="font-size: 80px; color: hsl(194 60% 85% / 0.85);"
                aria-hidden="true"
            >
                "
            </span>
            <h2
                class="font-serif italic font-medium leading-[1.15] tracking-[-0.02em] text-white mb-4"
                style="font-size: clamp(32px, 4vw, 48px); text-shadow: 0 2px 24px hsl(220 50% 10% / 0.4);"
            >
                The seat is locked the second a guest clicks <em
                    class="not-italic font-medium">Book</em
                >.
            </h2>
            <div
                class="font-mono text-[12px] uppercase tracking-[0.10em] text-white/[0.78]"
            >
                No double-bookings · ever
            </div>
        </div>
    </div>
</div>
