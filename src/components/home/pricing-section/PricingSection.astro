---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import { Paths } from '@/lib/utils/paths';
import PricingPlan, { type PlanFeature } from './PricingPlan.astro';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    /**
     * Skip the inner SectionHeader (eyebrow + h2 + dek). Used on `/pricing`
     * where the page hero already shows the same title.
     */
    hideHeader?: boolean;
    class?: string;
}

const { hideHeader = false, class: className, ...rest } = Astro.props;

interface Plan {
    name: string;
    tagline: string;
    priceAmount: string;
    billing: string;
    ctaLabel: string;
    ctaHref: string;
    ctaVariant: 'primary' | 'outline';
    includesLabel: string;
    features: PlanFeature[];
    badgeLabel?: string;
}

// TODO: replace placeholder feature copy with real plan details before launch.
// All CTAs route to BOOK_DEMO until a signup/contact-sales flow exists.
const plans: Plan[] = [
    {
        name: 'Free',
        tagline: 'For solo guides and small operators just getting started.',
        priceAmount: '0',
        billing: 'Free forever · No credit card',
        ctaLabel: 'Start Free',
        ctaHref: Paths.BOOK_DEMO,
        ctaVariant: 'outline',
        includesLabel: "What's included",
        features: [
            { label: 'Plan feature one', sub: 'short qualifier text' },
            { label: 'Plan feature two', sub: 'short qualifier text' },
            { label: 'Plan feature three' },
            { label: 'Plan feature four' },
            { label: 'Plan feature five' },
            { label: 'Excluded feature one', muted: true },
            { label: 'Excluded feature two', muted: true },
        ],
    },
    {
        name: 'Plus',
        tagline: 'For growing operators who sell across multiple channels.',
        priceAmount: '79',
        billing: 'Billed monthly · or $69/mo annually',
        ctaLabel: 'Start 30-day Trial',
        ctaHref: Paths.BOOK_DEMO,
        ctaVariant: 'primary',
        includesLabel: 'Everything in Free, plus',
        features: [
            { label: 'Plus feature one' },
            { label: 'Plus feature two', sub: 'short qualifier text' },
            { label: 'Plus feature three', sub: 'short qualifier text' },
            { label: 'Plus feature four' },
            { label: 'Plus feature five' },
            { label: 'Plus feature six' },
            { label: 'Plus feature seven' },
        ],
        badgeLabel: 'Most popular',
    },
    {
        name: 'Ultimate',
        tagline:
            'For multi-product operators with serious volume and complexity.',
        priceAmount: '199',
        billing: 'Billed monthly · custom enterprise plans available',
        ctaLabel: 'Talk to Sales',
        ctaHref: Paths.BOOK_DEMO,
        ctaVariant: 'outline',
        includesLabel: 'Everything in Plus, plus',
        features: [
            { label: 'Ultimate feature one' },
            { label: 'Ultimate feature two', sub: 'short qualifier text' },
            { label: 'Ultimate feature three' },
            { label: 'Ultimate feature four' },
            { label: 'Ultimate feature five' },
            { label: 'Ultimate feature six' },
            { label: 'Ultimate feature seven' },
        ],
    },
];
---

<section
    class={cn('pricing-section relative bg-paper py-12 md:py-16', className)}
    {...rest}
>
    <div class="container mx-auto px-6">
        {
            !hideHeader && (
                <SectionHeader eyebrow="Pricing" eyebrowWithRule align="center">
                    <Fragment slot="headline">
                        Plans for every <em>size of operation.</em>
                    </Fragment>
                    <p
                        slot="dek"
                        class="text-[18px] text-ink-muted leading-[1.55] max-w-[56ch] mx-auto"
                    >
                        From solo guides on the Free plan to multi-product
                        operators on Ultimate. Same booking engine, same channel
                        reach — different limits, different support tiers.
                    </p>
                </SectionHeader>
            )
        }

        <div
            class="pricing-cards grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-4 max-w-[1100px] mx-auto items-stretch"
        >
            {
                plans.map((plan) => (
                    <PricingPlan
                        name={plan.name}
                        tagline={plan.tagline}
                        priceAmount={plan.priceAmount}
                        billing={plan.billing}
                        ctaLabel={plan.ctaLabel}
                        ctaHref={plan.ctaHref}
                        ctaVariant={plan.ctaVariant}
                        includesLabel={plan.includesLabel}
                        features={plan.features}
                        badgeLabel={plan.badgeLabel}
                    />
                ))
            }
        </div>
    </div>
</section>

<style is:global>
    /*
     * Active-card hover swap (Phase 21).
     *
     * Default state: the middle (2nd) card is "active" — gradient conic
     * border + elevation + teal shadow. When any card is hovered, that
     * card becomes active and the middle de-activates (unless the middle
     * itself is the hovered one). Uses CSS `:has()` — modern-browser
     * baseline (Chrome/Edge 105+, Safari 15.4+, Firefox 121+).
     *
     * Style block is `is:global` because the active selector chain
     * combines `:has()` + a child class that lives in another component's
     * scope (`.pricing-plan` is added by PricingPlan.astro / Card.astro).
     * Astro's `:global()` wrapper interacted poorly with `:has()` here —
     * unscoping the whole block is simpler and the `.pricing-cards` class
     * is unique to this section, so style leakage isn't a concern.
     *
     * The conic-gradient background + 1.5px inset pseudo cover the same
     * pattern Card.astro's `featured` variant uses. The `@property` and
     * `@keyframes card-gradient-spin` declared in Card.astro are at-rules
     * (global by spec), so this block can reuse them without re-declaration.
     */

    .pricing-cards .pricing-plan {
        transition:
            transform 240ms cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 240ms cubic-bezier(0.4, 0, 0.2, 1),
            border-color 240ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Active state: middle card by default, OR any hovered card. */
    .pricing-cards:not(:has(.pricing-plan:hover)) .pricing-plan:nth-child(2),
    .pricing-cards .pricing-plan:hover {
        --card-gradient-angle: 0deg;
        isolation: isolate;
        background: conic-gradient(
            from var(--card-gradient-angle, 0deg),
            hsl(var(--travelity-teal)),
            hsl(var(--travelity-blue)),
            hsl(var(--travelity-teal-deep)),
            hsl(var(--travelity-teal))
        );
        animation: card-gradient-spin 10s linear infinite;
        border-color: transparent;
        box-shadow: 0 16px 40px -12px hsl(var(--travelity-teal) / 0.18);
    }

    @media (min-width: 1024px) {
        .pricing-cards:not(:has(.pricing-plan:hover))
            .pricing-plan:nth-child(2),
        .pricing-cards .pricing-plan:hover {
            transform: translateY(-12px) scale(1.02);
        }
    }

    /* Paper-colored interior overlay — completes the gradient-ring look. */
    .pricing-cards:not(:has(.pricing-plan:hover))
        .pricing-plan:nth-child(2)::before,
    .pricing-cards .pricing-plan:hover::before {
        content: '';
        position: absolute;
        inset: 1.5px;
        z-index: -1;
        border-radius: 14.5px;
        background: hsl(var(--paper));
    }

    @media (prefers-reduced-motion: reduce) {
        .pricing-cards .pricing-plan {
            transition: none !important;
        }
        .pricing-cards:not(:has(.pricing-plan:hover))
            .pricing-plan:nth-child(2),
        .pricing-cards .pricing-plan:hover {
            animation: none !important;
            transform: none !important;
        }
    }
</style>
