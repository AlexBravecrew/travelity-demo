---
import { cn } from '@/lib/utils/cn';
import ReviewCard from './ReviewCard.astro';
import type { HTMLAttributes } from 'astro/types';
import type { ImageMetadata } from 'astro';

// Customer review photos — live in src/assets/reviews/ so Astro can
// optimize them at build time (sources are multi-MB camera-roll files).
// Order here drives display order in the carousel; renumber by swapping
// imports + the reviews[] array entries.
import review01 from '@/assets/reviews/review-01.jpg';
import review02 from '@/assets/reviews/review-02.png';
import review03 from '@/assets/reviews/review-03.jpg';
import review04 from '@/assets/reviews/review-04.png';
import review05 from '@/assets/reviews/review-05.png';

/**
 * Home "social proof" band — replaces the retired ParallaxBreak. Dark
 * teal→navy gradient separates this section from the surrounding white
 * sections. The CAROUSEL container inside is transparent and gets its
 * own vertical padding so the polaroid halos have room to bloom without
 * triggering a vertical scrollbar.
 *
 * Layout:
 *   - lg+ (≥1024px): 5-column grid of polaroid cards. First card is the
 *     default-active; hovering any card transfers active state.
 *   - <lg (mobile + tablet): horizontal scroll-snap carousel — 1 card
 *     visible on phone, 3 on tablet. All cards are visually active
 *     (text on, halo on) and STRAIGHT (no tilt, no Y offset, no
 *     scale-up). Infinite loop via JS-cloned first/last cards at the
 *     ends — when the user lands on a clone after scrolling, scrollLeft
 *     is silently set to the matching real card. Pagination dots below
 *     track and drive the position.
 *
 * Carousel behavior lives in reviews.client.ts.
 */

export interface Props extends HTMLAttributes<'section'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

interface Review {
    imageSrc: ImageMetadata;
    imageAlt: string;
    quote: string;
    name: string;
    byline: string;
}

const reviews: Review[] = [
    {
        imageSrc: review01,
        imageAlt: 'Anna T. — tour operator in Tbilisi',
        quote: 'Replaced our spreadsheet chaos. Fully onboarded in less than a week.',
        name: 'Anna T.',
        byline: 'Tour Operator · Tbilisi',
    },
    {
        imageSrc: review02,
        imageAlt: 'Carlos M. — tour operator in Ubud',
        quote: 'No overbookings finally! OTA synchronization works the way it should.',
        name: 'Carlos M.',
        byline: 'Tour Operator · Ubud',
    },
    {
        imageSrc: review03,
        imageAlt: 'David H. — transfer provider in Bangkok',
        quote: 'Our airport transfers are fully organized — no missed pickups, no confusion.',
        name: 'David H.',
        byline: 'Transfer Provider · Bangkok',
    },
    {
        imageSrc: review04,
        imageAlt: 'Sofia P. — travel agency in Abu Dhabi',
        quote: 'Direct bookings increased after adding the widget to our website.',
        name: 'Sofia P.',
        byline: 'Travel Agency · Abu Dhabi',
    },
    {
        imageSrc: review05,
        imageAlt: 'Diana H. — individual guide in Tbilisi',
        quote: 'Much easier to manage my daily schedules.',
        name: 'Diana H.',
        byline: 'Individual Guide · Tbilisi',
    },
];

const tilts = ['-2.4deg', '1.8deg', '-1.4deg', '2.2deg', '-2deg'];
const yOffsets = ['10px', '-14px', '12px', '-8px', '8px'];
---

<section
    class={cn(
        'reviews-section relative overflow-hidden py-10 md:py-14',
        className,
    )}
    style="background: linear-gradient(180deg, hsl(218 45% 28%) 0%, hsl(194 38% 36%) 50%, hsl(218 45% 28%) 100%);"
    {...rest}
>
    <!-- Wider than the site-standard 1280px on lg+ so the 5-up grid
         gives each card meaningfully more horizontal room. -->
    <div class="mx-auto max-w-7xl lg:max-w-375 px-6 relative">
        <div class="reviews-carousel-wrap relative">
            <div
                class="review-grid grid grid-cols-1 lg:grid-cols-5 lg:gap-5"
                data-review-grid
            >
                {
                    reviews.map((r, i) => (
                        <ReviewCard
                            imageSrc={r.imageSrc}
                            imageAlt={r.imageAlt}
                            quote={r.quote}
                            name={r.name}
                            byline={r.byline}
                            tilt={tilts[i % tilts.length]}
                            yOffset={yOffsets[i % yOffsets.length]}
                            data-review-card
                            data-active={i === 0 ? 'true' : 'false'}
                            data-reveal
                            data-reveal-delay={i * 100}
                        />
                    ))
                }
            </div>

            <!-- Below-lg pagination dots. One dot per real card; the
                 active one is the first-visible card in the current
                 viewport. Click a dot to scroll to that card. Hidden
                 on lg+ where the grid shows everything at once. -->
            <div
                class="reviews-dots lg:hidden flex items-center justify-center gap-2 mt-6"
                data-review-dots
                role="tablist"
                aria-label="Review pagination"
            >
                {
                    reviews.map((_, i) => (
                        <button
                            type="button"
                            data-review-dot={i}
                            aria-label={`Go to review ${i + 1}`}
                            class="reviews-dot"
                        />
                    ))
                }
            </div>
        </div>
    </div>
</section>

<style>
    /* Pre-JS resting state — each card sits at its own --y / --tilt (set
       by ReviewCard from props), so cards render tilted/offset before
       hydration. reviews.client.ts then overrides this with inline styles
       once it knows which mode (mobile vs desktop) applies. */
    .review-grid :global(.review-card .review-card-frame) {
        transform: translateY(var(--y, 0px)) rotate(var(--tilt, 0deg));
    }

    /* Below lg, cards live in a horizontal scroll-snap carousel and only
       one is in the viewport at a time. Per-card scroll-reveal would
       leave cards 2-5 invisible until the user swipes to them, which
       reads as jank rather than polish. Force them visible immediately;
       the per-card cascade stays a desktop-only effect. */
    @media (max-width: 1023px) {
        .review-grid :global([data-reveal]) {
            opacity: 1 !important;
            transform: none !important;
            transition: none !important;
        }
    }

    /* Below-lg carousel — horizontal scroll-snap row. overflow-x: auto
       + overflow-y: clip prevents either axis from showing a scrollbar
       even when the polaroid halo extends past the card edges. Inner
       padding-block gives the halo room. */
    @media (max-width: 1023px) {
        .review-grid {
            display: flex;
            flex-direction: row;
            flex-wrap: nowrap;
            align-items: stretch;
            overflow-x: auto;
            overflow-y: clip;
            padding-block: 24px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            -ms-overflow-style: none;
            scrollbar-color: transparent transparent;
        }
        .review-grid::-webkit-scrollbar {
            width: 0;
            height: 0;
            background: transparent;
            display: none;
        }
        .review-grid :global(.review-card) {
            scroll-snap-align: start;
            scroll-snap-stop: always;
        }
    }

    /* Phone — one card visible at a time. */
    @media (max-width: 767px) {
        .review-grid {
            gap: 12px;
        }
        .review-grid :global(.review-card) {
            flex: 0 0 100%;
            min-width: 100%;
        }
    }

    /* Tablet (md → lg) — three cards visible with a small gap between.
       Each card snaps to start so swipes and arrow nudges advance by
       exactly one card. */
    @media (min-width: 768px) and (max-width: 1023px) {
        .review-grid {
            gap: 16px;
        }
        .review-grid :global(.review-card) {
            flex: 0 0 calc((100% - 32px) / 3);
            min-width: calc((100% - 32px) / 3);
        }
    }

    /* Pagination dots — small pills below the carousel. Inactive dots
       sit at low opacity; the active one expands and goes full opacity.
       Sized for comfortable tap targets while staying visually small. */
    .reviews-dot {
        width: 8px;
        height: 8px;
        padding: 0;
        border: 0;
        border-radius: 999px;
        background: hsl(var(--paper) / 0.4);
        cursor: pointer;
        transition:
            width 220ms var(--ease-out),
            background-color 220ms var(--ease-out),
            opacity 220ms var(--ease-out);
    }
    .reviews-dot:hover {
        background: hsl(var(--paper) / 0.7);
    }
    .reviews-dot[data-active='true'] {
        width: 24px;
        background: hsl(var(--paper));
    }

    @media (prefers-reduced-motion: reduce) {
        .review-grid :global(.review-card .review-card-frame) {
            transform: none !important;
            transition: none !important;
        }
        .reviews-dot {
            transition: none !important;
        }
    }
</style>

<script>
    import './reviews.client.ts';
</script>
