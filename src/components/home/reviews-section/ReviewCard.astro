---
import { Image } from 'astro:assets';
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';
import type { ImageMetadata } from 'astro';

/**
 * Polaroid-style customer review card for the home page reviews section.
 *
 * Shape borrowed from `src/components/solutions/outcome-collage/OutcomeCollage.astro`
 * — paper border with inner image, cool duotone filter, tilt + Y offset via
 * CSS vars set by the parent. The key difference: there's a review overlay
 * anchored to the bottom of the image (dark gradient veil + italic quote +
 * mono author line) whose visibility is driven by parent CSS — the parent
 * grid uses `:has(:hover)` + `:first-child` rules to show one review at a
 * time and default to the first card being active.
 *
 * No text outside the image — per design spec.
 */

export interface Props extends HTMLAttributes<'article'> {
    /** Imported image asset from `src/assets/reviews/`. Processed through
        Astro's <Image /> for build-time optimization (the source JPGs are
        several MB; raw <img> would ship them whole). */
    imageSrc: ImageMetadata;
    imageAlt: string;
    /** Customer quote — wrap-as-given. */
    quote: string;
    /** Customer name. */
    name: string;
    /** Byline — customer business / city under the name. */
    byline: string;
    /** Resting rotation, e.g. "-2.2deg". Defaults to no tilt. */
    tilt?: string;
    /** Resting Y offset, e.g. "10px" or "-12px". Defaults to 0. */
    yOffset?: string;
    class?: string;
}

const {
    imageSrc,
    imageAlt,
    quote,
    name,
    byline,
    tilt = '0deg',
    yOffset = '0px',
    class: className,
    ...rest
} = Astro.props;
---

<article
    class={cn('review-card relative', className)}
    style={`--tilt: ${tilt}; --y: ${yOffset};`}
    {...rest}
>
    <!-- Halo glow behind the card. Visibility driven by parent grid CSS. -->
    <span
        aria-hidden="true"
        class="review-card-halo absolute -inset-4 -z-10 rounded-2xl pointer-events-none opacity-0"
        style="background: radial-gradient(60% 60% at 50% 50%, hsl(var(--travelity-teal) / 0.35), transparent 70%); filter: blur(28px); transition: opacity 500ms var(--ease-out);"
    >
    </span>

    <!-- Paper frame — gets the tilt/scale/lift transforms via parent CSS.
         max-w-[360px] caps the polaroid so the image stays a reasonable
         size on landscape phones and other single-card-wide carousel
         viewports; mx-auto centers it inside the article's flex slot. -->
    <div
        class="review-card-frame relative overflow-hidden rounded-2xl border border-line bg-paper p-2 max-w-90 mx-auto"
        style="box-shadow: 0 18px 40px -16px hsl(var(--travelity-blue-deep) / 0.35), 0 6px 16px -8px hsl(var(--ink) / 0.15); transition: transform 600ms var(--ease-default), box-shadow 600ms var(--ease-default);"
    >
        <div
            class="relative overflow-hidden rounded-xl bg-surface-alt aspect-4/5"
        >
            <Image
                src={imageSrc}
                alt={imageAlt}
                widths={[360, 720]}
                sizes="(max-width: 1023px) 90vw, 360px"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover"
            />

            <!-- Review overlay — bottom-anchored, fades in via parent CSS.
                 Tighter text sizing because the cards are small in the
                 5-in-a-row desktop layout (~230px wide). -->
            <div
                class="review-overlay absolute inset-x-0 bottom-0 opacity-0"
                style="transition: opacity 350ms var(--ease-out);"
            >
                <!-- Dark legibility veil. Pushed deeper than the original
                     0.95/0.5/55% ramp so longer real quotes don't sit on a
                     fading veil at the top of the overlay. -->
                <span
                    aria-hidden="true"
                    class="absolute inset-0"
                    style="background: linear-gradient(0deg, hsl(220 50% 6% / 0.95) 0%, hsl(220 50% 6% / 0.82) 40%, hsl(220 50% 6% / 0.5) 75%, transparent);"
                >
                </span>

                <div class="relative px-4 pt-10 pb-4 lg:px-5 lg:pb-5">
                    <p
                        class="text-paper font-serif italic text-sm lg:text-base leading-snug mb-2.5"
                        style="text-shadow: 0 1px 8px hsl(220 50% 6% / 0.6);"
                    >
                        “{quote}”
                    </p>
                    <div
                        class="font-mono text-[10px] lg:text-[11px] uppercase tracking-[0.06em] leading-tight"
                    >
                        <div class="text-paper font-semibold">{name}</div>
                        <div class="text-paper/70 mt-0.5">{byline}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</article>
