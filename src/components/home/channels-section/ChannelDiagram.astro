---
import { cn } from '@/lib/utils/cn';
import ChannelSourceCard from './ChannelSourceCard.astro';
import ChannelConnectorLines from './ChannelConnectorLines.astro';
import ChannelHub from './ChannelHub.astro';
import {
    GygLogo,
    ViatorLogo,
    KlookLogo,
} from '@/components/decorative/ota-logos';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

const wrapperClasses = cn(
    'channel-diagram',
    'relative overflow-hidden',
    'bg-gradient-to-br from-paper to-[hsl(var(--surface-alt)/0.6)]',
    'border border-line rounded-[18px]',
    'p-7',
    className,
);

const otaBadgeClasses = cn(
    'channel-ota',
    'w-16 h-16 rounded-full',
    'flex items-center justify-center',
    'bg-paper border border-line',
    'shadow-[0_6px_16px_-6px_hsl(var(--ink)/0.10)]',
    'transition-transform duration-200',
    'hover:-translate-y-0.5',
);

const otaLogoClasses = 'w-10 h-auto';

/**
 * Element positions in % of the orbit container. Intentionally slightly
 * asymmetric — strict 14/78 percentages felt mechanical, so each axis
 * carries a few-point offset for a more organic, hand-placed feel.
 * The connector line endpoints in ChannelConnectorLines.astro match
 * these values exactly.
 */
const POS = {
    backoffice: { left: '17%', top: '24%' },
    widget: { left: '19%', top: '77%' },
    gyg: { left: '76%', top: '18%' },
    viator: { left: '90%', top: '53%' },
    klook: { left: '78%', top: '83%' },
    hub: { left: '50%', top: '50%' },
} as const;
---

<div class={wrapperClasses} {...rest}>
    <!-- Decorative atmospheric blooms — kept per design call. -->
    <div
        class="absolute -top-20 -right-20 w-60 h-60 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, hsl(var(--travelity-teal) / 0.12) 0%, transparent 70%);"
        aria-hidden="true"
    >
    </div>
    <div
        class="absolute -bottom-24 -left-24 w-72 h-72 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, hsl(var(--travelity-teal-deep) / 0.10) 0%, transparent 70%);"
        aria-hidden="true"
    >
    </div>

    <!-- Orbit (>= sm): 5 peripheral elements + central hub, all absolute. -->
    <div
        class="hidden sm:block relative w-full aspect-[5/4] min-h-[440px] z-[2]"
    >
        <!-- Connector lines (behind elements via z-[1] in its own file) -->
        <ChannelConnectorLines />

        <!-- Back-office -->
        <div
            class="absolute z-[2]"
            style={`left: ${POS.backoffice.left}; top: ${POS.backoffice.top}; transform: translate(-50%, -50%);`}
        >
            <ChannelSourceCard
                kind="backoffice"
                title="Back-office"
                subtitle="Direct sales"
            >
                <ul class="flex flex-col gap-1.5 m-0 p-0 list-none">
                    <li
                        class="flex items-center gap-2 font-body text-[11px] font-medium text-ink before:content-[''] before:w-1 before:h-1 before:rounded-full before:bg-ink-muted before:flex-shrink-0"
                    >
                        Manual orders
                    </li>
                    <li
                        class="flex items-center gap-2 font-body text-[11px] font-medium text-ink before:content-[''] before:w-1 before:h-1 before:rounded-full before:bg-ink-muted before:flex-shrink-0"
                    >
                        Partner B2B
                    </li>
                    <li
                        class="flex items-center gap-2 font-body text-[11px] font-medium text-ink before:content-[''] before:w-1 before:h-1 before:rounded-full before:bg-ink-muted before:flex-shrink-0"
                    >
                        Walk-ins
                    </li>
                </ul>
            </ChannelSourceCard>
        </div>

        <!-- Widget -->
        <div
            class="absolute z-[2]"
            style={`left: ${POS.widget.left}; top: ${POS.widget.top}; transform: translate(-50%, -50%);`}
        >
            <ChannelSourceCard
                kind="widget"
                title="Widget"
                subtitle="On your site"
            >
                <p class="text-[11px] text-ink font-medium leading-[1.5] m-0">
                    Embeds <span class="text-travelity-teal font-semibold"
                        >directly on your website</span
                    >
                    — your branding, no commission.
                </p>
            </ChannelSourceCard>
        </div>

        <!-- GYG -->
        <div
            class="absolute z-[2]"
            style={`left: ${POS.gyg.left}; top: ${POS.gyg.top}; transform: translate(-50%, -50%);`}
            aria-label="GetYourGuide"
        >
            <div class={otaBadgeClasses}>
                <GygLogo class={otaLogoClasses} />
            </div>
        </div>

        <!-- Viator -->
        <div
            class="absolute z-[2]"
            style={`left: ${POS.viator.left}; top: ${POS.viator.top}; transform: translate(-50%, -50%);`}
            aria-label="Viator"
        >
            <div class={otaBadgeClasses}>
                <ViatorLogo class={otaLogoClasses} />
            </div>
        </div>

        <!-- Klook -->
        <div
            class="absolute z-[2]"
            style={`left: ${POS.klook.left}; top: ${POS.klook.top}; transform: translate(-50%, -50%);`}
            aria-label="Klook"
        >
            <div class={otaBadgeClasses}>
                <KlookLogo class={otaLogoClasses} />
            </div>
        </div>

        <!-- Central hub -->
        <div
            class="absolute"
            style={`left: ${POS.hub.left}; top: ${POS.hub.top}; transform: translate(-50%, -50%); z-index: 3;`}
        >
            <ChannelHub />
        </div>
    </div>

    <!-- Mobile fallback: vertical stack, no orbit / no connectors. -->
    <div
        class="sm:hidden relative z-[2] flex flex-col items-center gap-4 py-2"
    >
        <ChannelSourceCard
            kind="backoffice"
            title="Back-office"
            subtitle="Direct sales"
        >
            <ul class="flex flex-col gap-1.5 m-0 p-0 list-none">
                <li
                    class="flex items-center gap-2 font-body text-[11px] font-medium text-ink before:content-[''] before:w-1 before:h-1 before:rounded-full before:bg-ink-muted before:flex-shrink-0"
                >
                    Manual orders
                </li>
                <li
                    class="flex items-center gap-2 font-body text-[11px] font-medium text-ink before:content-[''] before:w-1 before:h-1 before:rounded-full before:bg-ink-muted before:flex-shrink-0"
                >
                    Partner B2B
                </li>
                <li
                    class="flex items-center gap-2 font-body text-[11px] font-medium text-ink before:content-[''] before:w-1 before:h-1 before:rounded-full before:bg-ink-muted before:flex-shrink-0"
                >
                    Walk-ins
                </li>
            </ul>
        </ChannelSourceCard>
        <ChannelSourceCard
            kind="widget"
            title="Widget"
            subtitle="On your site"
        >
            <p class="text-[11px] text-ink font-medium leading-[1.5] m-0">
                Embeds <span class="text-travelity-teal font-semibold"
                    >directly on your website</span
                >
                — your branding, no commission.
            </p>
        </ChannelSourceCard>
        <ChannelHub class="my-2" />
        <div class="flex items-center gap-3">
            <div class={otaBadgeClasses}>
                <GygLogo class={otaLogoClasses} />
            </div>
            <div class={otaBadgeClasses}>
                <ViatorLogo class={otaLogoClasses} />
            </div>
            <div class={otaBadgeClasses}>
                <KlookLogo class={otaLogoClasses} />
            </div>
        </div>
    </div>
</div>

<style>
    @media (prefers-reduced-motion: reduce) {
        .channel-ota {
            transition: none !important;
        }
        .channel-ota:hover {
            transform: none !important;
        }
    }
</style>
