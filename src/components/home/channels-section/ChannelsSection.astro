---
import { cn } from '@/lib/utils/cn';
import ChannelDiagram from './ChannelDiagram.astro';
import ChannelsValue from './ChannelsValue.astro';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'section'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

const sectionClasses = cn(
    'channels-section',
    'relative bg-paper',
    'pb-10 md:pb-14',
    className,
);
---

<section class={sectionClasses} {...rest}>
    <div class="container mx-auto px-6 relative z-[1]">
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
        >
            <ChannelDiagram />
            <ChannelsValue />
        </div>
    </div>
</section>
