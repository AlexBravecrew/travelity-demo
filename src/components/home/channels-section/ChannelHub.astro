---
import { cn } from '@/lib/utils/cn';
import { LogoSmall } from '@/components/brand';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

const classes = cn(
    'channel-hub',
    'relative z-[3]',
    'flex flex-col items-center justify-center gap-2',
    'w-[112px] py-4 px-3',
    'bg-paper rounded-2xl',
    'border border-[hsl(var(--travelity-blue)/0.18)]',
    className,
);
---

<div class={classes} {...rest}>
    <LogoSmall class="w-11 h-11" />
    <span
        class="font-mono text-[9.5px] uppercase tracking-[0.14em] text-travelity-blue font-semibold leading-none"
    >
        One platform
    </span>
</div>

<style>
    /* Gentle pulse breath. Softer than v1: smaller expansion (8px),
       slower duration (4s), low opacity (10%). */
    .channel-hub {
        box-shadow:
            0 0 0 5px hsl(var(--paper)),
            0 12px 28px -8px hsl(var(--travelity-blue) / 0.22);
        animation: channel-hub-breath 4s ease-in-out infinite;
    }

    @keyframes channel-hub-breath {
        0%,
        100% {
            box-shadow:
                0 0 0 5px hsl(var(--paper)),
                0 12px 28px -8px hsl(var(--travelity-blue) / 0.22),
                0 0 0 0 hsl(var(--travelity-blue) / 0.10);
        }
        50% {
            box-shadow:
                0 0 0 5px hsl(var(--paper)),
                0 12px 28px -8px hsl(var(--travelity-blue) / 0.22),
                0 0 0 8px hsl(var(--travelity-blue) / 0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .channel-hub {
            animation: none !important;
        }
    }
</style>
