---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

/**
 * Five connector tracks radiating outward from the central logo. Each
 * connector is two overlaid SVG <line>s:
 *
 *   1. A static guide — solid, thin, low-opacity backbone, with a soft
 *      glow via an SVG <filter>.
 *   2. An animated pulse — a single short dash sliding from the hub
 *      outward to each peripheral badge via stroke-dashoffset, with a
 *      prominent glow via a second filter.
 *
 * Glow uses SVG <filter> + feGaussianBlur (not CSS filter:drop-shadow),
 * because the latter's default filter region is too tight on thin SVG
 * strokes and the halo gets clipped. The filter blurs the source in its
 * own color, so each line glows in its assigned color automatically.
 *
 * Coordinates are in viewBox % (0–100), matching the orbit positions in
 * ChannelDiagram.astro. Each <line> is drawn FROM the center TO the
 * peripheral element so dashoffset animation (0 → -100) carries the
 * pulse outward.
 *
 * OTA brand hex literals (#FF5533, #028768) — partner brand colors, not
 * part of the Travelity palette. Used here only on the connector
 * strokes so each OTA's pulse trails in its own brand color. The
 * aggregate "OTAs" line uses the Travelity blue-deep token.
 */
const lines: {
    id: string;
    to: { x: number; y: number };
    color: string;
    delay: string;
}[] = [
    {
        id: 'backoffice',
        to: { x: 15, y: 22 },
        color: 'hsl(var(--travelity-blue))',
        delay: '0s',
    },
    {
        id: 'widget',
        to: { x: 17, y: 78 },
        color: 'hsl(var(--travelity-teal))',
        delay: '0.4s',
    },
    {
        id: 'gyg',
        to: { x: 85, y: 20 },
        color: '#FF5533',
        delay: '0.8s',
    },
    {
        id: 'viator',
        to: { x: 90, y: 53 },
        color: '#028768',
        delay: '1.2s',
    },
    {
        id: 'otas',
        to: { x: 85, y: 82 },
        color: 'hsl(var(--travelity-blue-deep))',
        delay: '1.6s',
    },
];

const center = { x: 50, y: 50 };
---

<div
    class={cn(
        'channel-connector-lines',
        'absolute inset-0 z-[1]',
        'pointer-events-none',
        'hidden sm:block',
        className,
    )}
    aria-hidden="true"
    {...rest}
>
    <svg
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
        class="w-full h-full block overflow-visible"
    >
        <defs>
            <!-- Subtle glow for the static guide line. Single blur pass
                 + source overlay. -->
            <filter
                id="channel-guide-glow"
                x="-50%"
                y="-50%"
                width="200%"
                height="200%"
            >
                <feGaussianBlur stdDeviation="0.7" result="blur"
                ></feGaussianBlur>
                <feMerge>
                    <feMergeNode in="blur"></feMergeNode>
                    <feMergeNode in="SourceGraphic"></feMergeNode>
                </feMerge>
            </filter>
            <!-- Prominent glow for the pulse. Double blur merge gives
                 the single dash a bright comet-like halo. -->
            <filter
                id="channel-pulse-glow"
                x="-50%"
                y="-50%"
                width="200%"
                height="200%"
            >
                <feGaussianBlur stdDeviation="1.4" result="blur"
                ></feGaussianBlur>
                <feMerge>
                    <feMergeNode in="blur"></feMergeNode>
                    <feMergeNode in="blur"></feMergeNode>
                    <feMergeNode in="SourceGraphic"></feMergeNode>
                </feMerge>
            </filter>
        </defs>

        {
            lines.map((line) => (
                <>
                    <line
                        class="channel-guide"
                        x1={center.x}
                        y1={center.y}
                        x2={line.to.x}
                        y2={line.to.y}
                        stroke={line.color}
                        stroke-width="0.4"
                        stroke-opacity="0.3"
                        filter="url(#channel-guide-glow)"
                    />
                    <line
                        class="channel-pulse"
                        x1={center.x}
                        y1={center.y}
                        x2={line.to.x}
                        y2={line.to.y}
                        stroke={line.color}
                        stroke-width="0.7"
                        stroke-linecap="round"
                        pathLength="100"
                        stroke-dasharray="10 190"
                        filter="url(#channel-pulse-glow)"
                        style={`animation-delay: ${line.delay};`}
                    />
                </>
            ))
        }
    </svg>
</div>

<style>
    /* Single-beam pulse outward from the hub.
       pathLength=100 normalizes every line. Dasharray "16 184" gives a
       period (200) twice the path length, so the dash fully exits the
       line at offset=-100 and the path is empty for the second half of
       the cycle — clean rest before the next beam emerges (no wrap-
       around at the boundary, which is what made it look broken when
       the period matched the path length exactly).
       Animation: offset 0 → -200 over 2s linear = 1s beam travel + 1s
       rest. Opacity envelope masks the dash's first/last frames where
       it briefly straddles the line endpoints. Lines staggered by 0.4s
       so all five fire in a continuous ripple. */
    .channel-pulse {
        animation: channel-pulse 2s linear infinite;
        opacity: 0;
    }

    @keyframes channel-pulse {
        0% {
            stroke-dashoffset: 0;
            opacity: 0;
        }
        8% {
            opacity: 0.9;
        }
        45% {
            opacity: 0.9;
        }
        50% {
            stroke-dashoffset: -100;
            opacity: 0;
        }
        100% {
            stroke-dashoffset: -200;
            opacity: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .channel-pulse {
            animation: none !important;
            opacity: 0;
        }
    }
</style>
