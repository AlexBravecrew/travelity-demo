---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

type SourceKind = 'backoffice' | 'widget' | 'otas';

export interface Props extends HTMLAttributes<'div'> {
    /** Which of the three source types this card renders. */
    kind: SourceKind;
    /** Heading shown next to the icon. */
    title: string;
    /** Subhead shown under the title. */
    subtitle: string;
    /** Forwarded to underlying element. */
    class?: string;
}

const { kind, title, subtitle, class: className, ...rest } = Astro.props;

// Token-mapped icon tint per source kind. Translation note: "OTAs" uses a deeper
// blue (218 50% 38%) — that's the brand-blue-deep token equivalent, the same
// shade we use for other "third-tier brand" accents.
const iconBgClasses: Record<SourceKind, string> = {
    backoffice: 'bg-[hsl(var(--travelity-blue)/0.10)] text-travelity-blue',
    widget: 'bg-[hsl(var(--travelity-teal)/0.14)] text-travelity-teal',
    otas: 'bg-[hsl(var(--travelity-blue-deep)/0.10)] text-travelity-blue-deep',
};

const baseCardClasses = cn(
    'channel-source',
    'flex flex-col p-[14px] min-h-[168px]',
    'bg-paper border border-line rounded-xl',
    'shadow-[0_6px_16px_-6px_hsl(var(--ink)/0.10)]',
    'transition-transform duration-200',
    'hover:-translate-y-0.5',
    className,
);
---

<div class={baseCardClasses} data-source-kind={kind} {...rest}>
    <div class="flex items-center gap-[10px] mb-3">
        <!--
          Inline SVG below — channel source icons are bespoke one-off shapes,
          not reused elsewhere, so they live here rather than in @/icons. If a
          future phase needs any of these shapes, promote to decorative/.
        -->
        <div
            class={cn(
                'w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0',
                iconBgClasses[kind],
            )}
        >
            {
                kind === 'backoffice' && (
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4"
                        aria-hidden="true"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M3 9h18M9 21V9" />
                    </svg>
                )
            }
            {
                kind === 'widget' && (
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4"
                        aria-hidden="true"
                    >
                        <polyline points="16 18 22 12 16 6" />
                        <polyline points="8 6 2 12 8 18" />
                    </svg>
                )
            }
            {
                kind === 'otas' && (
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4"
                        aria-hidden="true"
                    >
                        <circle cx="12" cy="12" r="9" />
                        <path d="M3 12h18M12 3a15 15 0 0 1 4 9 15 15 0 0 1-4 9 15 15 0 0 1-4-9 15 15 0 0 1 4-9z" />
                    </svg>
                )
            }
        </div>
        <div class="min-w-0">
            <strong
                class="block font-display text-[13px] font-semibold leading-[1.2] tracking-[-0.01em] text-ink"
            >
                {title}
            </strong>
            <small class="block text-[11px] text-ink-muted mt-px">
                {subtitle}
            </small>
        </div>
    </div>

    <div class="flex-1 pt-[10px] border-t border-dashed border-line">
        <slot />
    </div>
</div>

<style>
    @media (prefers-reduced-motion: reduce) {
        .channel-source {
            transition: none !important;
        }
        .channel-source:hover {
            transform: none !important;
        }
    }
</style>
