---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

type SourceKind = 'backoffice' | 'widget';

export interface Props extends HTMLAttributes<'div'> {
    /** Which of the two internal source types this card renders. */
    kind: SourceKind;
    /** Heading shown next to the icon. */
    title: string;
    /** Subhead shown under the title. */
    subtitle: string;
    class?: string;
}

const { kind, title, subtitle, class: className, ...rest } = Astro.props;

const iconBgClasses: Record<SourceKind, string> = {
    backoffice: 'bg-[hsl(var(--travelity-blue)/0.10)] text-travelity-blue',
    widget: 'bg-[hsl(var(--travelity-teal)/0.14)] text-travelity-teal',
};

const cardClasses = cn(
    'channel-source',
    'flex flex-col',
    'w-[190px] p-3',
    'bg-paper border border-line rounded-xl',
    'shadow-[0_6px_16px_-6px_hsl(var(--ink)/0.10)]',
    'transition-transform duration-200',
    'hover:-translate-y-0.5',
    className,
);
---

<div class={cardClasses} data-source-kind={kind} {...rest}>
    <div class="flex items-center gap-2.5 mb-2.5">
        <div
            class={cn(
                'w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0',
                iconBgClasses[kind],
            )}
        >
            {
                kind === 'backoffice' && (
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4"
                        aria-hidden="true"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M3 9h18M9 21V9" />
                    </svg>
                )
            }
            {
                kind === 'widget' && (
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4"
                        aria-hidden="true"
                    >
                        <polyline points="16 18 22 12 16 6" />
                        <polyline points="8 6 2 12 8 18" />
                    </svg>
                )
            }
        </div>
        <div class="min-w-0">
            <strong
                class="block font-display text-[13px] font-semibold leading-[1.2] tracking-[-0.01em] text-ink"
            >
                {title}
            </strong>
            <small class="block text-[10.5px] text-ink-muted mt-px">
                {subtitle}
            </small>
        </div>
    </div>

    <div class="pt-2.5 border-t border-dashed border-line">
        <slot />
    </div>
</div>

<style>
    @media (prefers-reduced-motion: reduce) {
        .channel-source {
            transition: none !important;
        }
        .channel-source:hover {
            transform: none !important;
        }
    }
</style>
