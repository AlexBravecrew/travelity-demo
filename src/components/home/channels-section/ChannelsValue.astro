---
import { cn } from '@/lib/utils/cn';
import { SectionHeader } from '@/components/ui/section-header';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

interface ChannelsBullet {
    title: string;
    description: string;
}

const bullets: ChannelsBullet[] = [
    {
        title: 'Channel Management',
        description:
            'Sync availability, schedules, and bookings across multiple sales channels in real time and manage everything from a single dashboard.',
    },
    {
        title: 'OTA Integrations',
        description:
            'Expand your reach by distributing your tours and activities across leading marketplaces like GetYourGuide and Viator.',
    },
    {
        title: 'Booking Widget',
        description:
            'Sell directly from your own website with an integrated booking widget connected to your live availability, with the ability to integrate your preferred payment gateways.',
    },
];

const classes = cn('channels-value max-w-[540px]', className);
---

<div class={classes} {...rest}>
    <SectionHeader
        eyebrow="Sync availability. Sell everywhere."
        eyebrowWithRule
        align="left"
        data-reveal
        data-reveal-direction="right"
    >
        <Fragment slot="headline">
            Manage All Your Sales Channels from <em>One Platform.</em>
        </Fragment>
        <p
            slot="dek"
            class="text-[18px] text-ink-muted leading-[1.55] max-w-[56ch]"
        >
            Travelity helps you connect your products with leading OTAs,
            automate availability updates, reduce manual work, prevent
            overbookings, and sell more through your own website with a built-in
            booking widget — all from one centralized system.
        </p>
    </SectionHeader>

    <ul
        class="channels-value-bullets mt-8 m-0 p-0 list-none flex flex-col gap-[14px]"
    >
        {
            bullets.map((bullet, idx) => (
                <li
                    class="grid grid-cols-[22px_1fr] gap-3 items-start text-[15px] leading-[1.5] text-ink"
                    data-reveal
                    data-reveal-direction="right"
                    data-reveal-delay={120 + idx * 80}
                >
                    <span
                        class="block w-1.5 h-1.5 rounded-full bg-travelity-teal mt-[7px] mx-auto"
                        style="box-shadow: 0 0 0 3px hsl(var(--travelity-teal) / 0.16);"
                        aria-hidden="true"
                    />
                    <div>
                        <strong class="font-display font-semibold text-ink">
                            {bullet.title}
                        </strong>
                        <span class="block text-ink-muted text-[14px] mt-0.5 leading-[1.5]">
                            {bullet.description}
                        </span>
                    </div>
                </li>
            ))
        }
    </ul>
</div>
