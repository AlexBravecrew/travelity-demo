---
import { cn } from '@/lib/utils/cn';
import type { HTMLAttributes } from 'astro/types';

export interface Props extends HTMLAttributes<'div'> {
    class?: string;
}

const { class: className, ...rest } = Astro.props;

/**
 * Default Calendly URL ported from v1 (with text/primary color params baked in).
 * Production override: PUBLIC_CALENDLY_URL env var.
 */
const DEFAULT_CALENDLY_URL =
    'https://calendly.com/travelity-sales/30min?text_color=3a4d7d&primary_color=55b5cf';

const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL || DEFAULT_CALENDLY_URL;

/**
 * Google Ads conversion target — `AW-XXX/LABEL` — built from env vars
 * with v1 production fallbacks. Inlined into the postMessage handler
 * via Astro's `define:vars` so the value lands in the static HTML at
 * build time.
 */
const adsConversionTarget = `${
    import.meta.env.PUBLIC_GOOGLE_ADS_ID || 'AW-17231403747'
}/${import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_LABEL || 'o6zNCP7t0fYaEOO1yZhA'}`;
---

<div class={cn('calendly-widget-container', className)} {...rest}>
    <!--
        Simple inline embed pattern, mirroring v1. The fixed 700px height is
        deliberate: it makes the iframe scroll *internally* when Calendly's
        content overflows. Calendly's dropdowns / popovers position relative
        to their own iframe viewport, so an internal-scroll iframe keeps them
        visible. With `resize: true` (auto-grow), the iframe becomes taller
        than the user's viewport and Calendly's dropdowns can land below the
        fold. Don't switch back to the JS API without re-creating that bug.
    -->
    <div
        class="calendly-inline-widget"
        data-url={calendlyUrl}
        style="min-width:320px;height:700px;"
    >
    </div>
</div>

<link
    rel="stylesheet"
    href="https://assets.calendly.com/assets/external/widget.css"
/>
<script
    is:inline
    src="https://assets.calendly.com/assets/external/widget.js"
    async></script>

<script is:inline define:vars={{ adsConversionTarget }}>
    /**
     * Calendly booking → Google Ads conversion + /thank-you redirect.
     *
     * Improvements over v1:
     *   - postMessage origin check (v1 didn't have it).
     *   - Conversion fires with `value`/`currency` so Google Ads can
     *     compute ROAS (v1 sent neither).
     *   - Navigation is gated on `event_callback` (v1's was an empty
     *     noop, causing a race where the ping might not flush).
     *   - 1s timeout fallback covers ad-blocker / gtag-unavailable
     *     scenarios so the user is never stuck on the booking page.
     *   - Re-entry guard prevents double-navigation if both
     *     event_callback and the timeout fire.
     *
     * Consent gating: `window.gtag` is the Partytown-forwarded queue
     * pusher set up in Analytics.astro. If Consent Mode v2 has
     * `ad_storage: denied`, Google records a cookieless modeled
     * conversion — call still fires, event_callback still runs.
     */
    window.addEventListener('message', (e) => {
        if (e.origin !== 'https://calendly.com') return;
        const data = e.data;
        if (!data || data.event !== 'calendly.event_scheduled') return;

        let navigated = false;
        const navigate = () => {
            if (navigated) return;
            navigated = true;
            window.location.href = '/thank-you';
        };

        if (typeof window.gtag === 'function') {
            window.gtag('event', 'conversion', {
                send_to: adsConversionTarget,
                value: 0,
                currency: 'EUR',
                event_callback: navigate,
            });
            // Fallback: if gtag never reaches event_callback (ad
            // blocker, network failure, Partytown init pending),
            // navigate after 1s so the user isn't stuck.
            setTimeout(navigate, 1000);
        } else {
            // Analytics isn't loaded (dev build, or first-paint race) —
            // navigate immediately, no conversion to fire.
            navigate();
        }
    });
</script>
