---
import { Analytics } from '@/components/chrome/analytics';

interface Props {
    title: string;
    description?: string;
    canonical?: string;
    ogImage?: string;
}

const {
    title,
    description = 'The booking platform travel businesses run on.',
    canonical,
    ogImage = '/og-default.png',
} = Astro.props;

const siteUrl = 'https://travelity.app';
const fullCanonical =
    canonical ?? `${siteUrl}${Astro.url.pathname.replace(/\/$/, '')}`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={fullCanonical} />

        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={fullCanonical} />
        <meta property="og:type" content="website" />
        <meta property="og:image" content={`${siteUrl}${ogImage}`} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Fonts: Fontshare (Author, General Sans, Satoshi) + Google (JetBrains Mono) -->
        <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://api.fontshare.com/v2/css?f[]=author@400,500,600,700&f[]=general-sans@400,500,600,700&f[]=satoshi@400,500,700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <!-- Theme FOUC prevention — runs before body renders, applies .dark
             class to <html> if user has previously chosen dark. Theme toggle
             ships in Phase 2; this script is harmless until then. -->
        <script is:inline>
            (function () {
                try {
                    const stored = localStorage.getItem('travelity-theme');
                    if (stored === 'dark') {
                        document.documentElement.classList.add('dark');
                    }
                } catch (_) {
                    /* localStorage unavailable — fall back to light */
                }
            })();
        </script>

        <!-- Analytics — GA4 + Google Ads via Partytown Web Worker, gated
             by Consent Mode v2. Renders nothing in `astro dev`. See
             component for the 4-step load sequence. -->
        <Analytics />
    </head>
    <body>
        <a href="#main" class="skip-link">Skip to content</a>
        <main id="main">
            <slot />
        </main>
    </body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>
