---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;
---

<MarketingLayout
    title="Our Story · Travelity"
    description="Travelity is on a mission to simplify travel agency operations with affordable, smart software — built by people who've lived inbound tourism for 20+ years."
>
    <Nav />

    <div class="bg-paper">
        <!-- Hero strip -->
        <section
            class="border-b border-line py-10 md:py-14"
            style="background: radial-gradient(ellipse 60% 50% at 50% 0%, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%), hsl(var(--paper));"
        >
            <div class="container mx-auto px-6 max-w-[820px] text-center">
                <Eyebrow withRule centered data-reveal>Our story</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.035em] mt-5 mb-5"
                    style="font-size: clamp(36px, 5vw, 56px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    On a mission to
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal"
                            >simplify travel agency operations.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                    data-reveal
                    data-reveal-delay="160"
                >
                    From tour planning to team coordination — Travelity
                    simplifies it all. Less chaos, more bookings, happier teams.
                </p>
            </div>
        </section>

        <!-- 01 — Origin -->
        <section class="bg-paper py-10 md:py-14">
            <div class="container mx-auto px-6 max-w-[680px]">
                <Eyebrow withRule data-reveal>Origin</Eyebrow>

                <h2
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.025em] mt-5 mb-7"
                    style="font-size: clamp(36px, 4.6vw, 56px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    How Travelity
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal"
                            >Was Born.</span
                        >
                    </em>
                </h2>

                <div
                    class="text-lg text-ink-muted leading-[1.7] space-y-5"
                    data-reveal
                    data-reveal-delay="160"
                >
                    <p>
                        Travelity was born from the real challenges travel
                        companies face every day.
                    </p>
                    <p>
                        Managing bookings across multiple channels, updating
                        availability manually, coordinating daily services,
                        handling customer requests, and keeping everything
                        organized often required using disconnected tools and
                        time-consuming processes. As operations grew, so did the
                        complexity.
                    </p>
                    <p>
                        After experiencing these challenges firsthand, we
                        decided to build a platform designed specifically for
                        the way modern travel businesses actually work —
                        connected, practical, easy to use, and focused on
                        solving real operational problems.
                    </p>
                </div>
            </div>
        </section>

        <!-- 02 — Team -->
        <section class="bg-surface-alt py-10 md:py-14">
            <div class="container mx-auto px-6 max-w-[680px]">
                <Eyebrow withRule data-reveal>Team</Eyebrow>

                <h2
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.025em] mt-5 mb-7"
                    style="font-size: clamp(36px, 4.6vw, 56px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    Who
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal"
                            >We Are.</span
                        >
                    </em>
                </h2>

                <div
                    class="text-lg text-ink-muted leading-[1.7] space-y-5"
                    data-reveal
                    data-reveal-delay="160"
                >
                    <p>
                        We are a team of travel industry and tech enthusiasts
                        with over 20 years of experience in inbound tourism and
                        a deep understanding of how the industry works. What
                        sets us apart is our unique combination of strengths in
                        both tourism and IT — a blend that allows us to develop
                        smart, practical, and user-friendly solutions tailored
                        specifically for tour operators and travel
                        professionals.
                    </p>
                    <p>
                        We don't just understand the business — we've lived it.
                        We stood close to tourism and truly experienced its
                        day-to-day demands, operational nuances, and the
                        expectations of both travelers and agencies. That's why
                        we built Travelity as a B2B software solution — born
                        from real-world challenges and driven by a passion to
                        solve them from the inside out.
                    </p>
                </div>
            </div>
        </section>

        <!-- 03 — Mission -->
        <section class="bg-paper py-10 md:py-14 relative overflow-hidden">
            <!-- Atmospheric teal bloom in upper-right corner -->
            <span
                class="absolute pointer-events-none -top-24 -right-24 w-[520px] h-[520px]"
                style="background: radial-gradient(circle, hsl(var(--travelity-teal) / 0.10) 0%, transparent 60%);"
                aria-hidden="true"></span>

            <div class="container mx-auto px-6 max-w-[680px] relative z-[1]">
                <Eyebrow withRule data-reveal>Mission</Eyebrow>

                <h2
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.025em] mt-5 mb-7"
                    style="font-size: clamp(36px, 4.6vw, 56px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    What
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal"
                            >We Do For You.</span
                        >
                    </em>
                </h2>

                <div
                    class="text-lg text-ink-muted leading-[1.7] space-y-5"
                    data-reveal
                    data-reveal-delay="160"
                >
                    <p>
                        Travelity is built to help travel businesses operate
                        with more clarity and less manual work.
                    </p>
                    <p>
                        From managing bookings and coordinating daily services
                        to distributing products across sales channels and
                        improving team collaboration, the platform is designed
                        to simplify complex workflows and support business
                        growth as your operations scale.
                    </p>
                    <p>
                        Our goal is simple: help travel companies spend less
                        time managing operational chaos and more time growing
                        their business, improving customer experience, and
                        creating memorable travel experiences.
                    </p>
                </div>
            </div>
        </section>

        <ClosingCTASection />
    </div>

    <Footer />
</MarketingLayout>
