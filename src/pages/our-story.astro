---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;
---

<MarketingLayout
    title="Our Story · Travelity"
    description="Travelity is on a mission to simplify travel agency operations with affordable, smart software — built by people who've lived inbound tourism for 20+ years."
>
    <Nav />

    <main class="bg-paper">
        <!-- Hero strip -->
        <section
            class="border-b border-line py-10 md:py-14"
            style="background: radial-gradient(ellipse 60% 50% at 50% 0%, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%), hsl(var(--paper));"
        >
            <div class="container mx-auto px-6 max-w-[820px] text-center">
                <Eyebrow withRule centered data-reveal>Our story</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.035em] mt-5 mb-5"
                    style="font-size: clamp(36px, 5vw, 56px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    On a mission to
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal"
                            >simplify travel agency operations.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                    data-reveal
                    data-reveal-delay="160"
                >
                    From tour planning to team coordination — Travelity
                    simplifies it all. Less chaos, more bookings, happier teams.
                </p>
            </div>
        </section>

        <!-- Body: long-form prose -->
        <article
            class="legal-prose container mx-auto px-6 max-w-[720px] py-10 md:py-14"
            data-reveal
        >
            <h2>How Travelity was born</h2>
            <p>
                Travelity is a B2B software that was born out of the everyday
                challenges and struggles of managing tours and bookings with
                outdated tools like spreadsheets. The founders experienced
                these frustrations firsthand — juggling multiple systems,
                facing functionality gaps, and getting little to no support
                when it mattered most. Those tools often led to chaos, lost
                time, and unhappy clients.
            </p>
            <p>
                Driven by the need for a smarter, more efficient solution, we
                set out to build a platform that could bring structure,
                clarity, and control to travel businesses.
            </p>

            <h2>Who we are</h2>
            <p>
                We're a team of travel industry and tech enthusiasts with over
                20 years of experience in inbound tourism and a deep
                understanding of how the industry works. What sets us apart is
                our unique combination of strengths in both tourism and IT — a
                blend that lets us develop smart, practical, and user-friendly
                solutions tailored specifically for tour operators and travel
                professionals.
            </p>
            <p>
                We don't just understand the business — we've lived it. We
                stood close to tourism and truly experienced its day-to-day
                demands, operational nuances, and the expectations of both
                travelers and agencies. That's why we built Travelity as a B2B
                software solution — born from real-world challenges and driven
                by a passion to solve them from the inside out.
            </p>

            <h2>What we do for you</h2>
            <p>
                At Travelity, we simplify the way you run your tour business.
                We give you tools that are easy to use but powerful enough to
                scale with you. With features like automated operations, team
                collaboration, built-in CRM essentials, and smart reporting,
                you can offer a smooth and professional experience to your
                customers.
            </p>
            <p>
                In short, we built Travelity to take care of your travel
                agency operations so you can focus on creating memorable
                travel experiences.
            </p>

            <h2>Get in touch</h2>
            <p>
                If you run a travel business and you've read this far, we'd
                like to meet you. <a href="/book-demo">Book a demo</a> or <a
                    href="/contact">drop us a line</a
                > — we read everything, and we reply.
            </p>
        </article>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
