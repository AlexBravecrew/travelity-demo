---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { SectionHeader } from '@/components/ui/section-header';
import { FaqAccordion, FaqItem } from '@/components/shared/faq-accordion';
import { ClosingCTASection } from '@/components/home/closing-cta-section';
import { Paths } from '@/lib/utils/paths';

export const prerender = true;
---

<MarketingLayout
    title="FAQ · Travelity"
    description="Common questions about Travelity — getting started, pricing, bookings, channels, security, and more."
>
    <Nav />

    <main class="bg-paper">
        <!-- Hero strip -->
        <section
            class="border-b border-line py-10 md:py-14 text-center"
            style="background: radial-gradient(ellipse 60% 50% at 50% 0%, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%), hsl(var(--paper));"
        >
            <div class="container mx-auto px-6 max-w-[820px]">
                <Eyebrow withRule centered data-reveal>Frequently asked</Eyebrow
                >

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.035em] mt-5 mb-5"
                    style="font-size: clamp(36px, 4.6vw, 52px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    Questions, answered.
                </h1>

                <p
                    class="text-[18px] text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                    data-reveal
                    data-reveal-delay="160"
                >
                    If you don't see your question here, <a
                        href={Paths.CONTACT}
                        class="text-travelity-teal underline underline-offset-2 hover:no-underline"
                        >drop us a line</a
                    > — we reply within a business day.
                </p>
            </div>
        </section>

        <!-- Getting started -->
        <section class="py-10 md:py-14">
            <div class="container mx-auto px-6">
                <SectionHeader
                    eyebrow="Getting started"
                    eyebrowWithRule
                    align="center"
                    data-reveal
                >
                    <Fragment slot="headline">First questions.</Fragment>
                </SectionHeader>

                <FaqAccordion class="mt-2" data-reveal data-reveal-delay="120">
                    <FaqItem question="How long does setup take?">
                        For most companies, getting from zero to taking real
                        bookings is 2–5 days. The exact timeframe depends on the
                        number of products, sales channels, and integrations
                        involved.
                    </FaqItem>

                    <FaqItem
                        question="Can I get support during the setup process?"
                    >
                        Yes. Our team assists with onboarding, account setup,
                        and platform configuration to help you start using
                        Travelity smoothly and efficiently.
                    </FaqItem>

                    <FaqItem
                        question="I already use another system. Can I transfer my data?"
                    >
                        Yes. Travelity supports migration of bookings, customer
                        data, products, and other operational information from
                        existing systems or spreadsheets.
                    </FaqItem>

                    <FaqItem
                        question="Do I need technical knowledge to use Travelity?"
                    >
                        No. Travelity is designed to be simple and user-friendly
                        for travel businesses of all sizes.
                    </FaqItem>

                    <FaqItem question="Do I get support after onboarding?">
                        Yes. Travelity provides ongoing support, onboarding
                        guidance, training materials, and assistance whenever
                        your team needs help using the platform.
                    </FaqItem>
                </FaqAccordion>
            </div>
        </section>

        <!-- Pricing & plans -->
        <section class="bg-surface-alt py-10 md:py-14">
            <div class="container mx-auto px-6">
                <SectionHeader
                    eyebrow="Pricing & plans"
                    eyebrowWithRule
                    align="center"
                    data-reveal
                >
                    <Fragment slot="headline">Money questions.</Fragment>
                </SectionHeader>

                <FaqAccordion class="mt-2" data-reveal data-reveal-delay="120">
                    <FaqItem question="Is there a free plan?">
                        Yes. Travelity offers a free plan for solo guides,
                        drivers, and travel professionals with a smaller volume
                        of operations.
                    </FaqItem>

                    <FaqItem question="Can I change my plan later?">
                        Yes. You can upgrade, downgrade, or change your plan
                        anytime.
                    </FaqItem>

                    <FaqItem question="Is Travelity a month-to-month contract?">
                        Yes. Travelity offers flexible subscriptions with no
                        long-term commitment required. You can cancel your plan
                        anytime.
                    </FaqItem>
                </FaqAccordion>
            </div>
        </section>

        <!-- Bookings & channels -->
        <section class="py-10 md:py-14">
            <div class="container mx-auto px-6">
                <SectionHeader
                    eyebrow="Bookings & channels"
                    eyebrowWithRule
                    align="center"
                    data-reveal
                >
                    <Fragment slot="headline">How it works.</Fragment>
                </SectionHeader>

                <FaqAccordion class="mt-2" data-reveal data-reveal-delay="120">
                    <FaqItem
                        question="Which OTAs does Travelity integrate with?"
                    >
                        Travelity currently integrates with GetYourGuide and
                        Viator, with integrations for Klook, Ctrip, TUI
                        Musement, Expedia, Airbnb Experiences, Tiqets, Google
                        Things to Do, and Headout in progress.
                    </FaqItem>

                    <FaqItem question="What does the Channel Manager do?">
                        It synchronizes availability, pricing, and bookings
                        across connected sales channels automatically.
                    </FaqItem>

                    <FaqItem
                        question="Can I accept direct bookings from my website?"
                    >
                        Yes. The Booking Widget allows customers to book
                        directly through your website.
                    </FaqItem>

                    <FaqItem question="Can I connect payment gateways?">
                        Yes. Travelity supports integration with widely used
                        online payment gateways.
                    </FaqItem>
                </FaqAccordion>
            </div>
        </section>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
