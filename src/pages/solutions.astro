---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { OutcomeCard } from '@/components/solutions';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

import increaseSalesImg from '@/assets/solutions/increase-sales.jpg';
import preventOverbookingsImg from '@/assets/solutions/prevent-overbookings.jpg';
import manageAllBookingsImg from '@/assets/solutions/manage-all-bookings.jpg';

export const prerender = true;

/**
 * Solutions page — 3 outcome cards in a 3-up grid (2-up on tablet, 1 on
 * mobile). Each card: 5:3 image panel on top, eyebrow + italic-em title +
 * 3-4 sentence body below. The cards carry the canonical Increase / Prevent
 * / Manage outcomes, anchored `#increase-sales` / `#prevent-overbookings` /
 * `#manage-all-bookings`.
 */
---

<MarketingLayout
    title="Solutions · Travelity"
    description="How Travelity helps travel operators sell more, prevent overbookings, and manage every booking in one place."
>
    <Nav />

    <div class="bg-paper">
        <!-- Compact top intro -->
        <section class="py-10 md:py-14 text-center">
            <div class="container mx-auto px-6">
                <Eyebrow withRule centered data-reveal
                    >How Travelity Helps You</Eyebrow
                >

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.03em] max-w-[24ch] mx-auto mt-6 mb-5"
                    style="font-size: clamp(34px, 4.4vw, 52px);"
                    data-reveal
                    data-reveal-delay="80"
                >
                    Designed Around the
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            Real Needs of Travel Businesses.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg md:text-xl text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                    data-reveal
                    data-reveal-delay="160"
                >
                    Created for the real challenges of modern travel businesses,
                    Travelity reduces operational chaos and supports your
                    business growth.
                </p>
            </div>
        </section>

        <!-- 3-card outcome grid: 3 cols (lg) / 2 cols (md) / 1 col (mobile) -->
        <section class="py-12 md:py-16">
            <div class="container mx-auto px-6">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
                >
                    <OutcomeCard
                        id="increase-sales"
                        eyebrow="Growth"
                        image={increaseSalesImg}
                        imageAlt="Multiple booking channels feeding a single inventory"
                        data-reveal
                    >
                        <Fragment slot="title">
                            <em>Increase</em> Your Sales
                        </Fragment>
                        <Fragment slot="body">
                            Expand your business across multiple sales channels
                            by connecting your products to leading OTAs and
                            accepting direct bookings through your own website.
                            With interactive trip proposals, customizable
                            booking tools, and centralized sales management, you
                            can create a smoother customer journey, improve
                            conversion rates, and generate more bookings.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        id="prevent-overbookings"
                        eyebrow="Control"
                        image={preventOverbookingsImg}
                        imageAlt="A seat locked across three booking channels at once"
                        data-reveal
                        data-reveal-delay="60"
                    >
                        <Fragment slot="title">
                            <em>Prevent</em> Overbookings and Revenue Loss
                        </Fragment>
                        <Fragment slot="body">
                            Maintain accurate availability across all connected
                            channels with real-time synchronization and
                            automated inventory management. As bookings,
                            cancellations, or updates occur, availability is
                            updated automatically, helping reduce manual
                            mistakes, avoid double bookings, prevent missed
                            sales opportunities, and maintain better control
                            over your inventory distribution.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        id="manage-all-bookings"
                        eyebrow="Organization"
                        image={manageAllBookingsImg}
                        imageAlt="Unified booking queue with cards from multiple sources"
                        data-reveal
                        data-reveal-delay="120"
                    >
                        <Fragment slot="title">
                            <em>Manage</em> All Bookings in One Place
                        </Fragment>
                        <Fragment slot="body">
                            Bring together reservations from OTAs, direct
                            bookings, partners, resellers, and offline sales
                            into one centralized system. Manage customer
                            details, payments, schedules, operational notes, and
                            booking statuses from a single workspace, helping
                            your team stay organized, improve coordination, and
                            eliminate the need for spreadsheets or multiple
                            disconnected tools.
                        </Fragment>
                    </OutcomeCard>
                </div>
            </div>
        </section>

        <ClosingCTASection />
    </div>

    <Footer />
</MarketingLayout>
