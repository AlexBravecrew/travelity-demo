---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import {
    OutcomeCollage,
    BookingToast,
    LockChip,
    QueueStack,
} from '@/components/solutions';
import type { CollageImage } from '@/components/solutions';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;

/**
 * Solutions page — scrapbook-style outcome sections (giant title above a
 * 3-photo collage above body text). Deliberately NOT a two-column
 * text/image grid — that layout is reserved for /features.
 *
 * TODO: replace the placeholder images with real travel photographs.
 *       Drop assets under `/public/solutions/<slug>/<n>.jpg` and update
 *       each `images:` entry below. The component's CSS duotone filter
 *       tints whatever you drop in on-palette automatically.
 */

interface Outcome {
    slug: string;
    body: string;
    images: CollageImage[];
}

const outcomes: Outcome[] = [
    {
        slug: 'increase-sales',
        body: 'Reach buyers wherever they search. Direct site, OTA partners, embedded widget on partner sites — same inventory, one setup, every channel, no duplicate work, and no double-bookings.',
        images: [
            { src: '/solutions/placeholder.svg', alt: 'Direct site bookings' },
            { src: '/solutions/placeholder.svg', alt: 'OTA partner channels' },
            { src: '/solutions/placeholder.svg', alt: 'Embedded booking widget' },
        ],
    },
    {
        slug: 'prevent-overbookings',
        body: "Inventory locks the instant a booking starts — across every channel, simultaneously. No more reconciling spreadsheets at midnight. No more refunding angry customers on a Saturday morning.",
        images: [
            { src: '/solutions/placeholder.svg', alt: 'Real-time availability' },
            { src: '/solutions/placeholder.svg', alt: 'Inventory lock in action' },
            { src: '/solutions/placeholder.svg', alt: 'Channel sync audit log' },
        ],
    },
    {
        slug: 'manage-all-bookings',
        body: "Whether it came through your widget, GetYourGuide, an inbound email, or a sales rep — it lands in the same queue. Edit, refund, reassign, generate documents. No spreadsheet juggling.",
        images: [
            { src: '/solutions/placeholder.svg', alt: 'Unified booking inbox' },
            { src: '/solutions/placeholder.svg', alt: 'Customer record builder' },
            { src: '/solutions/placeholder.svg', alt: 'On-demand documents' },
        ],
    },
];
---

<MarketingLayout
    title="Solutions · Travelity"
    description="How Travelity helps travel operators sell more, prevent overbookings, and manage every booking in one place."
>
    <Nav />

    <main class="bg-paper">
        <!-- Compact top intro -->
        <section class="relative py-16 md:py-24">
            <div class="container mx-auto px-6 text-center">
                <Eyebrow withRule centered>Solutions</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.03em] max-w-[24ch] mx-auto mt-6 mb-5"
                    style="font-size: clamp(34px, 4.4vw, 52px);"
                >
                    What Travelity actually
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            does for your business.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg md:text-xl text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                >
                    Three outcomes you can measure: more bookings, no
                    double-sells, and one place to run the whole operation.
                </p>
            </div>
        </section>

        <!-- Outcome 1 — Increase Sales -->
        <OutcomeCollage
            id={outcomes[0]!.slug}
            images={outcomes[0]!.images}
        >
            <Fragment slot="title">
                <em>Increase</em> Sales.
            </Fragment>
            <Fragment slot="body">{outcomes[0]!.body}</Fragment>
            <Fragment slot="accent">
                <BookingToast class="top-4 right-4 md:top-5 md:right-5" />
            </Fragment>
        </OutcomeCollage>

        <!-- Outcome 2 — Prevent Overbookings -->
        <OutcomeCollage
            id={outcomes[1]!.slug}
            images={outcomes[1]!.images}
        >
            <Fragment slot="title">
                <em>Prevent</em> Overbookings <br class="hidden md:inline" />
                and Revenue Loss.
            </Fragment>
            <Fragment slot="body">{outcomes[1]!.body}</Fragment>
            <Fragment slot="accent">
                <LockChip class="bottom-4 left-4 md:bottom-5 md:left-5" />
            </Fragment>
        </OutcomeCollage>

        <!-- Outcome 3 — Manage All Bookings -->
        <OutcomeCollage
            id={outcomes[2]!.slug}
            images={outcomes[2]!.images}
        >
            <Fragment slot="title">
                <em>Manage</em> All Bookings <br class="hidden md:inline" />
                in One Place.
            </Fragment>
            <Fragment slot="body">{outcomes[2]!.body}</Fragment>
            <Fragment slot="accent">
                <QueueStack class="top-4 right-4 md:top-5 md:right-5" />
            </Fragment>
        </OutcomeCollage>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
