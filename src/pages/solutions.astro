---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { OutcomeBlock } from '@/components/solutions';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;

/**
 * Solutions page — three full-width editorial blocks, each with its own
 * centered title + 3-4 sentence body + large image below. Sections
 * alternate paper / surface-alt backgrounds so each outcome reads as a
 * distinct "act". Eyebrow tone rotates teal → sunset → blue for a
 * single warm accent without bg artifacts.
 *
 * TODO: replace `/solutions/placeholder.svg` with real travel
 *       photographs at `/public/solutions/<slug>.jpg`. The duotone
 *       filter tints whatever you drop in on-palette automatically.
 */
---

<MarketingLayout
    title="Solutions · Travelity"
    description="How Travelity helps travel operators sell more, prevent overbookings, and manage every booking in one place."
>
    <Nav />

    <main class="bg-paper">
        <!-- Compact top intro -->
        <section class="py-12 md:py-16 text-center">
            <div class="container mx-auto px-6">
                <Eyebrow withRule centered>Solutions</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.03em] max-w-[24ch] mx-auto mt-6 mb-5"
                    style="font-size: clamp(34px, 4.4vw, 52px);"
                >
                    What Travelity actually
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            does for your business.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg md:text-xl text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                >
                    Three outcomes you can measure: more bookings, no
                    double-sells, and one place to run the whole operation.
                </p>
            </div>
        </section>

        <!-- Outcome 1 — Increase Sales -->
        <OutcomeBlock
            id="increase-sales"
            eyebrow="Outcome 01"
            imageSrc="/solutions/placeholder.svg"
            imageAlt="Multiple booking channels feeding a single inventory"
            surface="alt"
            tone="teal"
        >
            <Fragment slot="title">
                <em>Increase</em> sales.
            </Fragment>
            <Fragment slot="body">
                Reach buyers wherever they search. Your direct site, OTA
                partners like GetYourGuide and Viator, and embedded widgets on
                partner sites — same inventory, one setup. Every channel stays
                in sync. Bookings flow into a single queue with no duplicate
                work and no double-bookings.
            </Fragment>
        </OutcomeBlock>

        <!-- Outcome 2 — Prevent Overbookings -->
        <OutcomeBlock
            id="prevent-overbookings"
            eyebrow="Outcome 02"
            imageSrc="/solutions/placeholder.svg"
            imageAlt="A seat locked across three booking channels at once"
            surface="paper"
            tone="sunset"
        >
            <Fragment slot="title">
                <em>Prevent</em> overbookings and revenue loss.
            </Fragment>
            <Fragment slot="body">
                Inventory locks the instant a booking starts — across every
                channel, simultaneously. No more reconciling spreadsheets at
                midnight. No more refunding angry customers on a Saturday
                morning. The seat is yours the second a guest clicks book,
                and the platform enforces it for you.
            </Fragment>
        </OutcomeBlock>

        <!-- Outcome 3 — Manage All Bookings -->
        <OutcomeBlock
            id="manage-all-bookings"
            eyebrow="Outcome 03"
            imageSrc="/solutions/placeholder.svg"
            imageAlt="Unified booking queue with cards from multiple sources"
            surface="alt"
            tone="blue"
        >
            <Fragment slot="title">
                <em>Manage</em> every booking in one place.
            </Fragment>
            <Fragment slot="body">
                Whether it came through your widget, GetYourGuide, an inbound
                email, or a sales rep — it lands in the same queue. Edit,
                refund, reassign, and generate tickets, vouchers, or invoices
                on demand. Customer records build themselves from every
                booking. No more spreadsheet juggling.
            </Fragment>
        </OutcomeBlock>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
