---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { OutcomeCard } from '@/components/solutions';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;

/**
 * Solutions page — 6 outcome cards in a 3-up grid (wraps to 2 / 1
 * columns on narrower viewports). Each card: screenshot panel on top,
 * eyebrow + italic-em title + 3-4 sentence body below. Cards 4-6
 * temporarily mirror cards 1-3's copy while real content for them
 * lands.
 *
 * TODO: replace cards 4-6 placeholder copy with real outcome content.
 * TODO: replace `/solutions/placeholder.svg` with per-card real
 *       product screenshots at `/public/solutions/<slug>.jpg`.
 */
---

<MarketingLayout
    title="Solutions · Travelity"
    description="How Travelity helps travel operators sell more, prevent overbookings, and manage every booking in one place."
>
    <Nav />

    <main class="bg-paper">
        <!-- Compact top intro -->
        <section class="py-10 md:py-14 text-center">
            <div class="container mx-auto px-6">
                <Eyebrow withRule centered>Solutions</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.03em] max-w-[24ch] mx-auto mt-6 mb-5"
                    style="font-size: clamp(34px, 4.4vw, 52px);"
                >
                    What Travelity actually
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            does for your business.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg md:text-xl text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                >
                    Six outcomes you can measure: more bookings, no
                    double-sells, and one place to run the whole operation.
                </p>
            </div>
        </section>

        <!-- 6-card outcome grid: 3 cols (lg) / 2 cols (md) / 1 col (mobile) -->
        <section class="py-12 md:py-16">
            <div class="container mx-auto px-6">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
                >
                    <OutcomeCard
                        id="increase-sales"
                        eyebrow="Outcome 01"
                        imageSrc="/solutions/placeholder.svg"
                        imageAlt="Multiple booking channels feeding a single inventory"
                    >
                        <Fragment slot="title">
                            <em>Increase</em> Sell more, on more channels.
                        </Fragment>
                        <Fragment slot="body">
                            Reach buyers wherever they search. Your direct
                            site, OTA partners like GetYourGuide and Viator,
                            and embedded widgets on partner sites — same
                            inventory, one setup. Every channel stays in
                            sync. Bookings flow into a single queue with no
                            duplicate work and no double-bookings.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        id="prevent-overbookings"
                        eyebrow="Outcome 02"
                        imageSrc="/solutions/placeholder.svg"
                        imageAlt="A seat locked across three booking channels at once"
                    >
                        <Fragment slot="title">
                            <em>Prevent</em> overbookings and revenue loss.
                        </Fragment>
                        <Fragment slot="body">
                            Inventory locks the instant a booking starts —
                            across every channel, simultaneously. No more
                            reconciling spreadsheets at midnight. No more
                            refunding angry customers on a Saturday morning.
                            The seat is yours the second a guest clicks
                            book, and the platform enforces it for you.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        id="manage-all-bookings"
                        eyebrow="Outcome 03"
                        imageSrc="/solutions/placeholder.svg"
                        imageAlt="Unified booking queue with cards from multiple sources"
                    >
                        <Fragment slot="title">
                            <em>Manage</em> every booking in one place.
                        </Fragment>
                        <Fragment slot="body">
                            Whether it came through your widget,
                            GetYourGuide, an inbound email, or a sales rep —
                            it lands in the same queue. Edit, refund,
                            reassign, and generate tickets, vouchers, or
                            invoices on demand. Customer records build
                            themselves from every booking. No more
                            spreadsheet juggling.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        eyebrow="Outcome 04"
                        imageSrc="/solutions/placeholder.svg"
                        imageAlt="Multiple booking channels feeding a single inventory"
                    >
                        <Fragment slot="title">
                            <em>Increase</em> Sell more, on more channels.
                        </Fragment>
                        <Fragment slot="body">
                            Reach buyers wherever they search. Your direct
                            site, OTA partners like GetYourGuide and Viator,
                            and embedded widgets on partner sites — same
                            inventory, one setup. Every channel stays in
                            sync. Bookings flow into a single queue with no
                            duplicate work and no double-bookings.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        eyebrow="Outcome 05"
                        imageSrc="/solutions/placeholder.svg"
                        imageAlt="A seat locked across three booking channels at once"
                    >
                        <Fragment slot="title">
                            <em>Prevent</em> overbookings and revenue loss.
                        </Fragment>
                        <Fragment slot="body">
                            Inventory locks the instant a booking starts —
                            across every channel, simultaneously. No more
                            reconciling spreadsheets at midnight. No more
                            refunding angry customers on a Saturday morning.
                            The seat is yours the second a guest clicks
                            book, and the platform enforces it for you.
                        </Fragment>
                    </OutcomeCard>

                    <OutcomeCard
                        eyebrow="Outcome 06"
                        imageSrc="/solutions/placeholder.svg"
                        imageAlt="Unified booking queue with cards from multiple sources"
                    >
                        <Fragment slot="title">
                            <em>Manage</em> every booking in one place.
                        </Fragment>
                        <Fragment slot="body">
                            Whether it came through your widget,
                            GetYourGuide, an inbound email, or a sales rep —
                            it lands in the same queue. Edit, refund,
                            reassign, and generate tickets, vouchers, or
                            invoices on demand. Customer records build
                            themselves from every booking. No more
                            spreadsheet juggling.
                        </Fragment>
                    </OutcomeCard>
                </div>
            </div>
        </section>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
