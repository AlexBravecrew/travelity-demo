---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { CoverageList, CoverageItem } from '@/components/shared/coverage-list';
import { CalendlyWidget } from '@/components/book-demo';

export const prerender = true;
---

<MarketingLayout
    title="Book a Demo · Travelity"
    description="30 minutes. Zero prep needed. We'll walk you through Travelity in your own context."
>
    <Nav />

    <main>
        <section class="bg-paper py-10 md:py-14">
            <div class="container mx-auto px-6">
                <div
                    class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start"
                >
                    <!-- Left: text + coverage list -->
                    <div>
                        <Eyebrow
                            withRule
                            data-reveal
                            data-reveal-direction="left">Get started</Eyebrow
                        >

                        <h1
                            class="font-serif font-semibold text-ink leading-[1.02] tracking-[-0.035em] mt-6 mb-6"
                            style="font-size: clamp(36px, 4.2vw, 56px);"
                            data-reveal
                            data-reveal-direction="left"
                            data-reveal-delay="80"
                        >
                            See Travelity in action. Book a
                            <em class="not-italic">
                                <span
                                    class="italic font-medium text-travelity-teal"
                                >
                                    Personalized Demo.</span
                                >
                            </em>
                        </h1>

                        <p
                            class="text-lg text-ink-muted leading-[1.55] max-w-[52ch] mb-8"
                            data-reveal
                            data-reveal-direction="left"
                            data-reveal-delay="160"
                        >
                            30 minutes that can completely change the way you
                            run your travel business. See how Travelity can help
                            you work smarter, sell more, and operate with less
                            stress.
                        </p>

                        <p
                            class="font-mono text-xs font-semibold uppercase tracking-[0.10em] text-ink-soft mb-4"
                            data-reveal
                            data-reveal-direction="left"
                            data-reveal-delay="240"
                        >
                            What we'll cover
                        </p>

                        <CoverageList
                            class="mx-0 max-w-none"
                            data-reveal
                            data-reveal-direction="left"
                            data-reveal-delay="320"
                        >
                            <CoverageItem
                                title="Your Business Needs Discussion"
                                description="We learn about your current processes, challenges, and operational pain points."
                            />
                            <CoverageItem
                                title="Platform Walkthrough"
                                description="Live demonstration of Travelity and its core features in action."
                            />
                            <CoverageItem
                                title="Real Examples"
                                description="See how bookings, availability, sales channels, and daily coordination are managed inside the system."
                            />
                            <CoverageItem
                                title="Personalized Recommendations"
                                description="Discover how Travelity can help optimize your workflows and support your business growth."
                            />
                        </CoverageList>
                    </div>

                    <!-- Right: Calendly inline widget (native advanced embed) -->
                    <div>
                        <CalendlyWidget
                            data-reveal
                            data-reveal-direction="right"
                            data-reveal-delay="200"
                        />
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</MarketingLayout>
