---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { CoverageList, CoverageItem } from '@/components/shared/coverage-list';
import { CalendlyWidget } from '@/components/book-demo';

export const prerender = true;
---

<MarketingLayout
    title="Book a Demo · Travelity"
    description="30 minutes. Zero prep needed. We'll walk you through Travelity in your own context."
>
    <Nav />

    <main>
        <section class="bg-paper py-12 md:py-16">
            <div class="container mx-auto px-6">
                <div
                    class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start"
                >
                    <!-- Left: text + coverage list -->
                    <div>
                        <Eyebrow withRule>Book a demo</Eyebrow>

                        <h1
                            class="font-serif font-semibold text-ink leading-[1.02] tracking-[-0.035em] mt-6 mb-6"
                            style="font-size: clamp(36px, 4.2vw, 56px);"
                        >
                            30 minutes.
                            <em class="not-italic">
                                <span
                                    class="italic font-medium text-travelity-teal"
                                >
                                    Zero prep needed.</span
                                >
                            </em>
                        </h1>

                        <p
                            class="text-lg text-ink-muted leading-[1.55] max-w-[52ch] mb-8"
                        >
                            We'll walk you through Travelity in your own context
                            — bring your current booking spreadsheet if you have
                            one. No credit card required.
                        </p>

                        <p
                            class="font-mono text-xs font-semibold uppercase tracking-[0.10em] text-ink-soft mb-4"
                        >
                            What we'll cover
                        </p>

                        <CoverageList class="mx-0 max-w-none">
                            <CoverageItem
                                title="Walk through the platform"
                                description="The actual back-office, with your products and channels in mind."
                            />
                            <CoverageItem
                                title="Look at your bookings"
                                description="Bring an example, a spreadsheet, or just a question. We'll model it together."
                            />
                            <CoverageItem
                                title="Discuss your channels"
                                description="OTAs you sell on, your widget setup, holdback rules, channel pricing."
                            />
                            <CoverageItem
                                title="Map a path forward"
                                description="If we're a fit, we'll set up trial access and a migration plan."
                            />
                        </CoverageList>
                    </div>

                    <!-- Right: Calendly inline widget (native advanced embed) -->
                    <div>
                        <CalendlyWidget />
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</MarketingLayout>
