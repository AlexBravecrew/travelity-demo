---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Hero } from '@/components/home/hero';
import { ChannelsSection } from '@/components/home/channels-section';
import { FeaturesSection } from '@/components/home/features-section';
---

<MarketingLayout
    title="Travelity — Run your travel business without the spreadsheets"
    description="Bookings, channels, payments, and operations — one platform for the people who run travel."
>
    <Nav />

    <main>
        <Hero />
        <ChannelsSection />
        <FeaturesSection />

        <!-- Phase 3c–3d will add Parallax, Pricing, GoLive, ClosingCTA here -->
        <div
            class="container mx-auto px-6 py-32 text-center border-t border-line"
        >
            <p
                class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-soft"
            >
                Sections 4–7 — Phase 3c onward
            </p>
        </div>
    </main>

    <Footer />
</MarketingLayout>
