---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Button } from '@/components/ui/button';
import { Eyebrow } from '@/components/ui/eyebrow';
import { Tag } from '@/components/ui/tag';
import { LinkInline } from '@/components/ui/link-inline';
import { Card } from '@/components/ui/card';
import { SectionHeader } from '@/components/ui/section-header';
import { Paths } from '@/lib/utils/paths';
---

<MarketingLayout
    title="Travelity — Primitives Showcase"
    description="Visual testbed for Phase 1 primitives."
>
    <Nav />
    <div class="container mx-auto px-6 py-16 max-w-[960px]">
        <header class="mb-16">
            <Eyebrow withRule>Phase 1 — Primitives</Eyebrow>
            <h1
                class="font-serif font-semibold text-ink mt-4 leading-[1.02] tracking-[-0.035em]"
                style="font-size: clamp(40px, 5vw, 56px);"
            >
                Building blocks
            </h1>
            <p class="text-[18px] text-ink-muted mt-4 max-w-[540px]">
                Every variant of every primitive, on one page. The rest of the
                site composes from these.
            </p>
        </header>

        <!-- BUTTON ===================================================== -->
        <section class="mb-16 pb-16 border-b border-line">
            <Eyebrow>Button</Eyebrow>
            <h2
                class="font-display font-semibold text-ink text-[28px] tracking-[-0.025em] mt-3 mb-8"
            >
                Three variants × three sizes
            </h2>

            <div class="space-y-6">
                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        Primary
                    </p>
                    <div class="flex flex-wrap items-end gap-3">
                        <Button size="sm">Small primary</Button>
                        <Button size="md">Medium primary</Button>
                        <Button size="lg">Large primary</Button>
                        <Button size="md" withArrow>With arrow</Button>
                    </div>
                </div>

                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        Outline
                    </p>
                    <div class="flex flex-wrap items-end gap-3">
                        <Button variant="outline" size="sm"
                            >Small outline</Button
                        >
                        <Button variant="outline" size="md"
                            >Medium outline</Button
                        >
                        <Button variant="outline" size="lg"
                            >Large outline</Button
                        >
                        <Button variant="outline" size="md" withArrow
                            >With arrow</Button
                        >
                    </div>
                </div>

                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        Ghost
                    </p>
                    <div class="flex flex-wrap items-end gap-3">
                        <Button variant="ghost" size="sm">Small ghost</Button>
                        <Button variant="ghost" size="md">Medium ghost</Button>
                        <Button variant="ghost" size="lg">Large ghost</Button>
                    </div>
                </div>

                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        As link (href prop)
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <Button href={Paths.BOOK_DEMO} withArrow
                            >Book a demo</Button
                        >
                        <Button href={Paths.PRICING} variant="outline"
                            >See pricing</Button
                        >
                    </div>
                </div>

                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        Disabled
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <Button disabled>Disabled primary</Button>
                        <Button variant="outline" disabled
                            >Disabled outline</Button
                        >
                    </div>
                </div>
            </div>
        </section>

        <!-- EYEBROW ==================================================== -->
        <section class="mb-16 pb-16 border-b border-line">
            <Eyebrow>Eyebrow</Eyebrow>
            <h2
                class="font-display font-semibold text-ink text-[28px] tracking-[-0.025em] mt-3 mb-8"
            >
                Two configurations
            </h2>

            <div class="space-y-6">
                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        Default
                    </p>
                    <Eyebrow>Section label</Eyebrow>
                </div>
                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        With rule
                    </p>
                    <Eyebrow withRule>Section label with rule</Eyebrow>
                </div>
                <div>
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.10em] text-ink-soft mb-3"
                    >
                        Centered (used inside center-aligned section headers)
                    </p>
                    <div class="text-center">
                        <Eyebrow centered withRule>Centered with rule</Eyebrow>
                    </div>
                </div>
            </div>
        </section>

        <!-- TAG ======================================================== -->
        <section class="mb-16 pb-16 border-b border-line">
            <Eyebrow>Tag</Eyebrow>
            <h2
                class="font-display font-semibold text-ink text-[28px] tracking-[-0.025em] mt-3 mb-8"
            >
                Four semantic variants
            </h2>

            <div class="flex flex-wrap gap-3 items-center">
                <Tag>v2.4.1</Tag>
                <Tag variant="success">Synced</Tag>
                <Tag variant="warning">Action required</Tag>
                <Tag variant="destructive">1 double-booking prevented</Tag>
            </div>

            <p class="text-[14px] text-ink-muted mt-6 max-w-[540px]">
                The destructive variant uses semantic red. It's used for both
                error states <em>and</em> "bad thing prevented" callouts (the hero's
                double-booking pill). Same color, different context.
            </p>
        </section>

        <!-- LINK INLINE ================================================ -->
        <section class="mb-16">
            <Eyebrow>LinkInline</Eyebrow>
            <h2
                class="font-display font-semibold text-ink text-[28px] tracking-[-0.025em] mt-3 mb-8"
            >
                Inline navigation
            </h2>

            <div
                class="space-y-4 text-[16px] text-ink leading-[1.6] max-w-[540px]"
            >
                <p>
                    Read more about our approach in <LinkInline
                        href={Paths.OUR_STORY}>our story</LinkInline
                    >, or jump straight to <LinkInline
                        href={Paths.PRICING}
                        withArrow>pricing</LinkInline
                    >.
                </p>
                <p>
                    External links open in a new tab —
                    <LinkInline href="https://travelity.app" external
                        >travelity.app</LinkInline
                    >.
                </p>
            </div>
        </section>

        <!-- CARD ======================================================= -->
        <section class="mb-16 pb-16 border-b border-line">
            <Eyebrow>Card</Eyebrow>
            <h2
                class="font-display font-semibold text-ink text-[28px] tracking-[-0.025em] mt-3 mb-8"
            >
                Two variants, with optional hover and accent
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <Card class="p-7">
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-muted mb-2"
                    >
                        Default
                    </p>
                    <h3
                        class="font-display font-semibold text-[18px] text-ink mb-2"
                    >
                        Static card
                    </h3>
                    <p class="text-[14.5px] text-ink-muted leading-[1.6]">
                        No hover. Used for layout containers and metadata
                        blocks.
                    </p>
                </Card>

                <Card interactive class="p-7">
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-muted mb-2"
                    >
                        Default + interactive
                    </p>
                    <h3
                        class="font-display font-semibold text-[18px] text-ink mb-2"
                    >
                        Hover me
                    </h3>
                    <p class="text-[14.5px] text-ink-muted leading-[1.6]">
                        Lifts -4px on hover with a tinted ink shadow. Used for
                        feature cards.
                    </p>
                </Card>

                <Card variant="featured" interactive topAccent class="p-7">
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.12em] text-travelity-teal mb-2"
                    >
                        Featured
                    </p>
                    <h3
                        class="font-display font-semibold text-[18px] text-ink mb-2"
                    >
                        Highlighted in set
                    </h3>
                    <p class="text-[14.5px] text-ink-muted leading-[1.6]">
                        Teal border, teal-tinted shadow, gradient top accent.
                        Used for recommended pricing tier.
                    </p>
                </Card>
            </div>
        </section>

        <!-- SECTION HEADER ============================================== -->
        <section class="mb-16">
            <Eyebrow>SectionHeader</Eyebrow>
            <h2
                class="font-display font-semibold text-ink text-[28px] tracking-[-0.025em] mt-3 mb-8"
            >
                Two alignments, with the editorial italic-em
            </h2>

            <div class="space-y-12">
                <div class="border border-line rounded-[16px] p-10">
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-soft mb-6"
                    >
                        Center (default — home page sections)
                    </p>
                    <SectionHeader
                        eyebrow="Built for daily operations"
                        eyebrowWithRule
                    >
                        <Fragment slot="headline">
                            Everything you need, <em>nothing you don't.</em>
                        </Fragment>
                        <p
                            slot="dek"
                            class="text-[18px] text-ink-muted leading-[1.55] max-w-[56ch] mx-auto"
                        >
                            Six core capabilities, modeled the way real travel
                            businesses actually work — not the way booking
                            software thinks they should.
                        </p>
                    </SectionHeader>
                </div>

                <div class="border border-line rounded-[16px] p-10">
                    <p
                        class="font-mono text-[11px] uppercase tracking-[0.12em] text-ink-soft mb-6"
                    >
                        Left (Solutions / Audience pages)
                    </p>
                    <SectionHeader eyebrow="For tour operators" align="left">
                        <Fragment slot="headline">
                            Multi-day tours, <em>without the spreadsheet.</em>
                        </Fragment>
                        <p
                            slot="dek"
                            class="text-[18px] text-ink-muted leading-[1.55] max-w-[56ch]"
                        >
                            Build itineraries, manage participants, and run the
                            operation from one place — for one-day excursions to
                            multi-week packages.
                        </p>
                    </SectionHeader>
                </div>
            </div>
        </section>
    </div>
    <Footer />
</MarketingLayout>
