        title: 'Channel Manager',
        slug: 'channel-manager',
        headline: 'Channel Manager — headline placeholder.',
        lead: 'Lead description for Channel Manager — real copy coming soon.',
        bullets: [
            { label: 'Placeholder bullet one.' },
            { label: 'Placeholder bullet two.' },
            { label: 'Placeholder bullet three.' },
        ],
        image: '/features/placeholder.svg',
    },
    {
