---

<MarketingLayout
    title="Features · Travelity"
    description="The full set of Travelity capabilities — channel management, bookings, payments, operations, and the tools your team uses every day."
>
    <Nav />

    <main>
        <!-- Compact top section: short title, no hero -->
        <section class="bg-paper py-10 md:py-14">
            <div class="container mx-auto px-6 text-center">
                <Eyebrow withRule centered>Features</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.03em] max-w-[20ch] mx-auto mt-6 mb-5"
                    style="font-size: clamp(32px, 4vw, 48px);"
                >
                    Everything Travelity does,
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal">
                            in detail.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-lg text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                >
                    Nine capabilities your travel business runs on. Each
                    section below maps to the cards on the home page — click
                    any card there and you'll land here.
                </p>
            </div>
        </section>

        <!-- 9 feature sections, alternating flip. The id on each section
             is the anchor target for the home card's /features#<slug> link;
             scroll-mt-[var(--nav-height)] offsets the jump so the heading
             clears the sticky nav. -->
        {
            features.map((f, i) => (
                <CapabilitySection
                    id={f.slug}
                    eyebrow={f.title}
                    flip={i % 2 === 1}
                    bullets={f.bullets}
                    class="scroll-mt-[var(--nav-height)]"
                >
                    <Fragment slot="headline">{f.headline}</Fragment>
                    <Fragment slot="lead">{f.lead}</Fragment>
                    <Fragment slot="visual">
                        <img
                            src={f.image}
                            alt={`${f.title} screenshot`}
                            class="block w-full aspect-video rounded-xl bg-surface-alt border border-line object-cover"
                            loading="lazy"
                            decoding="async"
                        />
                    </Fragment>
                </CapabilitySection>
            ))
        }

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
