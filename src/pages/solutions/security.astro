---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Button } from '@/components/ui/button';
import { Paths } from '@/lib/utils/paths';

import { ProductHero, QuickFact } from '@/components/shared/product-hero';
import { CapabilitySection } from '@/components/shared/capability-section';
import { CrossSell, CrossSellCard } from '@/components/shared/cross-sell';

import { ClosingCTASection } from '@/components/home/closing-cta-section';

import { CalendarIcon, BarChartIcon, FileCheckIcon } from '@/icons';
---

<MarketingLayout
    title="Security & Compliance · Travelity"
    description="Your data is fully separated, encrypted everywhere, access-controlled by role, and aligned with GDPR — with SOC 2 and ISO 27001 in progress."
>
    <Nav />

    <main>
        <ProductHero eyebrow="Security & Compliance">
            <Fragment slot="headline">
                Security built for the businesses <em>that need it</em>.
            </Fragment>
            <Fragment slot="lead">
                Your data is fully separated from every other operator's.
                Encrypted at every step. Access is controlled by role, every
                action is logged. Aligned with GDPR, with formal SOC 2 and ISO
                27001 audits underway. The page you forward to your IT team.
            </Fragment>
            <Fragment slot="ctas">
                <Button href={Paths.BOOK_DEMO} size="lg" withArrow>
                    Book a Demo
                </Button>
                {
                    /* TODO: replace with the real whitepaper download once published */
                }
                <Button href={Paths.BOOK_DEMO} size="lg" variant="outline">
                    Download whitepaper
                </Button>
            </Fragment>
            <Fragment slot="aside">
                <QuickFact
                    label="Encryption"
                    value="Always on"
                    sub="at rest and in transit"
                />
                <QuickFact
                    label="Identity"
                    value="Auth0"
                    sub="roles, SSO available"
                />
                <QuickFact label="Hosted in" value="EU" sub="Frankfurt" />
            </Fragment>
        </ProductHero>

        <CapabilitySection
            eyebrow="Trust pillars"
            bullets={[
                {
                    label: 'Your data is fully separated from every other operator — enforced at the database, not just the application',
                },
                {
                    label: 'Encrypted on disk, in backups, and as it moves; encryption keys rotate automatically',
                },
                {
                    label: 'Access by role — view-only, ops, finance, admin; SSO available on Enterprise',
                },
                {
                    label: 'Every meaningful action logged — orders edited, refunds issued, settings changed; logs kept 13 months',
                },
            ]}
        >
            <Fragment slot="headline">Four foundations.</Fragment>
            <Fragment slot="lead">
                The four things every operator's IT team asks about — answered
                by the platform's architecture, not just by paperwork.
            </Fragment>
            <Fragment slot="visual">
                <div
                    class="aspect-video bg-surface-alt border border-line rounded-xl flex items-center justify-center text-ink-muted font-mono text-sm p-4 text-center"
                >
                    [Screenshot: security architecture diagram — workspace
                    isolation, encryption in transit/at rest, role-based access]
                </div>
            </Fragment>
        </CapabilitySection>

        <CapabilitySection
            eyebrow="Compliance"
            flip
            bullets={[
                { label: 'GDPR — Aligned' },
                { label: 'CCPA — Aligned' },
                { label: 'SOC 2 — In progress (audit underway)' },
                { label: 'ISO 27001 — In progress (audit underway)' },
            ]}
        >
            <Fragment slot="headline">
                Aligned with the frameworks your buyers ask about.
            </Fragment>
            <Fragment slot="lead">
                We list status honestly. "Aligned" means we follow the
                framework's controls in practice. "In progress" means we're
                working toward formal certification.
            </Fragment>
            <Fragment slot="visual">
                <div
                    class="aspect-video bg-surface-alt border border-line rounded-xl flex items-center justify-center text-ink-muted font-mono text-sm p-4 text-center"
                >
                    [Screenshot: compliance status table — GDPR/CCPA aligned,
                    SOC 2/ISO 27001 in progress with audit dates]
                </div>
            </Fragment>
        </CapabilitySection>

        <CapabilitySection
            eyebrow="Operations"
            bullets={[
                {
                    label: 'Incident response — 24/7 on-call, 24h breach notification, 72h written follow-up',
                },
                {
                    label: 'Business continuity — point-in-time restore within 7 days, daily snapshots for 30',
                },
                {
                    label: '4-hour worst-case recovery target, 1 hour max activity loss',
                },
                {
                    label: 'Data residency — EU (Frankfurt); third-country routing disclosed per integration',
                },
            ]}
        >
            <Fragment slot="headline">When things go sideways.</Fragment>
            <Fragment slot="lead">
                Procedures tested quarterly, not theoretical. Recovery targets
                you can plan around, written into the standard contract.
            </Fragment>
            <Fragment slot="visual">
                <div
                    class="aspect-video bg-surface-alt border border-line rounded-xl flex items-center justify-center text-ink-muted font-mono text-sm p-4 text-center"
                >
                    [Screenshot: ops dashboard — incident log, last
                    point-in-time-restore test date, region status]
                </div>
            </Fragment>
        </CapabilitySection>

        <CrossSell heading="Related, for the IT review.">
            <CrossSellCard
                href={Paths.SOLUTIONS_BOOKING_ENGINE}
                title="Booking Engine"
                description="The platform itself — what gets reviewed by your security team."
            >
                <CalendarIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
            <CrossSellCard
                href={Paths.SOLUTIONS_REPORTING}
                title="Reporting & BI"
                description="Read-only credentials, documented schema, audited query access."
            >
                <BarChartIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
            <CrossSellCard
                href={Paths.SOLUTIONS_PROPOSALS}
                title="Proposals"
                description="Tamper-proof signed links, audit trails, gateway-handled payment data."
            >
                <FileCheckIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
        </CrossSell>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
