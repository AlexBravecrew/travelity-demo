---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';

import { ProductHero, QuickFact } from '@/components/shared/product-hero';
import { PainGrid, PainCard } from '@/components/shared/pain-grid';
import { SolutionMap, SolutionRow } from '@/components/shared/solution-map';
import { FeaturePillars, PillarRow } from '@/components/shared/feature-pillars';
import { Workflow, WorkflowStep } from '@/components/shared/workflow';
import { PlanRec } from '@/components/shared/plan-rec';

import { ClosingCTASection } from '@/components/home/closing-cta-section';

import {
    CalendarDaysIcon,
    BedIcon,
    BoxesIcon,
    LanguagesIcon,
    TrendingUpIcon,
    MessageSquareIcon,
    FileCheckIcon,
    BarChartIcon,
} from '@/icons';
---

<MarketingLayout
    title="For Accommodation Hosts · Travelity"
    description="Per-night inventory with proper multi-night booking flow — and the same channel reach as Booking.com, without surrendering your direct guests."
>
    <Nav />

    <main>
        <ProductHero eyebrow="For Accommodation Hosts">
            <Fragment slot="headline">
                Per-night inventory, <em>without the OTA-only trade-off</em>.
            </Fragment>
            <Fragment slot="lead">
                Hotels, B&amp;Bs, guesthouses, apartments. Travelity gives you
                per-room, per-night availability with proper multi-night booking
                flow — and the same channel reach as Booking.com, without
                surrendering your direct guests to commission.
            </Fragment>
            <Fragment slot="aside">
                <QuickFact label="Inventory" value="Per-room" sub="per-night" />
                <QuickFact
                    label="Stay types"
                    value="Single · Multi-night · Long-term"
                />
                <QuickFact label="Recommended plan" value="Ultimate" />
            </Fragment>
        </ProductHero>

        <PainGrid>
            <PainCard
                num="Problem 01"
                title="OTA dependence eats your margin"
                description="Booking.com and Airbnb send guests but take 15–25%. Direct bookings would save the commission, but most booking software doesn't handle multi-night properly."
            />
            <PainCard
                num="Problem 02"
                title="Room types are not just labels"
                description="Standard king, deluxe with view, family suite. Each has its own capacity, pricing, amenities, and minimum stay rules. Generic booking tools treat them as text fields."
            />
            <PainCard
                num="Problem 03"
                title="Price parity across channels is a moving target"
                description="Direct guests pay one rate. Booking.com requires another. Airbnb a third. Keeping them aligned without breaking parity rules is a daily chore."
            />
        </PainGrid>

        <SolutionMap>
            <SolutionRow
                pain="OTA dependence eats your margin"
                solution="Direct bookings via your widget, with multi-night flow built right"
                sub="Embed Travelity on your site. Real per-night calendar, real multi-night pricing, real availability — no commission on direct."
            />
            <SolutionRow
                pain="Room types are not just labels"
                solution="Room types as proper inventory, not just labels"
                sub="Each room type has its own capacity, base rate, minimum stay, amenities, and channel visibility. Standard king is a different product from deluxe."
            />
            <SolutionRow
                pain="Price parity across channels is a moving target"
                solution="Per-channel pricing rules, automatic"
                sub="Direct rate, OTA rate, partner rate — set once, applied automatically per channel. Parity managed in one settings panel."
            />
        </SolutionMap>

        <FeaturePillars>
            <PillarRow
                title="Per-night availability + multi-night booking flow"
                description="Real calendar logic. A 3-night stay locks 3 nights, not 1. Multi-night pricing applies the right rule for the whole stay."
                spotlight
            >
                <CalendarDaysIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Room types modeled as products"
                description="Each room type has its own capacity, rate, minimum stay, amenities. Travelity treats them as bookable products."
            >
                <BedIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Direct booking widget"
                description="Embed on your site. No commission. Same availability pool as your OTAs — sold direct first."
            >
                <BoxesIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Multi-currency for international guests"
                description="Display in USD or EUR for international, charge in AMD or GEL. Conversion happens at checkout, audited."
            >
                <LanguagesIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Channel-level pricing"
                description="Different rates on direct vs Booking.com vs Airbnb, automatically applied per booking source."
            >
                <TrendingUpIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
        </FeaturePillars>

        <Workflow
            heading="A typical week for a 12-room boutique guesthouse in Dilijan."
        >
            <WorkflowStep
                when="Sunday"
                title="Set the week"
                description="Adjust pricing for the upcoming holiday weekend. Block out one suite for a returning guest. Apply rule across channels."
            >
                <CalendarDaysIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="Monday"
                title="Booking comes in"
                description="A French couple books a deluxe room for 4 nights via your widget. No commission. Confirmation email sent automatically."
            >
                <MessageSquareIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="Wednesday"
                title="OTA reservation lands"
                description="A 3-night stay arrives via Booking.com. Lands in your back-office with full guest details. Your housekeeping team sees it instantly."
            >
                <FileCheckIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="Friday"
                title="Revenue review"
                description="Direct vs Booking.com vs Airbnb. ADR, occupancy, channel mix. Export for accountant."
            >
                <BarChartIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
        </Workflow>

        <PlanRec
            planName="Ultimate"
            description="For accommodation hosts with multiple room types, multiple channels, and the goal of growing direct bookings without losing OTA reach."
        />

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
