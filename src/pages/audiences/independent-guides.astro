---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';

import { ProductHero, QuickFact } from '@/components/shared/product-hero';
import { PainGrid, PainCard } from '@/components/shared/pain-grid';
import { SolutionMap, SolutionRow } from '@/components/shared/solution-map';
import { FeaturePillars, PillarRow } from '@/components/shared/feature-pillars';
import { Workflow, WorkflowStep } from '@/components/shared/workflow';
import { PlanRec } from '@/components/shared/plan-rec';
import { CrossSell, CrossSellCard } from '@/components/shared/cross-sell';

import { ClosingCTASection } from '@/components/home/closing-cta-section';

import { Paths } from '@/lib/utils/paths';

import {
    CalendarDaysIcon,
    BoxesIcon,
    GlobeIcon,
    LayoutGridIcon,
    UsersIcon,
    MessageSquareIcon,
    MapPinIcon,
    CalendarIcon,
    CodeIcon,
    FileCheckIcon,
} from '@/icons';

export const prerender = true;
---

<MarketingLayout
    title="For Independent Guides · Travelity"
    description="One product, one event a day, fully online. Free. Real booking software, your widget at 1.9%, OTA access included — for solo guides."
>
    <Nav />

    <main>
        <ProductHero eyebrow="For Independent Guides">
            <Fragment slot="headline">
                One product, one event a day, <em>fully online</em>. Free.
            </Fragment>
            <Fragment slot="lead">
                Solo guides, drivers, single-route operators. Get a real booking
                system, your own simple widget, and access to GetYourGuide and
                Klook — at zero monthly cost. You only pay 1.9% on bookings made
                through your widget.
            </Fragment>
            <Fragment slot="aside">
                <QuickFact label="Monthly cost" value="$0" />
                <QuickFact
                    label="Online widget"
                    value="1.9%"
                    sub="per booking"
                />
                <QuickFact label="Recommended plan" value="Free" />
            </Fragment>
        </ProductHero>

        <PainGrid>
            <PainCard
                num="Problem 01"
                title="Manual everything"
                description="WhatsApp messages. Hand-written calendars. Excel sheets that everyone in the family edits. Lost double-bookings. Missed inquiries. Time bleeding away from actually guiding."
            />
            <PainCard
                num="Problem 02"
                title="Missing the OTA opportunity"
                description="GetYourGuide, Viator, and Klook send millions of travelers to local operators. But getting on them requires technical setup most solo guides skip — and they lose the bookings."
            />
            <PainCard
                num="Problem 03"
                title="Software that costs more than you make"
                description="Most booking platforms charge $50–200 a month before you've sold a single tour. For a solo guide running 3 days a week, the math doesn't work."
            />
        </PainGrid>

        <SolutionMap>
            <SolutionRow
                pain="Software that costs more than you make"
                solution="Real booking software, no monthly cost"
                sub="Manage availability, take bookings, generate confirmations — for free. Pay only 1.9% on bookings that come through your own widget."
            />
            <SolutionRow
                pain="Missing the OTA opportunity"
                solution="Connect to GetYourGuide and Klook"
                sub="Same OTA integrations as the big operators. List your tours on the channels travelers actually use. Bookings land in your dashboard automatically."
            />
            <SolutionRow
                pain="Manual everything"
                solution="Replace WhatsApp with a real workflow"
                sub="Calendar, daily view, customer database, automatic confirmations. Spend less time on coordination, more time on what you're actually good at."
            />
        </SolutionMap>

        <FeaturePillars>
            <PillarRow
                title="Free monthly subscription"
                description="$0 a month, every month. No surprise pricing tier when your booking volume grows. The Free plan stays free."
                spotlight
            >
                <CalendarDaysIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Online widget at 1.9%"
                description="Embed Travelity on your site or share your booking link. Pay only 1.9% on bookings that come through it."
            >
                <BoxesIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="OTA access included"
                description="Connect to GetYourGuide and Klook on Free. Same integrations as the larger operators."
            >
                <GlobeIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Daily view + availability calendar"
                description="What's booked today, what's open this week. The minimum viable backbone for a solo operation."
            >
                <LayoutGridIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Customer database"
                description="Every booking creates a customer record. No more reconstructing contacts from WhatsApp threads."
            >
                <UsersIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
        </FeaturePillars>

        <Workflow
            heading="A typical week for a solo Yerevan-based hiking guide."
        >
            <WorkflowStep
                when="Monday"
                title="Set the week"
                description="Open the calendar, mark Tuesday and Friday off. Wednesday morning blocked for a private booking. Done in 90 seconds."
            >
                <CalendarDaysIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="Tuesday"
                title="Booking via widget"
                description="A traveler from Berlin books your Geghard hike for Saturday via your website. Confirmation email auto-sent. You only pay 1.9%."
            >
                <MessageSquareIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="Thursday"
                title="GetYourGuide booking"
                description="Two more travelers book via GetYourGuide. They land in your dashboard with full details. You see your Saturday is now full."
            >
                <GlobeIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="Saturday"
                title="Just guide"
                description="Open daily view in the morning. See your group: 6 people, all paid, dietary notes for one. Run the tour."
            >
                <MapPinIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
        </Workflow>

        <PlanRec
            planName="Free"
            description="For solo guides, drivers, and small operators just getting their digital workflow online. Stays free as long as you need it."
        />

        <CrossSell heading="Where to next.">
            <CrossSellCard
                href={Paths.SOLUTIONS_WIDGET}
                title="Booking Widget"
                description="Take direct bookings on your own site — no commission, your branding."
            >
                <CodeIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
            <CrossSellCard
                href={Paths.SOLUTIONS_BOOKING_ENGINE}
                title="Booking Engine"
                description="Products, scheduling, pricing, and daily ops in one back-office."
            >
                <CalendarIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
            <CrossSellCard
                href={Paths.SOLUTIONS_PROPOSALS}
                title="Proposals"
                description="Custom quotes for B2B partners and group inquiries — paid via signed link."
            >
                <FileCheckIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
        </CrossSell>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
