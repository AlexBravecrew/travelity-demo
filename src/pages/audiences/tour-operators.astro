---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';

import { ProductHero, QuickFact } from '@/components/shared/product-hero';
import { PainGrid, PainCard } from '@/components/shared/pain-grid';
import { SolutionMap, SolutionRow } from '@/components/shared/solution-map';
import { FeaturePillars, PillarRow } from '@/components/shared/feature-pillars';
import { Workflow, WorkflowStep } from '@/components/shared/workflow';
import { PlanRec } from '@/components/shared/plan-rec';
import { CrossSell, CrossSellCard } from '@/components/shared/cross-sell';

import { ClosingCTASection } from '@/components/home/closing-cta-section';

import { Paths } from '@/lib/utils/paths';

import {
    CalendarDaysIcon,
    GlobeIcon,
    TrendingUpIcon,
    LayoutGridIcon,
    LanguagesIcon,
    MessageSquareIcon,
    FileCheckIcon,
    BarChartIcon,
    CalendarIcon,
} from '@/icons';

export const prerender = true;
---

<MarketingLayout
    title="For Tour Operators · Travelity"
    description="Run your tour operation without the spreadsheets. Products, schedules, prices, bookings, and team — in one place."
>
    <Nav />

    <main>
        <ProductHero eyebrow="For Tour Operators">
            <Fragment slot="headline">
                Run your tour operation <em>without the spreadsheets</em>.
            </Fragment>
            <Fragment slot="lead">
                Whether you run a small Yerevan day-tour outfit or a 40-person
                Tbilisi operation with three offices, Travelity holds the whole
                thing — products, schedules, prices, bookings, and team — in one
                place.
            </Fragment>
            <Fragment slot="aside">
                <QuickFact
                    label="Run on Travelity"
                    value="Group · Private · Multi-day"
                />
                <QuickFact
                    label="Sales channels"
                    value="3"
                    sub="OTAs · widget · direct"
                />
                <QuickFact label="Recommended plan" value="Ultimate" />
            </Fragment>
        </ProductHero>

        <PainGrid>
            <PainCard
                num="Problem 01"
                title="Multi-product chaos"
                description="Day tours, multi-day packages, transfers, bundles. Each with their own pricing, capacity, and ops. The spreadsheet you started with breaks at scale."
            />
            <PainCard
                num="Problem 02"
                title="OTA overhead"
                description="GetYourGuide, Viator, Klook, your own site, walk-ins. Updating availability across all of them eats hours every week — and one missed update means oversold bookings."
            />
            <PainCard
                num="Problem 03"
                title="Team coordination"
                description="Sales, ops, drivers, guides, accountants. Everyone needs different views of the same booking. Right now they're getting it via WhatsApp screenshots."
            />
        </PainGrid>

        <SolutionMap>
            <SolutionRow
                pain="Multi-product chaos"
                solution="Day tours, multi-day packages, transfers — all in one catalog"
                sub="Each product type has its own model. Tours by departure, multi-days by start date, transfers by route, accommodation by night."
            />
            <SolutionRow
                pain="OTA overhead"
                solution="One availability, every channel updated automatically"
                sub="Update inventory once in your back-office. Travelity pushes it to GetYourGuide, Viator, Klook, your widget, and your direct sales — same second."
            />
            <SolutionRow
                pain="Team coordination"
                solution="Workspaces with role-based access"
                sub="Sales sees the funnel. Ops sees today's departures. Drivers see their routes. Accountants see revenue. Same data, right view per person."
            />
        </SolutionMap>

        <FeaturePillars>
            <PillarRow
                title="Tours · Transfers · Stays"
                description="Every product type modeled the way it actually sells — group capacity, private bookings, room-night inventory."
            >
                <CalendarDaysIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Native OTA integrations"
                description="GetYourGuide and Klook live, Viator in beta. Bidirectional sync, hold-back rules per channel, automatic price differences."
            >
                <GlobeIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Pricing rules that actually work"
                description="Seasonal tiers, group-size discounts, per-channel overrides, holiday surcharges — with priority order so the right rule wins."
            >
                <TrendingUpIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Daily ops dashboard"
                description="Today's departures, who's driving, who's guiding, who's booked. The view your operations manager opens at 8am."
            >
                <LayoutGridIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
            <PillarRow
                title="Multi-currency"
                description="Sell in USD, EUR, AMD, GEL. Reconcile in your home currency. Daily rates from the Central Bank source."
            >
                <LanguagesIcon
                    slot="icon"
                    class="w-5 h-5"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </PillarRow>
        </FeaturePillars>

        <Workflow
            heading="A typical Tuesday for a Yerevan tour operator with three guides and a part-time accountant."
        >
            <WorkflowStep
                when="8:00 AM"
                title="Operations check"
                description="Open daily ops, see 6 departures today. Garni-Geghard at 9, Khor Virap at 10, two airport transfers, two custom tours."
            >
                <CalendarDaysIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="9:30 AM"
                title="OTA bookings land"
                description="Three GetYourGuide bookings come in for Saturday's wine tour. Synced to today's availability instantly. Holdback for direct sales kicks in."
            >
                <MessageSquareIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="2:00 PM"
                title="Custom proposal"
                description="B2B partner asks for a 12-person multi-day package. Build a proposal in 4 minutes, send a signed link. They pay tomorrow."
            >
                <FileCheckIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
            <WorkflowStep
                when="6:00 PM"
                title="Day closeout"
                description="Revenue by channel, capacity used, what's queued for tomorrow. Friday's Q3 report goes to the accountant in one click."
            >
                <BarChartIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="1.75"
                    aria-hidden="true"
                />
            </WorkflowStep>
        </Workflow>

        <PlanRec
            planName="Ultimate"
            description="For tour operators with multiple product types, OTA channels, and a team that needs structured access."
        />

        <CrossSell heading="Where to next.">
            <CrossSellCard
                href={Paths.SOLUTIONS_BOOKING_ENGINE}
                title="Booking Engine"
                description="Products, scheduling, pricing, and daily ops in one back-office."
            >
                <CalendarIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
            <CrossSellCard
                href={Paths.SOLUTIONS_INTEGRATIONS}
                title="OTA Integrations"
                description="Two-way connections with GetYourGuide, Viator, and Klook."
            >
                <GlobeIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
            <CrossSellCard
                href={Paths.SOLUTIONS_REPORTING}
                title="Reporting & BI"
                description="Operations data, queryable. Curated reports + BI tool connectors."
            >
                <BarChartIcon
                    slot="icon"
                    class="w-4 h-4"
                    stroke-width="2"
                    aria-hidden="true"
                />
            </CrossSellCard>
        </CrossSell>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
