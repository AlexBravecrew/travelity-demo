---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { Eyebrow } from '@/components/ui/eyebrow';
import { GuideCard } from '@/components/shared/guide-card';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;

interface Guide {
    category: string;
    title: string;
    description: string;
    readingTime: string;
    href: string;
}

// TODO: replace `#` hrefs with real guide article URLs as they're written.
const guides: Guide[] = [
    {
        category: 'Getting started',
        title: 'How to migrate from a spreadsheet',
        description:
            'A step-by-step approach to moving products, schedules, and historical bookings into Travelity without losing data.',
        readingTime: '8 min read',
        href: '#',
    },
    {
        category: 'Getting started',
        title: 'Setting up your first product',
        description:
            'Everything you need to model a tour, transfer, or accommodation product correctly the first time.',
        readingTime: '6 min read',
        href: '#',
    },
    {
        category: 'Getting started',
        title: 'Inviting your team',
        description:
            'How to add team members, set roles, and configure permissions for sales, ops, drivers, and accountants.',
        readingTime: '4 min read',
        href: '#',
    },
    {
        category: 'Channels',
        title: 'Connecting GetYourGuide',
        description:
            'Two-way OTA integration walkthrough: connecting your account, mapping products, and configuring holdback rules.',
        readingTime: '7 min read',
        href: '#',
    },
    {
        category: 'Channels',
        title: 'Embedding the booking widget',
        description:
            'Three lines of code, your branding, and the same shared availability as every other channel.',
        readingTime: '5 min read',
        href: '#',
    },
    {
        category: 'Channels',
        title: 'Channel pricing and overrides',
        description:
            'When to use the same price across all channels, and when (and how) to differentiate.',
        readingTime: '6 min read',
        href: '#',
    },
    {
        category: 'Operations',
        title: 'Daily ops checklist',
        description:
            'The view your operations manager opens at 8am — what to check, what to assign, what to confirm.',
        readingTime: '5 min read',
        href: '#',
    },
    {
        category: 'Operations',
        title: 'Building proposals for B2B partners',
        description:
            'Custom group inquiries, multi-day packages, and partner orders — closed online with one signed link.',
        readingTime: '7 min read',
        href: '#',
    },
    {
        category: 'Reporting',
        title: 'Connecting your BI tool',
        description:
            'How to pipe Travelity data into Looker, Metabase, or Superset for custom reporting.',
        readingTime: '6 min read',
        href: '#',
    },
];
---

<MarketingLayout
    title="Guides · Travelity"
    description="Practical guides for setting up and running Travelity — migrations, integrations, daily operations, and more."
>
    <Nav />

    <main class="bg-paper">
        <!-- Hero strip -->
        <section
            class="border-b border-line py-12 md:py-16 text-center"
            style="background: radial-gradient(ellipse 60% 50% at 50% 0%, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%), hsl(var(--paper));"
        >
            <div class="container mx-auto px-6 max-w-[820px]">
                <Eyebrow withRule centered>Guides</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.035em] mt-5 mb-5"
                    style="font-size: clamp(34px, 4.4vw, 48px);"
                >
                    Practical, not theoretical.
                </h1>

                <p
                    class="text-[18px] text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                >
                    Real-world walkthroughs for the things operators actually do
                    — migrations, integrations, daily ops, reporting.
                </p>
            </div>
        </section>

        <!-- Guides grid -->
        <section class="py-12 md:py-16">
            <div class="container mx-auto px-6">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-[1200px] mx-auto"
                >
                    {
                        guides.map((guide) => (
                            <GuideCard
                                href={guide.href}
                                category={guide.category}
                                title={guide.title}
                                description={guide.description}
                                readingTime={guide.readingTime}
                            />
                        ))
                    }
                </div>
            </div>
        </section>

        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
