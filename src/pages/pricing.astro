---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Nav } from '@/components/chrome/nav';
import { Footer } from '@/components/chrome/footer';
import { SectionHeader } from '@/components/ui/section-header';
import { Eyebrow } from '@/components/ui/eyebrow';

import { PricingSection } from '@/components/home/pricing-section';
import {
    ComparisonTable,
    type ComparisonGroup,
} from '@/components/shared/comparison-table';
import { FaqAccordion, FaqItem } from '@/components/shared/faq-accordion';
import { ClosingCTASection } from '@/components/home/closing-cta-section';

export const prerender = true;

// Placeholder comparison data — same shape as PricingPlan's placeholder copy.
// TODO: replace with real feature labels and per-plan values before launch.
const comparisonGroups: ComparisonGroup[] = [
    {
        heading: 'Bookings & channels',
        rows: [
            {
                label: 'Feature row 1',
                values: ['Up to 50/mo', 'Unlimited', 'Unlimited'],
            },
            { label: 'Feature row 2', values: [true, true, true] },
            {
                label: 'Feature row 3',
                sub: 'optional sub-text',
                values: [false, true, true],
            },
            {
                label: 'Feature row 4',
                values: ['1 type', 'All 3 types', 'All 3 types'],
            },
        ],
    },
    {
        heading: 'Operations & team',
        rows: [
            {
                label: 'Feature row 5',
                values: ['1 user', 'Up to 5', 'Unlimited'],
            },
            { label: 'Feature row 6', values: [false, true, true] },
            { label: 'Feature row 7', values: [false, false, true] },
            {
                label: 'Feature row 8',
                sub: 'optional sub-text',
                values: [false, true, true],
            },
        ],
    },
    {
        heading: 'Reporting & integrations',
        rows: [
            { label: 'Feature row 9', values: [false, true, true] },
            { label: 'Feature row 10', values: [false, false, true] },
            {
                label: 'Feature row 11',
                sub: 'optional sub-text',
                values: [false, false, true],
            },
        ],
    },
    {
        heading: 'Support',
        rows: [
            {
                label: 'Feature row 12',
                values: ['Email', 'Priority', 'Priority + SLA'],
            },
            { label: 'Feature row 13', values: [false, false, true] },
        ],
    },
];
---

<MarketingLayout
    title="Pricing · Travelity"
    description="Plans for every size of operation. From solo guides to multi-product operators with serious volume."
>
    <Nav />

    <main>
        <!-- Hero strip -->
        <section
            class="bg-paper py-12 md:py-16 text-center"
            style="background: radial-gradient(ellipse 60% 50% at 50% 0%, hsl(var(--travelity-teal) / 0.08) 0%, transparent 60%), hsl(var(--paper));"
        >
            <div class="container mx-auto px-6">
                <Eyebrow withRule centered>Pricing</Eyebrow>

                <h1
                    class="font-serif font-semibold text-ink leading-[1.05] tracking-[-0.035em] max-w-[18ch] mx-auto mt-5 mb-5"
                    style="font-size: clamp(36px, 4.6vw, 56px);"
                >
                    Plans for every
                    <em class="not-italic">
                        <span class="italic font-medium text-travelity-teal"
                            >size of operation.</span
                        >
                    </em>
                </h1>

                <p
                    class="text-[18px] text-ink-muted leading-[1.55] max-w-[60ch] mx-auto"
                >
                    From solo guides on the Free plan to multi-product operators
                    on Ultimate. Same booking engine, same channel reach —
                    different limits, different support tiers.
                </p>
            </div>
        </section>

        <!-- Plan cards (reused from home; section header suppressed since the page hero above already shows the same title) -->
        <PricingSection hideHeader />

        <!-- Comparison table -->
        <section class="bg-paper py-12 md:py-16 border-t border-line">
            <div class="container mx-auto px-6">
                <SectionHeader
                    eyebrow="Compare plans"
                    eyebrowWithRule
                    align="center"
                >
                    <Fragment slot="headline">
                        Side by side, every detail.
                    </Fragment>
                    <p
                        slot="dek"
                        class="text-[16px] text-ink-muted leading-[1.55] max-w-[52ch] mx-auto"
                    >
                        Pick the plan that matches the shape of your operation,
                        not the one that sounds biggest.
                    </p>
                </SectionHeader>

                <div class="mt-2 max-w-[1100px] mx-auto">
                    <ComparisonTable
                        groups={comparisonGroups}
                        featuredIndex={1}
                    />
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="bg-surface-alt py-12 md:py-16">
            <div class="container mx-auto px-6">
                <SectionHeader
                    eyebrow="Pricing FAQ"
                    eyebrowWithRule
                    align="center"
                >
                    <Fragment slot="headline">Common questions.</Fragment>
                </SectionHeader>

                <FaqAccordion class="mt-2">
                    <FaqItem question="Do I need a credit card to start?">
                        No. The Free plan is genuinely free — no card required.
                        The 30-day Plus trial also doesn't ask for a card. We
                        only collect payment when you actively choose a paid
                        plan.
                    </FaqItem>

                    <FaqItem question="Can I switch plans later?">
                        Yes, at any time. Upgrades take effect immediately.
                        Downgrades take effect at the end of your current
                        billing period — your data and access stay the same;
                        only the plan limits change.
                    </FaqItem>

                    <FaqItem
                        question="What counts as a 'booking' on the Free plan?"
                    >
                        Any confirmed booking that consumes inventory. Quotes,
                        proposals, and cancelled orders don't count toward the
                        limit. We show your usage in the dashboard so there are
                        no surprises.
                    </FaqItem>

                    <FaqItem
                        question="Are OTA commissions included in your pricing?"
                    >
                        No — OTA commissions are charged by the OTAs themselves
                        (GetYourGuide, Viator, Klook), and those are separate
                        from your Travelity subscription. Travelity itself takes
                        no commission on bookings, ever.
                    </FaqItem>

                    <FaqItem question="What payment methods do you accept?">
                        Credit cards (via Stripe) and SEPA direct debit for EU
                        customers. Annual plans can be paid by bank transfer —
                        contact us for details.
                    </FaqItem>

                    <FaqItem question="Can I get a refund?">
                        Monthly plans are non-refundable but you can cancel any
                        time. Annual plans are refundable on a pro-rata basis
                        within the first 30 days. After that, you keep access
                        until the end of the term.
                    </FaqItem>

                    <FaqItem
                        question="Do you offer discounts for non-profits or educational organizations?"
                    >
                        Yes. Reach out via the demo form and let us know your
                        situation — we typically offer 20–30% off for verified
                        non-profits and educational institutions.
                    </FaqItem>

                    <FaqItem question="What happens to my data if I cancel?">
                        You can export everything (bookings, customers,
                        products) as CSV at any time, including after
                        cancellation. We keep your data for 90 days
                        post-cancellation in case you change your mind, then
                        permanently delete it.
                    </FaqItem>
                </FaqAccordion>
            </div>
        </section>

        <!-- Closing CTA — reused from home (default copy) -->
        <ClosingCTASection />
    </main>

    <Footer />
</MarketingLayout>
