---
import {
    LegalPageLayout,
    type TocItem,
} from '@/components/shared/legal-page-layout';

export const prerender = true;

const tocItems: TocItem[] = [
    { id: 'introduction', label: '1. Introduction' },
    { id: 'information-we-collect', label: '2. Information we collect' },
    { id: 'how-we-use-information', label: '3. How we use your information' },
    { id: 'data-sharing', label: '4. Data sharing & third parties' },
    { id: 'data-security', label: '5. Data security' },
    { id: 'data-retention', label: '6. Data retention' },
    { id: 'user-rights', label: '7. User rights & choices' },
    { id: 'international-transfers', label: '8. International data transfers' },
    { id: 'governing-law', label: '9. Governing law' },
    { id: 'changes', label: '10. Changes to this policy' },
    { id: 'contact', label: '11. Contact us' },
];
---

<LegalPageLayout
    title="Privacy Policy"
    tagline="How Travelity collects, uses, and protects information."
    lastUpdated="February 4, 2025"
    effectiveDate="February 4, 2025"
    tocItems={tocItems}
    description="Travelity's privacy policy: what data we collect, how we use it, your rights, and how to contact us."
    showDraftBanner={false}
>
    <h2 id="introduction">1. Introduction</h2>
    <p>
        BraveCrew Inc. (&ldquo;Company,&rdquo; &ldquo;we,&rdquo;
        &ldquo;us,&rdquo; or &ldquo;our&rdquo;) operates Travelity, a tour
        booking management software. We are committed to protecting your privacy
        and ensuring the security of personal data collected through our
        platform. This Privacy Policy explains how we collect, use, store, and
        protect your information.
    </p>

    <h2 id="information-we-collect">2. Information we collect</h2>
    <p>When you use Travelity, we may collect the following information:</p>
    <ul>
        <li>
            <strong>Customer data:</strong> business details, names, email addresses,
            phone numbers, and other identifiers provided during account creation.
        </li>
        <li>
            <strong>End-user data:</strong> information entered about customers booking
            services, such as names, contact details, and booking preferences.
        </li>
        <li>
            <strong>Payment information:</strong> billing details necessary for subscription
            processing.
        </li>
        <li>
            <strong>Technical information:</strong> IP addresses, device details,
            and usage statistics to enhance platform performance.
        </li>
        <li>
            <strong>Communications:</strong> any correspondence with our support or
            sales teams.
        </li>
    </ul>

    <h2 id="how-we-use-information">3. How we use your information</h2>
    <p>We process collected data for the following purposes:</p>
    <ul>
        <li>Providing and managing the Travelity platform.</li>
        <li>Processing bookings and managing customer relationships.</li>
        <li>Communicating important service updates.</li>
        <li>Improving platform functionality and security.</li>
        <li>Complying with legal and regulatory requirements.</li>
    </ul>

    <h2 id="data-sharing">4. Data sharing & third-party services</h2>
    <ul>
        <li>We do not sell or rent your personal data.</li>
        <li>
            We may share data with service providers (e.g. payment processors,
            cloud storage providers) strictly for operational purposes.
        </li>
        <li>
            If required by law, we may disclose information to regulatory
            authorities.
        </li>
    </ul>

    <h2 id="data-security">5. Data security</h2>
    <p>
        We implement industry-standard security measures to protect personal
        data from unauthorized access, alteration, or disclosure. However, no
        system is entirely secure, and users should also take precautions in
        handling sensitive data.
    </p>

    <h2 id="data-retention">6. Data retention</h2>
    <ul>
        <li>
            We retain customer data for as long as necessary to provide services
            and comply with legal obligations.
        </li>
        <li>
            End-user data entered into Travelity is managed by the respective
            Customer and can be deleted upon request.
        </li>
    </ul>

    <h2 id="user-rights">7. User rights & choices</h2>
    <p>
        Depending on your location and applicable laws, you may have the right
        to:
    </p>
    <ul>
        <li>Access, update, or delete your personal data.</li>
        <li>Opt out of marketing communications.</li>
        <li>Request details on how your data is used.</li>
        <li>Submit complaints regarding data handling.</li>
    </ul>

    <h2 id="international-transfers">8. International data transfers</h2>
    <p>
        As Travelity operates under BraveCrew Inc., a <strong
            >Delaware, USA</strong
        >-registered company, data may be stored or processed in the United
        States or other jurisdictions. We ensure compliance with relevant data
        protection laws when transferring data internationally.
    </p>

    <h2 id="governing-law">9. Governing law</h2>
    <p>
        This Privacy Policy is governed by and interpreted under the laws of the <strong
            >State of Delaware, USA</strong
        >. Any disputes arising from this policy will be subject to the
        exclusive jurisdiction of the courts located in Delaware.
    </p>

    <h2 id="changes">10. Changes to this privacy policy</h2>
    <p>
        We may update this Privacy Policy periodically. Continued use of
        Travelity after changes take effect constitutes acceptance of the
        revised terms.
    </p>

    <h2 id="contact">11. Contact us</h2>
    <p>
        For any questions or data requests, please contact us at <a
            href="mailto:support@travelity.app">support@travelity.app</a
        >.
    </p>
    <p>By using Travelity, you acknowledge and agree to this Privacy Policy.</p>
    <p>
        BraveCrew Inc.<br />
        651 N Broad St, Suite 201<br />
        Middletown, Delaware, 19709, US
    </p>
</LegalPageLayout>
