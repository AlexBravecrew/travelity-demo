---
import {
    LegalPageLayout,
    type TocItem,
} from '@/components/shared/legal-page-layout';

export const prerender = true;

const tocItems: TocItem[] = [
    { id: 'what-are-cookies', label: 'What are cookies?' },
    { id: 'cookies-we-use', label: 'Cookies we use' },
    { id: 'analytics', label: 'Analytics and marketing' },
    { id: 'third-party', label: 'Third-party cookies' },
    { id: 'managing-cookies', label: 'Managing cookies' },
    { id: 'do-not-track', label: 'Do Not Track' },
    { id: 'changes', label: 'Changes to this policy' },
    { id: 'contact', label: 'Contact' },
];
---

<LegalPageLayout
    title="Cookies Policy"
    tagline="What cookies Travelity uses, why, and how you can control them."
    lastUpdated="May 1, 2026"
    effectiveDate="May 1, 2026"
    tocItems={tocItems}
    description="Travelity's cookies policy: types of cookies used, purposes, third parties, and how to manage your preferences."
>
    <h2 id="what-are-cookies">What are cookies?</h2>
    <p>
        Cookies are small text files placed on your device by websites you
        visit. They are widely used to make websites work efficiently, to
        remember preferences, and to provide information to website operators.
        Similar technologies (such as local storage and pixels) are sometimes
        used in addition to or instead of cookies — references to
        &ldquo;cookies&rdquo; in this policy include those technologies.
    </p>

    <h2 id="cookies-we-use">Cookies we use</h2>
    <p>We use cookies that fall into the following categories:</p>
    <ul>
        <li>
            <strong>Strictly necessary:</strong> required to operate the Services.
            These include session cookies for authentication and CSRF protection.
            You cannot opt out of strictly necessary cookies because the Services
            would not function without them.
        </li>
        <li>
            <strong>Functional:</strong> remember your preferences, such as language,
            theme, or recently-viewed content.
        </li>
        <li>
            <strong>Analytics:</strong> help us understand how visitors and customers
            use the Services, so we can improve them. Analytics data is aggregated
            and doesn't identify you personally.
        </li>
        <li>
            <strong>Marketing:</strong> measure the effectiveness of our campaigns
            and may be set by third parties when you visit our website. You can opt
            out of marketing cookies via your browser or our cookie preferences UI
            [TBD].
        </li>
    </ul>

    <h2 id="analytics">Analytics and marketing</h2>
    <p>
        We use analytics services such as [analytics provider TBD — e.g.
        Plausible, Fathom, or Google Analytics] to understand traffic patterns
        and improve the Services. These services may use cookies or similar
        technologies; the data collected is described in the provider's own
        privacy notice.
    </p>
    <p>
        We may also use marketing tools to measure ad effectiveness on platforms
        where we run campaigns (for example, LinkedIn or search engines). These
        tools may set cookies on your device when you click an ad or visit our
        site from a campaign source.
    </p>

    <h2 id="third-party">Third-party cookies</h2>
    <p>
        Some pages may include content or functionality from third parties (such
        as embedded videos, social-media share buttons, or live-chat widgets).
        These third parties may set their own cookies, governed by their privacy
        policies. We have no control over third-party cookies; please consult
        the relevant provider for details.
    </p>

    <h2 id="managing-cookies">Managing cookies</h2>
    <p>
        You can control cookies through your browser settings. Most browsers let
        you:
    </p>
    <ul>
        <li>
            See which cookies are stored and delete individual or all cookies.
        </li>
        <li>Block third-party cookies.</li>
        <li>
            Block all cookies (note: blocking strictly necessary cookies will
            prevent the Services from working).
        </li>
        <li>Receive a prompt before a cookie is set.</li>
    </ul>
    <p>
        Browser-specific instructions are available at <a
            href="https://www.allaboutcookies.org"
            rel="noopener noreferrer">allaboutcookies.org</a
        >.
    </p>
    <p>
        For website visitors in the EU/EEA and other jurisdictions with consent
        requirements, we present a cookie banner on first visit allowing you to
        accept, reject, or customize cookie preferences (excluding strictly
        necessary cookies). You can change your choices at any time via the
        [cookie preferences link TBD] in our footer.
    </p>

    <h2 id="do-not-track">Do Not Track</h2>
    <p>
        &ldquo;Do Not Track&rdquo; is a browser preference indicating that you
        do not want to be tracked across websites. Because there is no industry
        consensus on how to interpret Do Not Track signals, we currently do not
        respond to them. Our cookie controls described above provide an
        alternative way to manage your preferences.
    </p>

    <h2 id="changes">Changes to this policy</h2>
    <p>
        We may update this Cookies Policy from time to time. When we do, we
        revise the &ldquo;Last updated&rdquo; date at the top.
    </p>

    <h2 id="contact">Contact</h2>
    <p>
        For cookie-related inquiries:<br />BraveCrew Inc.<br />Email: <a
            href="mailto:privacy@travelity.app">privacy@travelity.app</a
        >
    </p>
</LegalPageLayout>
