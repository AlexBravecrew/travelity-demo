---
import {
    LegalPageLayout,
    type TocItem,
} from '@/components/shared/legal-page-layout';

export const prerender = true;

const tocItems: TocItem[] = [
    { id: 'introduction', label: '1. Introduction' },
    { id: 'defined-terms', label: '2. Defined terms & interpretation' },
    { id: 'rights-and-obligations', label: '3. Customer rights and obligations' },
    { id: 'intellectual-property', label: '4. Intellectual property rights' },
    { id: 'payment-terms', label: '5. Payment terms' },
    { id: 'termination', label: '6. Termination or suspension' },
    { id: 'confidentiality', label: '7. Confidentiality' },
    { id: 'data-protection', label: '8. Data protection' },
    { id: 'dispute-resolution', label: '9. Dispute resolution' },
    { id: 'force-majeure', label: '10. Force majeure' },
    { id: 'amendments', label: '11. Amendments & contact' },
];
---

<LegalPageLayout
    title="Terms and Conditions"
    tagline="The agreement between you and Travelity for use of the platform."
    lastUpdated="February 4, 2025"
    effectiveDate="February 4, 2025"
    tocItems={tocItems}
    description="Travelity's terms and conditions: customer rights, obligations, payments, termination, and dispute resolution."
    showDraftBanner={false}
>
    <h2 id="introduction">1. Introduction</h2>
    <p>
        Travelity is a tour booking management software developed and operated
        by BraveCrew Inc., registered at 651 N Broad St Suite 201, Middletown,
        Delaware, 19709, US. These Terms and Conditions govern your use of
        Travelity. By accessing or using the platform, you agree to abide by
        these terms. If you do not agree, you must discontinue use immediately.
    </p>

    <h2 id="defined-terms">2. Defined terms & interpretation</h2>
    <ul>
        <li>
            <strong>&ldquo;Company,&rdquo; &ldquo;We,&rdquo;
            &ldquo;Us,&rdquo;</strong> refers to BraveCrew Inc. operating
            Travelity.
        </li>
        <li>
            <strong>&ldquo;Customer,&rdquo; &ldquo;You&rdquo;</strong> refers
            to any company, tour operator, or guide using Travelity.
        </li>
        <li>
            <strong>&ldquo;Platform&rdquo;</strong> refers to the Travelity
            software and related services.
        </li>
        <li>
            <strong>&ldquo;Subscription Plan&rdquo;</strong> refers to the paid
            service tier selected by the Customer.
        </li>
        <li>
            <strong>&ldquo;Trial Period&rdquo;</strong> refers to any free or
            limited access period offered by Travelity.
        </li>
        <li>
            <strong>&ldquo;Agreement&rdquo;</strong> refers to this document and
            any updates made to it.
        </li>
        <li>Singular terms include plural meanings where applicable.</li>
    </ul>

    <h2 id="rights-and-obligations">3. Customer rights and obligations</h2>
    <h3>3.1 Customer rights</h3>
    <ul>
        <li>
            You have the right to access and use Travelity in accordance with
            your selected subscription plan.
        </li>
        <li>
            You have the right to receive platform updates, support, and any
            features included in your plan.
        </li>
        <li>
            You have the right to manage bookings, customer data, and content
            within the platform in compliance with applicable laws.
        </li>
        <li>
            You have the right to terminate your subscription as per the
            termination terms outlined in this agreement.
        </li>
        <li>
            You have the right to request information regarding how your data
            is handled in accordance with our <a href="/legal/privacy"
                >Privacy Policy</a
            >.
        </li>
    </ul>

    <h3>3.2 Customer obligations</h3>
    <ul>
        <li>You must provide accurate, lawful business information.</li>
        <li>
            You are responsible for all activities and bookings managed through
            your account.
        </li>
        <li>You must comply with all applicable laws and regulations.</li>
        <li>
            You shall not use the platform for unlawful, fraudulent, or
            unethical activities.
        </li>
        <li>
            You must ensure that uploaded content does not infringe on
            third-party rights.
        </li>
    </ul>

    <h3>3.3 Our rights & obligations</h3>
    <ul>
        <li>
            We provide access to the Travelity platform based on your
            subscription plan.
        </li>
        <li>
            We may modify, suspend, or discontinue services with prior notice,
            except in cases of a breach.
        </li>
        <li>
            We reserve the right to remove or disable content that violates
            these Terms.
        </li>
        <li>
            We maintain the right to update software features, pricing, and
            service offerings.
        </li>
    </ul>

    <h2 id="intellectual-property">4. Intellectual property rights</h2>
    <ul>
        <li>
            BraveCrew Inc. retains all ownership rights to the Travelity
            software, trademarks, and content.
        </li>
        <li>
            You may not copy, modify, or distribute any part of the software
            unless expressly permitted.
        </li>
        <li>
            Any feedback or suggestions provided by you may be used by Travelity
            without compensation.
        </li>
    </ul>

    <h2 id="payment-terms">5. Payment terms</h2>
    <ul>
        <li>
            Travelity offers a <strong>free version</strong> with limited
            features and <strong>subscription plans</strong> on a monthly or
            annual basis.
        </li>
        <li>
            Payments are due in advance, invoiced for the selected period, and
            are <strong>non-refundable</strong>.
        </li>
        <li>
            Subscriptions may be set to <strong>auto-renew</strong> or require
            <strong>manual renewal</strong> as per the chosen plan.
        </li>
        <li>
            Failure to make payments within the specified period may result in
            suspension or termination.
        </li>
        <li>
            Travelity reserves the right to adjust pricing with prior notice.
        </li>
    </ul>

    <h2 id="termination">6. Termination or suspension</h2>
    <p>We may suspend or terminate your access if:</p>
    <ul>
        <li>You breach these Terms.</li>
        <li>You fail to make timely payments.</li>
        <li>You engage in fraudulent, illegal, or harmful activities.</li>
        <li>Your use of the platform causes harm to Travelity or its users.</li>
    </ul>
    <p>
        Termination does not relieve you of outstanding payment obligations.
    </p>

    <h2 id="confidentiality">7. Confidentiality</h2>
    <ul>
        <li>
            Both parties agree to keep confidential any proprietary or
            business-sensitive information.
        </li>
        <li>
            Confidentiality obligations survive termination of this agreement.
        </li>
        <li>
            You agree not to disclose, share, or misuse confidential
            information received from Travelity.
        </li>
    </ul>

    <h2 id="data-protection">8. Data protection</h2>
    <ul>
        <li>Travelity complies with applicable data protection laws.</li>
        <li>
            We collect, process, and store data as described in our <a
                href="/legal/privacy">Privacy Policy</a
            >.
        </li>
        <li>
            Customers must ensure compliance with data protection laws when
            handling user data.
        </li>
        <li>
            Travelity is not liable for unauthorized access due to user
            negligence.
        </li>
    </ul>

    <h2 id="dispute-resolution">9. Dispute resolution</h2>
    <ul>
        <li>
            Any disputes shall first be resolved through good-faith
            negotiations.
        </li>
        <li>
            If unresolved, disputes shall be referred to arbitration under
            Delaware law.
        </li>
        <li>
            Legal proceedings may only be initiated after arbitration efforts
            have been exhausted.
        </li>
    </ul>

    <h2 id="force-majeure">10. Force majeure</h2>
    <p>
        We are not liable for delays or failure to perform due to unforeseen
        events beyond our control, including natural disasters, government
        actions, cyberattacks, or other force majeure events.
    </p>

    <h2 id="amendments">11. Amendments & contact information</h2>
    <ul>
        <li>
            We reserve the right to update these Terms. Continued use of
            Travelity after changes constitutes acceptance.
        </li>
        <li>Customers will be notified of significant changes.</li>
        <li>
            For inquiries, contact us at <a href="mailto:legal@travelity.app"
                >legal@travelity.app</a
            >.
        </li>
    </ul>
    <p>
        By using Travelity, you acknowledge and agree to these Terms and
        Conditions.
    </p>
    <p>
        BraveCrew Inc.<br />
        651 N Broad St, Suite 201<br />
        Middletown, Delaware, 19709, US
    </p>
</LegalPageLayout>
