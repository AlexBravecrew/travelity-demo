---
import {
    LegalPageLayout,
    type TocItem,
} from '@/components/shared/legal-page-layout';

export const prerender = true;

const tocItems: TocItem[] = [
    { id: 'overview', label: 'Overview' },
    { id: 'definitions', label: 'Definitions' },
    { id: 'roles', label: 'Roles and responsibilities' },
    { id: 'processing', label: 'Scope of processing' },
    { id: 'security-measures', label: 'Security measures' },
    { id: 'subprocessors', label: 'Subprocessors' },
    { id: 'data-subject-rights', label: 'Data subject rights' },
    { id: 'breach-notification', label: 'Breach notification' },
    { id: 'international-transfers', label: 'International transfers' },
    { id: 'audits', label: 'Audits' },
    { id: 'return-deletion', label: 'Return or deletion of data' },
    { id: 'contact', label: 'Contact' },
];
---

<LegalPageLayout
    title="Data Processing Agreement"
    tagline="How Travelity processes personal data on behalf of customers."
    lastUpdated="May 1, 2026"
    effectiveDate="May 1, 2026"
    tocItems={tocItems}
    description="Travelity's Data Processing Agreement (DPA): roles, processing scope, security measures, subprocessors, and data subject rights."
>
    <h2 id="overview">Overview</h2>
    <p>
        This Data Processing Agreement (&ldquo;DPA&rdquo;) supplements the Terms
        of Service between you (&ldquo;Customer&rdquo;) and BraveCrew Inc.
        (&ldquo;Travelity&rdquo;) and applies to the processing of personal data
        by Travelity on Customer's behalf in the course of providing the
        Services.
    </p>
    <p>
        This DPA reflects the parties' obligations under applicable data
        protection laws, including the EU General Data Protection Regulation
        (GDPR) and equivalent regimes.
    </p>

    <h2 id="definitions">Definitions</h2>
    <p>
        Capitalized terms not defined here have the meanings given in the Terms
        of Service or, where applicable, the GDPR.
    </p>
    <ul>
        <li>
            <strong>Customer Personal Data:</strong> personal data that Customer or
            its end-users submit to or generate within the Services.
        </li>
        <li>
            <strong>Data Subject:</strong> the identified or identifiable natural
            person to whom Customer Personal Data relates (typically Customer's customers,
            employees, or contacts).
        </li>
        <li>
            <strong>Processing:</strong> any operation performed on personal data,
            as defined under applicable law.
        </li>
        <li>
            <strong>Subprocessor:</strong> a third party engaged by Travelity to process
            Customer Personal Data.
        </li>
    </ul>

    <h2 id="roles">Roles and responsibilities</h2>
    <p>
        For Customer Personal Data, Customer acts as the
        &ldquo;controller&rdquo; (or equivalent) and Travelity acts as the
        &ldquo;processor&rdquo; (or equivalent). Customer is responsible for the
        lawful basis of processing and for providing required notices to Data
        Subjects. Travelity processes Customer Personal Data only on Customer's
        documented instructions, which include the Terms of Service, this DPA,
        and Customer's use of the Services.
    </p>

    <h2 id="processing">Scope of processing</h2>
    <p>
        <strong>Subject matter:</strong> provision of the Travelity platform and related
        services.
    </p>
    <p>
        <strong>Duration:</strong> for the term of the Customer's agreement with Travelity,
        plus any post-termination retention period described in the Terms of Service.
    </p>
    <p>
        <strong>Nature and purpose:</strong> hosting, processing, transmitting, and
        otherwise operating on Customer Personal Data as needed to provide the Services.
    </p>
    <p>
        <strong>Categories of Data Subjects:</strong> Customer's end-users, including
        booking guests, contacts, employees, and other individuals whose personal
        data Customer chooses to process via the Services.
    </p>
    <p>
        <strong>Categories of personal data:</strong> contact information (name, email,
        phone), booking details, transaction records, and other categories Customer
        chooses to enter into the Services. Customer must not submit special categories
        of personal data (sensitive data) without entering into a separate written
        agreement with Travelity.
    </p>

    <h2 id="security-measures">Security measures</h2>
    <p>
        Travelity implements appropriate technical and organizational measures
        to protect Customer Personal Data, including:
    </p>
    <ul>
        <li>Encryption in transit (TLS 1.2+) and at rest (AES-256).</li>
        <li>
            Role-based access controls and the principle of least privilege.
        </li>
        <li>
            Audit logging of access to production systems and Customer data.
        </li>
        <li>Regular vulnerability scanning and penetration testing.</li>
        <li>
            Background checks and confidentiality obligations for personnel with
            access to Customer Personal Data.
        </li>
        <li>
            Data segregation: each Customer's data is logically separated from
            every other Customer's data.
        </li>
        <li>Business continuity and incident response procedures.</li>
    </ul>
    <p>
        Travelity is aligned with the principles of ISO/IEC 27001 and SOC 2;
        formal audits are underway. Updated security documentation is available
        on request.
    </p>

    <h2 id="subprocessors">Subprocessors</h2>
    <p>
        Customer authorizes Travelity to engage subprocessors to process
        Customer Personal Data, subject to (a) a written agreement requiring the
        subprocessor to provide protections substantially equivalent to those in
        this DPA, and (b) Travelity remaining responsible for the subprocessor's
        compliance.
    </p>
    <p>
        Current subprocessors include providers for hosting, payment processing,
        email delivery, error tracking, and analytics. A current list is
        maintained at <a href="/legal/subprocessors"
            >travelity.app/legal/subprocessors</a
        > [page TBD]. We will provide at least 30 days' notice of new subprocessors
        via email; Customer may object on reasonable grounds, and we will work in
        good faith to resolve any objection.
    </p>

    <h2 id="data-subject-rights">Data subject rights</h2>
    <p>
        Travelity provides functionality within the Services that enables
        Customer to respond to Data Subject requests (access, correction,
        deletion, portability, restriction, objection). Where a Data Subject
        contacts Travelity directly, Travelity will, where reasonably possible,
        redirect the request to Customer and assist Customer in responding,
        taking into account the nature of the processing.
    </p>

    <h2 id="breach-notification">Breach notification</h2>
    <p>
        Travelity will notify Customer without undue delay (and in any event
        within 72 hours where reasonably possible) of becoming aware of a
        personal data breach affecting Customer Personal Data. Notice will
        include, where available, a description of the breach, the categories
        and approximate number of Data Subjects affected, likely consequences,
        and measures taken to address the breach.
    </p>

    <h2 id="international-transfers">International transfers</h2>
    <p>
        Travelity hosts Customer Personal Data in the European Union (Frankfurt,
        Germany) by default. Where personal data is transferred outside the
        EU/EEA — including for support, monitoring, or backup purposes —
        Travelity will rely on appropriate safeguards under applicable law,
        including the European Commission's Standard Contractual Clauses (2021)
        where required.
    </p>

    <h2 id="audits">Audits</h2>
    <p>
        Travelity will make available to Customer information necessary to
        demonstrate compliance with this DPA. Customer may, on reasonable notice
        and no more than once per year (except as required by law or following a
        security incident), request information about Travelity's security
        measures, including current third-party audit reports. On-site audits
        may be arranged for Ultimate-plan customers under reasonable
        confidentiality and operational constraints.
    </p>

    <h2 id="return-deletion">Return or deletion of data</h2>
    <p>
        On termination of the Services, Customer may export Customer Personal
        Data in CSV format from within the Services. Travelity retains Customer
        Personal Data for 90 days after termination, after which it is
        permanently deleted from production systems, except where applicable law
        requires longer retention. Backup data is purged in accordance with our
        standard backup retention schedule.
    </p>

    <h2 id="contact">Contact</h2>
    <p>
        For DPA-related inquiries:<br />BraveCrew Inc.<br />Email: <a
            href="mailto:dpo@travelity.app">dpo@travelity.app</a
        >
    </p>
</LegalPageLayout>
