# Calendly scheduling URL with theme params baked in.
# Defaults to the production URL hard-coded in CalendlyWidget.astro if unset.
PUBLIC_CALENDLY_URL=https://calendly.com/travelity-sales/30min?text_color=3a4d7d&primary_color=55b5cf

# ============================================================
# Analytics (Phase 23)
#
# All four PUBLIC_* vars are inlined at build time. Set in Netlify
# (or `.env` for prod builds) — leave unset in local dev so analytics
# scripts are NEVER injected during `astro dev` (the Analytics
# component returns null when `import.meta.env.DEV === true`).
#
# Defaults below are v1 production IDs; the Analytics component falls
# back to them if env vars are unset, so a prod build "just works"
# even without env config. Set explicit values to override.
# ============================================================

# Google Analytics 4 measurement ID. Format: G-XXXXXXXXXX.
PUBLIC_GA4_ID=G-4SDEHMDC2F

# Google Ads conversion account ID. Format: AW-XXXXXXXXXX.
PUBLIC_GOOGLE_ADS_ID=AW-17231403747

# Google Ads conversion label — appended to the Ads ID as `send_to`
# in the Calendly-booking conversion event. Format: alphanumeric.
PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=o6zNCP7t0fYaEOO1yZhA

# CookieYes consent management platform — Google-certified CMP
# integrated with IAB TCF, required for personalized Google Ads in
# EU/UK/Switzerland (Google policy effective Jan 16, 2024). The
# client_id below is v1's production CookieYes account; the banner
# UI + category config lives in their dashboard.
PUBLIC_COOKIEYES_CLIENT_ID=a13b12d7f7983235806273d7
